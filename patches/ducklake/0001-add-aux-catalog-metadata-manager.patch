+unique_ptr<DuckLakeSnapshot> AuxCatalogMetadataManager::GetSnapshot() {
+	auto output = RuntimeExecute("GetConflictSnapshot", "");
+	if (output.find("catalog_snapshot_exists=false") != string::npos) {
+		return nullptr;
+	}
+	return make_uniq<DuckLakeSnapshot>(RequireRuntimeIndex(output, "ducklake_snapshot_id"),
+	                                   RequireRuntimeIndex(output, "ducklake_schema_version"),
+	                                   RequireRuntimeIndex(output, "ducklake_next_catalog_id"),
+	                                   RequireRuntimeIndex(output, "ducklake_next_file_id"));
+}
+
+unique_ptr<DuckLakeSnapshot> AuxCatalogMetadataManager::GetSnapshot(BoundAtClause &at_clause, SnapshotBound bound) {
+	auto &unit = at_clause.Unit();
+	auto &val = at_clause.GetValue();
+	string operation;
+	string payload;
+	if (StringUtil::CIEquals(unit, "version")) {
+		auto snapshot_id = val.DefaultCastAs(LogicalType::UBIGINT).GetValue<idx_t>();
+		operation = "GetSnapshotAt";
+		payload = StringUtil::Format("snapshot_id=%d\n", snapshot_id);
+	} else if (StringUtil::CIEquals(unit, "timestamp")) {
+		auto timestamp = val.DefaultCastAs(LogicalType::TIMESTAMP_TZ).GetValue<timestamp_tz_t>();
+		operation = "GetSnapshotAtTimestamp";
+		payload = StringUtil::Format("timestamp_micros=%lld\nbound=%s\n", timestamp.value,
+		                             bound == SnapshotBound::LOWER_BOUND ? "lower" : "upper");
+	} else {
+		throw InvalidInputException("Unsupported AT clause unit - %s", unit);
+	}
+	auto output = RuntimeExecute(operation, payload);
+	if (output.find("catalog_snapshot_exists=false") != string::npos) {
+		throw InvalidInputException("No snapshot found at %s %s", StringUtil::Lower(unit), val.ToString());
+	}
+	return make_uniq<DuckLakeSnapshot>(RequireRuntimeIndex(output, "ducklake_snapshot_id"),
+	                                   RequireRuntimeIndex(output, "ducklake_schema_version"),
+	                                   RequireRuntimeIndex(output, "ducklake_next_catalog_id"),
+	                                   RequireRuntimeIndex(output, "ducklake_next_file_id"));
+}
