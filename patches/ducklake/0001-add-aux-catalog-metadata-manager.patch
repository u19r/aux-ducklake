+static void RejectUnsafeInlinePayloadValue(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog runtime %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static vector<idx_t> InlineRowCountsFromOutput(const string &output) {
+	vector<idx_t> row_counts;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("inline_table_stats\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 3) {
+			throw IOException("aux_catalog runtime returned invalid inline_table_stats row: %s", line);
+		}
+		row_counts.push_back(AuxCatalogParseIndex(fields[1], "inline row count"));
+	}
+	return row_counts;
+}
+
+static int64_t ParseI64(const string &value, const char *field_name) {
+	try {
+		return NumericCast<int64_t>(std::stoll(value));
+	} catch (std::exception &ex) {
+		throw IOException("aux_catalog runtime returned invalid %s '%s': %s", field_name, value, ex.what());
+	}
+}
+
+static optional_idx ParseOptionalIndex(const string &value, const char *field_name) {
+	if (value.empty()) {
+		return optional_idx();
+	}
+	auto parsed = ParseI64(value, field_name);
+	if (parsed < 0) {
+		throw IOException("aux_catalog runtime returned negative %s '%s'", field_name, value);
+	}
+	return NumericCast<idx_t>(parsed);
+}
+
+static unsigned char HexNibble(char c) {
+	if (c >= '0' && c <= '9') {
+		return NumericCast<unsigned char>(c - '0');
+	}
+	if (c >= 'a' && c <= 'f') {
+		return NumericCast<unsigned char>(c - 'a' + 10);
+	}
+	if (c >= 'A' && c <= 'F') {
+		return NumericCast<unsigned char>(c - 'A' + 10);
+	}
+	throw IOException("aux_catalog runtime returned invalid hex payload");
+}
+
+static string HexDecode(const string &value) {
+	if (value.size() % 2 != 0) {
+		throw IOException("aux_catalog runtime returned odd-length hex payload");
+	}
+	string result;
+	result.reserve(value.size() / 2);
+	for (idx_t i = 0; i < value.size(); i += 2) {
+		auto byte = static_cast<unsigned char>((HexNibble(value[i]) << 4) | HexNibble(value[i + 1]));
+		result.push_back(static_cast<char>(byte));
+	}
+	return result;
+}
+
+static Value DeserializeDuckDbValue(string payload) {
+	MemoryStream stream(data_ptr_cast(payload.data()), payload.size());
+	BinaryDeserializer deserializer(stream);
+	deserializer.Begin();
+	auto value = Value::Deserialize(deserializer);
+	deserializer.End();
+	return value;
+}
+
+static Value DecodeValue(const string &encoded, const LogicalType &type) {
+	if (encoded == "n:") {
+		return Value(type);
+	}
+	if (encoded.rfind("b:", 0) == 0) {
+		if (type.id() != LogicalTypeId::BOOLEAN) {
+			throw IOException("aux_catalog inline boolean payload read as %s", type.ToString());
+		}
+		if (encoded == "b:1") {
+			return Value::BOOLEAN(true);
+		}
+		if (encoded == "b:0") {
+			return Value::BOOLEAN(false);
+		}
+		throw IOException("aux_catalog runtime returned invalid boolean payload: %s", encoded);
+	}
+	if (encoded.rfind("i:", 0) == 0) {
+		auto value = ParseI64(encoded.substr(2), "inline integer");
+		switch (type.id()) {
+		case LogicalTypeId::TINYINT:
+			return Value::TINYINT(NumericCast<int8_t>(value));
+		case LogicalTypeId::SMALLINT:
+			return Value::SMALLINT(NumericCast<int16_t>(value));
+		case LogicalTypeId::INTEGER:
+			return Value::INTEGER(NumericCast<int32_t>(value));
+		case LogicalTypeId::BIGINT:
+			return Value::BIGINT(value);
+		case LogicalTypeId::UTINYINT:
+			return Value::UTINYINT(NumericCast<uint8_t>(value));
+		case LogicalTypeId::USMALLINT:
+			return Value::USMALLINT(NumericCast<uint16_t>(value));
+		case LogicalTypeId::UINTEGER:
+			return Value::UINTEGER(NumericCast<uint32_t>(value));
+		case LogicalTypeId::UBIGINT:
+			return Value::UBIGINT(NumericCast<uint64_t>(value));
+		default:
+			throw IOException("aux_catalog inline integer payload read as %s", type.ToString());
+		}
+	}
+	if (encoded.rfind("s:", 0) == 0) {
+		if (type.id() != LogicalTypeId::VARCHAR) {
+			throw IOException("aux_catalog inline string payload read as %s", type.ToString());
+		}
+		return Value(HexDecode(encoded.substr(2)));
+	}
+	if (encoded.rfind("x:", 0) == 0) {
+		if (type.id() != LogicalTypeId::BLOB) {
+			throw IOException("aux_catalog inline blob payload read as %s", type.ToString());
+		}
+		return Value::BLOB_RAW(HexDecode(encoded.substr(2)));
+	}
+	if (encoded.rfind("d:", 0) == 0) {
+		auto value = DeserializeDuckDbValue(HexDecode(encoded.substr(2)));
+		if (value.type() != type) {
+			throw IOException("aux_catalog inline DuckDB payload read as %s, expected %s", value.type().ToString(),
+			                  type.ToString());
+		}
+		return value;
+	}
+	if (encoded.rfind("v:", 0) == 0) {
+		if (type.id() == LogicalTypeId::VARIANT) {
+			throw IOException("aux_catalog inline VARIANT payload must use DuckDB serialized encoding");
+		}
+		Value cast_value;
+		auto text = HexDecode(encoded.substr(2));
+		if (!Value(text).DefaultTryCastAs(type, cast_value, nullptr)) {
+			throw IOException("aux_catalog inline scalar payload '%s' cannot be read as %s", text, type.ToString());
+		}
+		return cast_value;
+	}
+	throw IOException("aux_catalog runtime returned invalid inline value payload: %s", encoded);
+}
+
+static string NormalizeProjectionName(string value) {
+	if (value.rfind("CAST(", 0) == 0 && value.back() == ')') {
+		auto as_pos = value.find(" AS ");
+		if (as_pos != string::npos) {
+			value = value.substr(5, as_pos - 5);
+		}
+	}
+	if (value.size() >= 2 && value.front() == '"' && value.back() == '"') {
+		string result;
+		for (idx_t i = 1; i + 1 < value.size(); i++) {
+			if (value[i] == '"' && i + 2 < value.size() && value[i + 1] == '"') {
+				result.push_back('"');
+				i++;
+			} else {
+				result.push_back(value[i]);
+			}
+		}
+		return result;
+	}
+	return value;
+}
+
+static idx_t FindColumnIndex(const vector<AuxInlineColumn> &columns, const string &name) {
+	for (idx_t i = 0; i < columns.size(); i++) {
+		if (columns[i].name == name || StringUtil::CIEquals(columns[i].name, name)) {
+			return i;
+		}
+	}
+	throw IOException("aux_catalog runtime did not return inline column %s", name);
+}
+
+static LogicalType ParseRuntimeType(ClientContext &context, const string &type_name) {
+	if (type_name == "float32") {
+		return LogicalType::FLOAT;
+	}
+	if (type_name == "float64") {
+		return LogicalType::DOUBLE;
+	}
+	try {
+		return TransformStringToLogicalType(type_name, context);
+	} catch (std::exception &ex) {
+		throw IOException("aux_catalog runtime returned invalid column type '%s': %s", type_name, ex.what());
+	}
+}
+
+static optional_ptr<LogicalType> TryProjectionCastType(ClientContext &context, const string &value,
+                                                       LogicalType &cast_type) {
+	if (value.rfind("CAST(", 0) != 0 || value.back() != ')') {
+		return nullptr;
+	}
+	auto as_pos = value.find(" AS ");
+	if (as_pos == string::npos) {
+		return nullptr;
+	}
+	auto type_name = value.substr(as_pos + 4, value.size() - as_pos - 5);
+	cast_type = ParseRuntimeType(context, type_name);
+	return optional_ptr<LogicalType>(&cast_type);
+}
+
+static vector<AuxInlineProjection> BuildProjection(ClientContext &context, const vector<AuxInlineColumn> &columns,
+                                                   const vector<string> &columns_to_read) {
+	vector<AuxInlineProjection> projection;
+	projection.reserve(columns_to_read.size());
+	for (auto &raw_name : columns_to_read) {
+		LogicalType cast_type;
+		auto projected_type = TryProjectionCastType(context, raw_name, cast_type);
+		auto name = NormalizeProjectionName(raw_name);
+		if (StringUtil::CIEquals(name, "row_id")) {
+			projection.push_back({name, LogicalType::BIGINT, "row_id", DConstants::INVALID_INDEX});
+			continue;
+		}
+		if (StringUtil::CIEquals(name, "begin_snapshot")) {
+			projection.push_back({name, LogicalType::BIGINT, "begin_snapshot", DConstants::INVALID_INDEX});
+			continue;
+		}
+		if (StringUtil::CIEquals(name, "end_snapshot")) {
+			projection.push_back({name, LogicalType::BIGINT, "end_snapshot", DConstants::INVALID_INDEX});
+			continue;
+		}
+		auto column_index = FindColumnIndex(columns, name);
+		projection.push_back({name, projected_type ? *projected_type : columns[column_index].type, string(), column_index});
+	}
+	return projection;
+}
+
+static void ParseReadInlineRowsOutput(ClientContext &context, const string &output, vector<AuxInlineColumn> &columns,
+                                      vector<AuxInlineRow> &rows) {
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		if (line.rfind("column\t", 0) == 0) {
+			auto fields = AuxCatalogSplitTabLine(line);
+			if (fields.size() != 5) {
+				throw IOException("aux_catalog runtime returned invalid inline column row: %s", line);
+			}
+			columns.push_back({fields[2], ParseRuntimeType(context, fields[3])});
+			continue;
+		}
+		if (line.rfind("row\t", 0) == 0) {
+			auto fields = AuxCatalogSplitTabLine(line);
+			if (fields.size() < 2) {
+				throw IOException("aux_catalog runtime returned invalid inline row: %s", line);
+			}
+			AuxInlineRow row;
+			row.row_id = ParseI64(fields[1], "inline row_id");
+			row.begin_snapshot = optional_idx();
+			row.end_snapshot = optional_idx();
+			row.values.assign(fields.begin() + 2, fields.end());
+			rows.push_back(std::move(row));
+			continue;
+		}
+		if (line.rfind("row_change\t", 0) == 0) {
+			auto fields = AuxCatalogSplitTabLine(line);
+			if (fields.size() < 5) {
+				throw IOException("aux_catalog runtime returned invalid inline change row: %s", line);
+			}
+			AuxInlineRow row;
+			row.begin_snapshot = ParseOptionalIndex(fields[1], "inline begin_snapshot");
+			row.end_snapshot = ParseOptionalIndex(fields[2], "inline end_snapshot");
+			row.row_id = ParseI64(fields[3], "inline row_id");
+			row.values.assign(fields.begin() + 4, fields.end());
+			rows.push_back(std::move(row));
+		}
+	}
+	std::sort(rows.begin(), rows.end(), [](const AuxInlineRow &left, const AuxInlineRow &right) {
+		if (left.row_id != right.row_id) {
+			return left.row_id < right.row_id;
+		}
+		if (left.begin_snapshot.IsValid() != right.begin_snapshot.IsValid()) {
+			return left.begin_snapshot.IsValid();
+		}
+		if (left.begin_snapshot.IsValid() && left.begin_snapshot.GetIndex() != right.begin_snapshot.GetIndex()) {
+			return left.begin_snapshot.GetIndex() < right.begin_snapshot.GetIndex();
+		}
+		return false;
+	});
+}
+
+static void AppendInlineDataChunk(ClientContext &context, ColumnDataCollection &collection, DuckLakeSnapshot snapshot,
+                                  const vector<AuxInlineProjection> &projection, const vector<AuxInlineRow> &rows,
+                                  idx_t offset, idx_t count) {
+	vector<LogicalType> types;
+	types.reserve(projection.size());
+	for (auto &column : projection) {
+		types.push_back(column.type);
+	}
+	DataChunk chunk;
+	chunk.Initialize(context, types);
+	for (idx_t row_idx = 0; row_idx < count; row_idx++) {
+		auto &row = rows[offset + row_idx];
+		for (idx_t col_idx = 0; col_idx < projection.size(); col_idx++) {
+			auto &column = projection[col_idx];
+			if (column.virtual_name == "row_id") {
+				chunk.data[col_idx].SetValue(row_idx, Value::BIGINT(row.row_id));
+				continue;
+			}
+			if (column.virtual_name == "begin_snapshot") {
+				auto begin_snapshot = row.begin_snapshot.IsValid() ? row.begin_snapshot.GetIndex() : snapshot.snapshot_id;
+				chunk.data[col_idx].SetValue(row_idx, Value::BIGINT(NumericCast<int64_t>(begin_snapshot)));
+				continue;
+			}
+			if (column.virtual_name == "end_snapshot") {
+				if (!row.end_snapshot.IsValid()) {
+					chunk.data[col_idx].SetValue(row_idx, Value(LogicalType::BIGINT));
+				} else {
+					chunk.data[col_idx].SetValue(row_idx,
+					                             Value::BIGINT(NumericCast<int64_t>(row.end_snapshot.GetIndex())));
+				}
+				continue;
+			}
+			if (column.value_index >= row.values.size()) {
+				throw IOException("aux_catalog inline row has too few values for requested column %s", column.name);
+			}
+			chunk.data[col_idx].SetValue(row_idx, DecodeValue(row.values[column.value_index], column.type));
+		}
+	}
+	chunk.SetChildCardinality(count);
+	collection.Append(chunk);
+}
+
+static unique_ptr<QueryResult> BuildInlineQueryResult(ClientContext &context, DuckLakeSnapshot snapshot,
+                                                      const vector<AuxInlineProjection> &projection,
+                                                      const vector<AuxInlineRow> &rows) {
+	vector<string> names;
+	vector<LogicalType> types;
+	names.reserve(projection.size());
+	types.reserve(projection.size());
+	for (idx_t i = 0; i < projection.size(); i++) {
+		auto &column = projection[i];
+		names.push_back(StringUtil::Format("col%d", i + 1));
+		types.push_back(column.type);
+	}
+	auto collection = make_uniq<ColumnDataCollection>(context, types);
+	for (idx_t offset = 0; offset < rows.size(); offset += STANDARD_VECTOR_SIZE) {
+		auto count = MinValue<idx_t>(STANDARD_VECTOR_SIZE, rows.size() - offset);
+		AppendInlineDataChunk(context, *collection, snapshot, projection, rows, offset, count);
+	}
+	StatementProperties properties;
+	return make_uniq<MaterializedQueryResult>(StatementType::SELECT_STATEMENT, properties, std::move(names),
+	                                          std::move(collection), ClientProperties());
+}
+
+static unique_ptr<QueryResult> BuildInlineRowsOutput(ClientContext &context, DuckLakeSnapshot snapshot,
+                                                     const vector<string> &columns_to_read,
+                                                     const vector<AuxInlineColumn> &columns,
+                                                     vector<AuxInlineRow> &rows);
+
+static unique_ptr<QueryResult> BuildInlineRowsOutput(ClientContext &context, DuckLakeSnapshot snapshot,
+                                                     const vector<string> &columns_to_read, const string &output) {
+	vector<AuxInlineColumn> columns;
+	vector<AuxInlineRow> rows;
+	ParseReadInlineRowsOutput(context, output, columns, rows);
+	return BuildInlineRowsOutput(context, snapshot, columns_to_read, columns, rows);
+}
+
+static unique_ptr<QueryResult> BuildInlineRowsOutput(ClientContext &context, DuckLakeSnapshot snapshot,
+                                                     const vector<string> &columns_to_read,
+                                                     const vector<AuxInlineColumn> &columns,
+                                                     vector<AuxInlineRow> &rows) {
+	for (auto &row : rows) {
+		if (row.values.size() != columns.size()) {
+			throw IOException("aux_catalog inline row value count does not match table schema");
+		}
+	}
+	auto projection = BuildProjection(context, columns, columns_to_read);
+	return BuildInlineQueryResult(context, snapshot, projection, rows);
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::ReadInlinedData(DuckLakeSnapshot snapshot,
+                                                                    const string &inlined_table_name,
+                                                                    const vector<string> &columns_to_read) {
+	auto remapped_table_name = RemapCreatedInlinedTableName(inlined_table_name);
+	RejectUnsafeInlinePayloadValue(remapped_table_name, "inlined table name");
+	auto output = RuntimeExecute(
+	    "ReadInlineRows",
+	    StringUtil::Format("inlined_table_name=%s\nsnapshot_id=%d\n", remapped_table_name, snapshot.snapshot_id));
+	auto context_ptr = transaction.context.lock();
+	vector<AuxInlineColumn> columns;
+	vector<AuxInlineRow> rows;
+	ParseReadInlineRowsOutput(*context_ptr, output, columns, rows);
+	return BuildInlineRowsOutput(*context_ptr, snapshot, columns_to_read, columns, rows);
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::ReadInlinedDataInsertions(DuckLakeSnapshot start_snapshot,
+                                                                             DuckLakeSnapshot end_snapshot,
+                                                                             const string &inlined_table_name,
+                                                                             const vector<string> &columns_to_read) {
+	auto remapped_table_name = RemapCreatedInlinedTableName(inlined_table_name);
+	RejectUnsafeInlinePayloadValue(remapped_table_name, "inlined table name");
+	auto output = RuntimeExecute(
+	    "ListInlineRowInsertions",
+	    StringUtil::Format("inlined_table_name=%s\nstart_snapshot_id=%d\nend_snapshot_id=%d\n", remapped_table_name,
+	                       start_snapshot.snapshot_id, end_snapshot.snapshot_id));
+	auto context_ptr = transaction.context.lock();
+	return BuildInlineRowsOutput(*context_ptr, end_snapshot, columns_to_read, output);
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::ReadInlinedDataDeletions(DuckLakeSnapshot start_snapshot,
+                                                                            DuckLakeSnapshot end_snapshot,
+                                                                            const string &inlined_table_name,
+                                                                            const vector<string> &columns_to_read) {
+	auto remapped_table_name = RemapCreatedInlinedTableName(inlined_table_name);
+	RejectUnsafeInlinePayloadValue(remapped_table_name, "inlined table name");
+	auto output = RuntimeExecute(
+	    "ListInlineRowDeletions",
+	    StringUtil::Format("inlined_table_name=%s\nstart_snapshot_id=%d\nend_snapshot_id=%d\n", remapped_table_name,
+	                       start_snapshot.snapshot_id, end_snapshot.snapshot_id));
+	auto context_ptr = transaction.context.lock();
+	return BuildInlineRowsOutput(*context_ptr, end_snapshot, columns_to_read, output);
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::ReadAllInlinedDataForFlush(
+    DuckLakeSnapshot snapshot, const string &inlined_table_name, const vector<string> &columns_to_read) {
+	auto remapped_table_name = RemapCreatedInlinedTableName(inlined_table_name);
+	RejectUnsafeInlinePayloadValue(remapped_table_name, "inlined table name");
+	auto output = RuntimeExecute("ReadInlineRowsForFlush",
+	                             StringUtil::Format("inlined_table_name=%s\nsnapshot_id=%d\n", remapped_table_name,
+	                                                snapshot.snapshot_id));
+	auto context_ptr = transaction.context.lock();
+	vector<AuxInlineColumn> columns;
+	vector<AuxInlineRow> rows;
+	ParseReadInlineRowsOutput(*context_ptr, output, columns, rows);
+	return BuildInlineRowsOutput(*context_ptr, snapshot, columns_to_read, columns, rows);
+}
