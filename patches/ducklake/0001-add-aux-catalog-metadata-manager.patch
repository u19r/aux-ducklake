+static bool IsReadOnlyMirrorQuery(const string &query) {
+	auto lower = StringUtil::Lower(query);
+	idx_t first = 0;
+	while (first < lower.size() && StringUtil::CharacterIsSpace(lower[first])) {
+		first++;
+	}
+	for (auto &blocked : {"insert", "update", "delete", "drop", "alter", "create", "replace"}) {
+		string blocked_keyword(blocked);
+		if (lower.substr(first, blocked_keyword.size()) == blocked_keyword &&
+		    (lower.size() == first + blocked_keyword.size() ||
+		     StringUtil::CharacterIsSpace(lower[first + blocked_keyword.size()]))) {
+			return false;
+		}
+	}
+	if (lower.find("ducklake_data_file") == string::npos && lower.find("ducklake_file_column_stats") == string::npos &&
+	    lower.find("ducklake_delete_file") == string::npos) {
+		return false;
+	}
+	if (lower.find("ducklake_inlined_delete_") != string::npos) {
+		return false;
+	}
+	return lower.find("select ") != string::npos || lower.find("with ") != string::npos;
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::Query(DuckLakeSnapshot snapshot, string &query) {
+	if (IsDeletedOrDroppedFilesAfterSnapshotQuery(query)) {
+		auto context_ptr = transaction.context.lock();
+		auto output = RuntimeExecute("ListRemovedDataFilesAfter", StringUtil::Format("snapshot_id=%d\n", snapshot.snapshot_id));
+		return BuildRemovedDataFilesResult(*context_ptr, output);
+	}
+	if (IsReadOnlyMirrorQuery(query)) {
+		return DuckLakeMetadataManager::Query(snapshot, query);
+	}
+	if (IsSnapshotAndStatsAndChangesQuery(query)) {
+		auto conflict_snapshot_id = snapshot.snapshot_id;
+		if (active_read_snapshot_id.IsValid() && active_read_snapshot_id.GetIndex() > conflict_snapshot_id) {
+			conflict_snapshot_id = active_read_snapshot_id.GetIndex();
+		}
+		auto output = RuntimeExecute("ListSnapshotStatsAndChangesInputs",
+		                             StringUtil::Format("snapshot_id=%d\n", conflict_snapshot_id));
+		if (output.find("catalog_snapshot_exists=false") != string::npos) {
+			auto context_ptr = transaction.context.lock();
+			return BuildSnapshotAndChangesResult(*context_ptr, output, string(), vector<DuckLakeGlobalStatsInfo>());
+		}
+		auto latest_output = output;
+		auto latest_snapshot = RuntimeSnapshotFromOutput(latest_output);
+		auto catalog = GetCatalogForSnapshot(latest_snapshot);
+		auto global_stats = GetAllGlobalTableStatsForCatalogOutput(latest_snapshot, catalog, output);
+		auto context_ptr = transaction.context.lock();
+		return BuildSnapshotAndChangesResult(*context_ptr, latest_output, AuxCatalogRequireValue(output, "changes_made"),
+		                                     global_stats);
+	}
+	if (IsInlineFlushDeletePositionQuery(query)) {
+		auto context_ptr = transaction.context.lock();
+		string table_name;
+		if (!ExtractInlinedTableName(query, table_name)) {
+			throw IOException("aux_catalog could not extract inlined table name from flush delete query");
+		}
+		RejectUnsafeInlineAggregatePayloadValue(table_name, "inlined table name");
+		auto output = RuntimeExecute(
+		    "ListCurrentInlineFlushDeletePositions",
+		    StringUtil::Format("inlined_table_name=%s\nsnapshot_id=%d\nfile_order=%s\n", table_name,
+		                       snapshot.snapshot_id, ExtractInlineFlushFileOrder(query)));
+		return BuildFlushDeletePositionResult(*context_ptr, output);
+	}
+	if (IsInlineFlushFileDeleteQuery(query)) {
+		auto context_ptr = transaction.context.lock();
+		auto table_id = ExtractInlineFileDeleteTableId(query);
+		auto output = RuntimeExecute("ListInlineFileDeletionsForFlush",
+		                             StringUtil::Format("table_id=%d\nsnapshot_id=%d\n", table_id, snapshot.snapshot_id));
+		return BuildInlineFileDeleteFlushResult(*context_ptr, output);
+	}
+	if (IsInlineFileDeleteRowsQuery(query)) {
+		auto context_ptr = transaction.context.lock();
+		auto table_id = ExtractInlineFileDeleteTableId(query);
+		auto output = RuntimeExecute("ListInlineFileDeletions",
+		                             StringUtil::Format("table_id=%d\nsnapshot_id=%d\n", table_id, snapshot.snapshot_id));
+		return BuildInlineFileDeletionRowsResult(*context_ptr, output);
+	}
+	string table_name;
+	if (!ExtractInlinedAggregateTableName(query, table_name)) {
+		throw NotImplementedException("conflict: aux_catalog cannot execute unhandled SQL metadata query: %s", query);
+	}
+	RejectUnsafeInlineAggregatePayloadValue(table_name, "inlined table name");
+	auto output = RuntimeExecute("ReadInlineRowsForAggregateStats",
+	                             StringUtil::Format("inlined_table_name=%s\nsnapshot_id=%d\n", table_name,
+	                                                snapshot.snapshot_id));
+	idx_t row_count = 0;
+	auto stats = ParseInlineAggregateStats(output, row_count);
+	auto context_ptr = transaction.context.lock();
+	return BuildAggregateResult(*context_ptr, row_count, stats);
+}
+
