+static unique_ptr<QueryResult> BuildFlushDeletePositionResult(ClientContext &context, const string &output) {
+	vector<string> names {"end_snapshot", "output_position"};
+	vector<LogicalType> types {LogicalType::BIGINT, LogicalType::BIGINT};
+	AuxCatalogResultBuilder builder(context, std::move(names), std::move(types));
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("delete_position\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 3) {
+			throw IOException("aux_catalog runtime returned invalid inline delete position row: %s", line);
+		}
+		builder.AppendRow({Value::BIGINT(NumericCast<int64_t>(AuxCatalogParseIndex(fields[1], "inline delete end snapshot"))),
+		                   Value::BIGINT(ParseI64(fields[2], "inline delete output position"))});
+	}
+	return builder.Finish();
+}
