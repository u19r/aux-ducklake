+static unique_ptr<QueryResult> BuildSnapshotAndChangesResult(ClientContext &context, const string &latest_output,
+                                                             const string &changes_after_snapshot,
+                                                             const vector<DuckLakeGlobalStatsInfo> &global_stats) {
+	vector<string> names {"snapshot_id",    "schema_version", "next_catalog_id", "next_file_id", "changes",
+	                      "table_id",       "column_id",      "record_count",    "next_row_id",  "file_size_bytes",
+	                      "contains_null",  "contains_nan",   "min_value",       "max_value",    "extra_stats"};
+	vector<LogicalType> types {LogicalType::BIGINT,  LogicalType::BIGINT, LogicalType::BIGINT, LogicalType::BIGINT,
+	                           LogicalType::VARCHAR, LogicalType::BIGINT, LogicalType::BIGINT, LogicalType::BIGINT,
+	                           LogicalType::BIGINT,  LogicalType::BIGINT, LogicalType::BOOLEAN, LogicalType::BOOLEAN,
+	                           LogicalType::VARCHAR, LogicalType::VARCHAR, LogicalType::VARCHAR};
+	AuxCatalogResultBuilder builder(context, std::move(names), std::move(types));
+	auto null_value = [&](idx_t index) { return builder.NullValue(index); };
+
+	vector<Value> snapshot_values;
+	snapshot_values.push_back(Value::BIGINT(NumericCast<int64_t>(RequireRuntimeIndex(latest_output, "ducklake_snapshot_id"))));
+	snapshot_values.push_back(Value::BIGINT(NumericCast<int64_t>(RequireRuntimeIndex(latest_output, "ducklake_schema_version"))));
+	snapshot_values.push_back(Value::BIGINT(NumericCast<int64_t>(RequireRuntimeIndex(latest_output, "ducklake_next_catalog_id"))));
+	snapshot_values.push_back(Value::BIGINT(NumericCast<int64_t>(RequireRuntimeIndex(latest_output, "ducklake_next_file_id"))));
+	snapshot_values.push_back(Value(changes_after_snapshot));
+	for (idx_t i = 5; i < builder.ColumnCount(); i++) {
+		snapshot_values.push_back(null_value(i));
+	}
+	builder.AppendRow(snapshot_values);
+
+	for (auto &stats : global_stats) {
+		if (stats.column_stats.empty()) {
+			vector<Value> values;
+			for (idx_t i = 0; i < 5; i++) {
+				values.push_back(null_value(i));
+			}
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.table_id.index)));
+			values.push_back(null_value(6));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.record_count)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.next_row_id)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.table_size_bytes)));
+			for (idx_t i = 10; i < builder.ColumnCount(); i++) {
+				values.push_back(null_value(i));
+			}
+			builder.AppendRow(values);
+			continue;
+		}
+		for (auto &column_stats : stats.column_stats) {
+			vector<Value> values;
+			for (idx_t i = 0; i < 5; i++) {
+				values.push_back(null_value(i));
+			}
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.table_id.index)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(column_stats.column_id.index)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.record_count)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.next_row_id)));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(stats.table_size_bytes)));
+			values.push_back(column_stats.has_contains_null ? Value::BOOLEAN(column_stats.contains_null) : null_value(10));
+			values.push_back(column_stats.has_contains_nan ? Value::BOOLEAN(column_stats.contains_nan) : null_value(11));
+			values.push_back(column_stats.has_min ? Value(column_stats.min_val) : null_value(12));
+			values.push_back(column_stats.has_max ? Value(column_stats.max_val) : null_value(13));
+			values.push_back(column_stats.has_extra_stats ? Value(column_stats.extra_stats) : null_value(14));
+			builder.AppendRow(values);
+		}
+	}
+
+	return builder.Finish();
+}
