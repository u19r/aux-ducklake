new file mode 100644
index 00000000..6e7a5d3a
--- /dev/null
+++ b/src/include/metadata_manager/aux_catalog_tabular_payload.hpp
@@ -0,0 +1,140 @@
+#pragma once
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/types.hpp"
+#include "duckdb/common/types/blob.hpp"
+#include "duckdb/common/types/column/column_data_collection.hpp"
+#include "duckdb/common/types/data_chunk.hpp"
+#include "duckdb/main/client_context.hpp"
+#include "duckdb/main/materialized_query_result.hpp"
+#include <exception>
+#include <initializer_list>
+#include <sstream>
+#include <string>
+#include <vector>
+
+namespace duckdb {
+
+inline vector<string> AuxCatalogSplitTabLine(const string &line) {
+	vector<string> result;
+	idx_t start = 0;
+	for (idx_t i = 0; i <= line.size(); i++) {
+		if (i == line.size() || line[i] == '\t') {
+			result.push_back(line.substr(start, i - start));
+			start = i + 1;
+		}
+	}
+	return result;
+}
+
+inline uint64_t AuxCatalogParseUInt64(const string &value, const char *field_name) {
+	try {
+		return std::stoull(value);
+	} catch (std::exception &ex) {
+		throw IOException("aux_catalog runtime returned invalid %s '%s': %s", field_name, value, ex.what());
+	}
+}
+
+inline idx_t AuxCatalogParseIndex(const string &value, const char *field_name) {
+	try {
+		return NumericCast<idx_t>(AuxCatalogParseUInt64(value, field_name));
+	} catch (std::exception &ex) {
+		throw IOException("aux_catalog runtime returned invalid %s '%s': %s", field_name, value, ex.what());
+	}
+}
+
+inline optional_idx AuxCatalogParseOptionalIndex(const string &value, const char *field_name) {
+	if (value.empty()) {
+		return optional_idx();
+	}
+	return optional_idx(AuxCatalogParseIndex(value, field_name));
+}
+
+inline bool AuxCatalogParseBool(const string &value, const char *field_name) {
+	if (value == "true") {
+		return true;
+	}
+	if (value == "false") {
+		return false;
+	}
+	throw IOException("aux_catalog runtime returned invalid %s '%s'", field_name, value);
+}
+
+inline string AuxCatalogEncodeEncryptionKey(const string &encryption_key) {
+	return encryption_key.empty() ? string() : Blob::ToBase64(string_t(encryption_key));
+}
+
+inline string AuxCatalogDecodeEncryptionKey(const string &encryption_key) {
+	return encryption_key.empty() ? string() : Blob::FromBase64(encryption_key);
+}
+
+inline bool AuxCatalogFieldCountIs(idx_t count, std::initializer_list<idx_t> allowed) {
+	for (auto allowed_count : allowed) {
+		if (count == allowed_count) {
+			return true;
+		}
+	}
+	return false;
+}
+
+inline string AuxCatalogRequireValue(const string &output, const string &key) {
+	std::stringstream stream(output);
+	string line;
+	auto prefix = key + "=";
+	while (std::getline(stream, line)) {
+		if (line.rfind(prefix, 0) == 0) {
+			return line.substr(prefix.size());
+		}
+	}
+	throw IOException("aux_catalog runtime output missing required field %s", key);
+}
+
+inline string AuxCatalogRuntimeSqlPayload(const string &output) {
+	auto delete_pos = output.find("DELETE FROM ");
+	if (delete_pos == string::npos) {
+		throw IOException("aux_catalog runtime SQL output did not contain a DELETE statement");
+	}
+	return output.substr(delete_pos);
+}
+
+class AuxCatalogResultBuilder {
+public:
+	AuxCatalogResultBuilder(ClientContext &context, vector<string> names, vector<LogicalType> types)
+	    : names(std::move(names)), types(std::move(types)), collection(make_uniq<ColumnDataCollection>(context, this->types)) {
+		chunk.Initialize(Allocator::Get(context), this->types);
+	}
+
+	void AppendRow(const vector<Value> &values) {
+		if (values.size() != types.size()) {
+			throw IOException("aux_catalog result row has %d values for %d columns", values.size(), types.size());
+		}
+		chunk.Reset();
+		for (idx_t column_idx = 0; column_idx < values.size(); column_idx++) {
+			chunk.data[column_idx].SetValue(0, values[column_idx]);
+		}
+		chunk.SetChildCardinality(1);
+		collection->Append(chunk);
+	}
+
+	Value NullValue(idx_t column_idx) const {
+		return Value(types[column_idx]);
+	}
+
+	idx_t ColumnCount() const {
+		return types.size();
+	}
+
+	unique_ptr<QueryResult> Finish() {
+		StatementProperties properties;
+		return make_uniq<MaterializedQueryResult>(StatementType::SELECT_STATEMENT, properties, std::move(names),
+		                                          std::move(collection), ClientProperties());
+	}
+
+private:
+	vector<string> names;
+	vector<LogicalType> types;
+	unique_ptr<ColumnDataCollection> collection;
+	DataChunk chunk;
+};
+
+} // namespace duckdb
