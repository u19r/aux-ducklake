+static bool IsSnapshotAndStatsAndChangesQuery(const string &query) {
+	return query.find("ducklake_snapshot_changes") != string::npos &&
+	       query.find("ducklake_table_stats") != string::npos && query.find("STRING_AGG(changes_made") != string::npos;
+}
+
+static idx_t RequireRuntimeIndex(const string &output, const string &key) {
+	auto prefix = key + "=";
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.rfind(prefix, 0) == 0) {
+			return AuxCatalogParseIndex(line.substr(prefix.size()), key.c_str());
+		}
+	}
+	throw IOException("aux_catalog runtime response missing required field %s", key);
+}
+
+static DuckLakeSnapshot RuntimeSnapshotFromOutput(const string &output) {
+	DuckLakeSnapshot snapshot;
+	snapshot.snapshot_id = RequireRuntimeIndex(output, "ducklake_snapshot_id");
+	snapshot.schema_version = RequireRuntimeIndex(output, "ducklake_schema_version");
+	snapshot.next_catalog_id = RequireRuntimeIndex(output, "ducklake_next_catalog_id");
+	snapshot.next_file_id = RequireRuntimeIndex(output, "ducklake_next_file_id");
+	return snapshot;
+}
+
+static bool ParseInlineAggregateBool(const string &value, const char *field_name) {
+	if (value == "true" || value == "1") {
+		return true;
+	}
+	if (value == "false" || value == "0") {
+		return false;
+	}
+	throw IOException("aux_catalog runtime returned invalid %s '%s'", field_name, value);
+}
+
+static vector<AuxAggregateColumnStats> ParseInlineAggregateStats(const string &output, idx_t &row_count) {
+	vector<AuxAggregateColumnStats> stats;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.rfind("inline_aggregate_stats\t", 0) == 0) {
+			auto fields = AuxCatalogSplitTabLine(line);
+			if (fields.size() != 2) {
+				throw IOException("aux_catalog runtime returned invalid inline aggregate stats row: %s", line);
+			}
+			row_count = AuxCatalogParseIndex(fields[1], "inline aggregate row count");
+			continue;
+		}
+		if (line.rfind("inline_aggregate_column_stats\t", 0) == 0) {
+			auto fields = AuxCatalogSplitTabLine(line);
+			if (fields.size() != 7) {
+				throw IOException("aux_catalog runtime returned invalid inline aggregate column stats row: %s", line);
+			}
+			AuxAggregateColumnStats column_stats;
+			column_stats.non_null_count = AuxCatalogParseIndex(fields[2], "inline aggregate non-null count");
+			auto has_min = ParseInlineAggregateBool(fields[3], "inline aggregate has min");
+			auto has_max = ParseInlineAggregateBool(fields[5], "inline aggregate has max");
+			column_stats.has_value = has_min || has_max;
+			column_stats.min_value = fields[4];
+			column_stats.max_value = fields[6];
+			stats.push_back(std::move(column_stats));
+		}
+	}
+	return stats;
+}
