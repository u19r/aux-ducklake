+#include "storage/ducklake_table_entry.hpp"
+#include <algorithm>
+#include <map>
+#include <mutex>
+#include <set>
+#include <sstream>
+
+namespace duckdb {
+
+namespace {
+
+struct AuxCatalogFileRow {
+	DataFileIndex data_file_id;
+	TableIndex table_id;
+	string path;
+	idx_t row_count = 0;
+	idx_t file_size_bytes = 0;
+	optional_idx data_file_footer_size;
+	optional_idx row_id_start;
+	MappingIndex mapping_id;
+	optional_idx begin_snapshot;
+	optional_idx max_partial_snapshot;
+	optional_idx snapshot_filter_max;
+	string data_encryption_key;
+	DataFileIndex delete_file_id;
+	string delete_path;
+	idx_t delete_count = 0;
+	idx_t delete_file_size_bytes = 0;
+	optional_idx delete_begin_snapshot;
+	string delete_encryption_key;
+	set<idx_t> inlined_file_deletions;
+};
+
+static bool IsFileRowFieldCount(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {6, 12, 13, 14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool FileRowHasMapping(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool FileRowHasInlineDeletions(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {13, 14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool FileRowHasFooterSize(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {17, 18, 19, 20, 22});
+}
+
+struct AuxFileColumnStatsRow {
+	DataFileIndex data_file_id;
+	TableIndex table_id;
+	FieldIndex column_id;
+	optional_idx value_count;
+	idx_t null_count = 0;
+	string min_value;
+	string max_value;
+	string extra_stats;
+};
+
+struct DynamicFilterColumn {
+	idx_t column_field_index;
+	ExpressionType comparison_type;
+	LogicalType column_type;
+};
+
+static bool IsSimpleFilterSubject(const Expression &expr);
+static bool TryCastStatsValue(const string &raw, const LogicalType &type, Value &out);
+
+static set<idx_t> ParseInlinedFileDeletions(const string &value) {
+	set<idx_t> rows;
+	if (value.empty()) {
+		return rows;
+	}
+	idx_t start = 0;
+	for (idx_t i = 0; i <= value.size(); i++) {
+		if (i == value.size() || value[i] == ',') {
+			rows.insert(AuxCatalogParseIndex(value.substr(start, i - start), "inline file deletion row id"));
+			start = i + 1;
+		}
+	}
+	return rows;
+}
+
+static AuxCatalogFileRow ParseFileRowFields(const vector<string> &fields, const string &line) {
+	if (!IsFileRowFieldCount(fields.size())) {
+		throw IOException("aux_catalog runtime returned invalid file row: %s", line);
+	}
+	AuxCatalogFileRow file;
+	file.data_file_id = DataFileIndex(AuxCatalogParseIndex(fields[1], "data file id"));
+	file.table_id = TableIndex(AuxCatalogParseIndex(fields[2], "file table id"));
+	file.path = fields[3];
+	file.row_count = AuxCatalogParseIndex(fields[4], "file record count");
+	file.file_size_bytes = AuxCatalogParseIndex(fields[5], "file size bytes");
+	if (fields.size() < 12) {
+		return file;
+	}
+	file.row_id_start = AuxCatalogParseOptionalIndex(fields[6], "row id start");
+	idx_t delete_offset = 7;
+	idx_t inline_offset = 12;
+	if (FileRowHasMapping(fields.size())) {
+		if (!fields[7].empty()) {
+			file.mapping_id = MappingIndex(AuxCatalogParseIndex(fields[7], "mapping id"));
+		}
+		delete_offset = 8;
+		inline_offset = 13;
+	}
+	if (!fields[delete_offset].empty() && !fields[delete_offset + 2].empty()) {
+		file.delete_file_id = DataFileIndex(AuxCatalogParseIndex(fields[delete_offset], "delete file id"));
+		file.delete_path = fields[delete_offset + 1];
+		file.delete_count = AuxCatalogParseIndex(fields[delete_offset + 2], "delete count");
+		file.delete_file_size_bytes = AuxCatalogParseIndex(fields[delete_offset + 3], "delete file size bytes");
+		file.delete_begin_snapshot = AuxCatalogParseOptionalIndex(fields[delete_offset + 4], "delete begin snapshot");
+	}
+	if (FileRowHasInlineDeletions(fields.size())) {
+		file.inlined_file_deletions = ParseInlinedFileDeletions(fields[inline_offset]);
+	}
+	if (fields.size() >= 16) {
+		file.begin_snapshot = AuxCatalogParseOptionalIndex(fields[14], "data file begin snapshot");
+		file.max_partial_snapshot = AuxCatalogParseOptionalIndex(fields[15], "data file partial max snapshot");
+	}
+	if (FileRowHasFooterSize(fields.size())) {
+		file.data_file_footer_size = AuxCatalogParseOptionalIndex(fields[16], "data file footer size");
+	}
+	if (fields.size() >= 20) {
+		file.snapshot_filter_max = AuxCatalogParseOptionalIndex(fields[19], "data file snapshot filter max");
+	}
+	if (fields.size() == 22) {
+		file.data_encryption_key = AuxCatalogDecodeEncryptionKey(fields[20]);
+		file.delete_encryption_key = AuxCatalogDecodeEncryptionKey(fields[21]);
+	}
+	return file;
+}
+
+static vector<AuxCatalogFileRow> ParseFileRows(const string &output) {
+	vector<AuxCatalogFileRow> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("file\t", 0) != 0) {
+			continue;
+		}
+		files.push_back(ParseFileRowFields(AuxCatalogSplitTabLine(line), line));
+	}
+	return files;
+}
+
+static vector<AuxCatalogFileRow> ParseFileRows(const string &output, TableIndex expected_table_id) {
+	auto files = ParseFileRows(output);
+	for (auto &file : files) {
+		if (file.table_id != expected_table_id) {
+			throw IOException("aux_catalog runtime returned file for table %d while reading table %d",
+			                  file.table_id.index, expected_table_id.index);
+		}
+	}
+	return files;
+}
+
+static vector<AuxFileColumnStatsRow> ParseFileColumnStatsRows(const string &output) {
+	vector<AuxFileColumnStatsRow> rows;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("file_column_stats\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 8 && fields.size() != 9) {
+			throw IOException("aux_catalog runtime returned invalid file column stats row: %s", line);
+		}
+		AuxFileColumnStatsRow row;
+		row.data_file_id = DataFileIndex(AuxCatalogParseIndex(fields[1], "file column stats data file id"));
+		row.table_id = TableIndex(AuxCatalogParseIndex(fields[2], "file column stats table id"));
+		row.column_id = FieldIndex(AuxCatalogParseIndex(fields[3], "file column stats column id"));
+		row.value_count = AuxCatalogParseOptionalIndex(fields[4], "file column stats value count");
+		row.null_count = AuxCatalogParseIndex(fields[5], "file column stats null count");
+		row.min_value = fields[6];
+		row.max_value = fields[7];
+		if (fields.size() == 9) {
+			row.extra_stats = fields[8];
+		}
+		rows.push_back(std::move(row));
+	}
+	return rows;
+}
+
+static bool ParseGlobalStatsBool(const string &value, const char *field_name) {
+	if (value == "true" || value == "1") {
+		return true;
+	}
+	if (value == "false" || value == "0") {
+		return false;
+	}
+	throw IOException("aux_catalog runtime returned invalid %s '%s'", field_name, value);
+}
+
+static vector<DuckLakeGlobalStatsInfo> ParseGlobalStatsOutput(const string &output) {
+	vector<DuckLakeGlobalStatsInfo> result;
+	map<TableIndex, idx_t> result_index;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields[0] == "global_stats_snapshot" || fields[0].rfind("global_stats_snapshot=", 0) == 0) {
+			continue;
+		}
+		if (fields[0] == "global_table_stats") {
+			if (fields.size() != 5) {
+				throw IOException("aux_catalog runtime returned invalid global table stats row: %s", line);
+			}
+			auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "global stats table id"));
+			auto entry = result_index.find(table_id);
+			if (entry == result_index.end()) {
+				entry = result_index.emplace(table_id, result.size()).first;
+				result.emplace_back();
+			}
+			auto &stats = result[entry->second];
+			stats.table_id = table_id;
+			stats.initialized = true;
+			stats.record_count = AuxCatalogParseIndex(fields[2], "global stats record count");
+			stats.next_row_id = AuxCatalogParseIndex(fields[3], "global stats next row id");
+			stats.table_size_bytes = AuxCatalogParseIndex(fields[4], "global stats table size bytes");
+			continue;
+		}
+		if (fields[0] == "global_table_column_stats") {
+			if (fields.size() != 11) {
+				throw IOException("aux_catalog runtime returned invalid global table column stats row: %s", line);
+			}
+			auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "global column stats table id"));
+			auto entry = result_index.find(table_id);
+			if (entry == result_index.end()) {
+				entry = result_index.emplace(table_id, result.size()).first;
+				result.emplace_back();
+				result.back().table_id = table_id;
+			}
+			DuckLakeGlobalColumnStatsInfo column_stats;
+			column_stats.column_id = FieldIndex(AuxCatalogParseIndex(fields[2], "global column stats column id"));
+			column_stats.has_contains_null =
+			    ParseGlobalStatsBool(fields[3], "global column stats has contains null");
+			column_stats.contains_null = ParseGlobalStatsBool(fields[4], "global column stats contains null");
+			column_stats.has_min = ParseGlobalStatsBool(fields[5], "global column stats has min");
+			column_stats.min_val = fields[6];
+			column_stats.has_max = ParseGlobalStatsBool(fields[7], "global column stats has max");
+			column_stats.max_val = fields[8];
+			column_stats.has_extra_stats = ParseGlobalStatsBool(fields[9], "global column stats has extra stats");
+			column_stats.extra_stats = fields[10];
+			result[entry->second].column_stats.push_back(std::move(column_stats));
+			continue;
+		}
+	}
+	return result;
+}
+
+static vector<DuckLakeGlobalStatsInfo> ParseGlobalStatsOutput(const string &output, TableIndex expected_table_id) {
+	auto result = ParseGlobalStatsOutput(output);
+	for (auto &stats : result) {
+		if (stats.table_id != expected_table_id) {
+			throw IOException("aux_catalog runtime returned global stats for table %d while reading table %d",
+			                  stats.table_id.index, expected_table_id.index);
+		}
+	}
+	return result;
+}
+
+static vector<DynamicFilterColumn> DynamicFilterColumns(const FilterPushdownInfo *filter_info) {
+	vector<DynamicFilterColumn> columns;
+	if (!filter_info) {
+		return columns;
+	}
+	for (auto &entry : filter_info->column_filters) {
+		auto &column_filter = entry.second;
+		if (!column_filter.table_filter) {
+			continue;
+		}
+		auto dynamic_filter_data = DuckLakeUtil::GetOptionalDynamicFilterData(*column_filter.table_filter);
+		if (!dynamic_filter_data) {
+			continue;
+		}
+		ExpressionType comparison_type;
+		{
+			lock_guard<mutex> lock(dynamic_filter_data->lock);
+			comparison_type = dynamic_filter_data->comparison_type;
+		}
+		columns.push_back({column_filter.column_field_index, comparison_type, column_filter.column_type});
+	}
+	return columns;
+}
+
+static string DataFileIdsPayload(const vector<AuxCatalogFileRow> &rows) {
+	string payload;
+	for (auto &row : rows) {
+		payload += StringUtil::Format("data_file_id\t%d\n", row.data_file_id.index);
+	}
+	return payload;
+}
+
+static void AttachDynamicFilterStats(vector<DuckLakeFileListEntry> &files, const string &stats_output,
+                                     const vector<DynamicFilterColumn> &dynamic_filter_columns) {
+	if (dynamic_filter_columns.empty() || files.empty()) {
+		return;
+	}
+	map<DataFileIndex, DuckLakeFileListEntry *> files_by_id;
+	for (auto &file : files) {
+		files_by_id[file.file_id] = &file;
+	}
+	for (auto &row : ParseFileColumnStatsRows(stats_output)) {
+		auto file = files_by_id.find(row.data_file_id);
+		if (file == files_by_id.end()) {
+			continue;
+		}
+		for (auto &column : dynamic_filter_columns) {
+			if (row.column_id.index != column.column_field_index) {
+				continue;
+			}
+			file->second->column_min_max.emplace(column.column_field_index,
+			                                    make_pair(row.min_value, row.max_value));
+		}
+	}
+}
+
+static bool DynamicFilterSeeksHighValues(ExpressionType comparison_type) {
+	return comparison_type == ExpressionType::COMPARE_GREATERTHAN ||
+	       comparison_type == ExpressionType::COMPARE_GREATERTHANOREQUALTO;
+}
+
+static bool DynamicFilterSeeksLowValues(ExpressionType comparison_type) {
+	return comparison_type == ExpressionType::COMPARE_LESSTHAN ||
+	       comparison_type == ExpressionType::COMPARE_LESSTHANOREQUALTO;
+}
+
+static bool DynamicFilterSortValue(const DuckLakeFileListEntry &file, const DynamicFilterColumn &column, bool use_max,
+                                   Value &out) {
+	auto entry = file.column_min_max.find(column.column_field_index);
+	if (entry == file.column_min_max.end()) {
+		return false;
+	}
+	return TryCastStatsValue(use_max ? entry->second.second : entry->second.first, column.column_type, out);
+}
+
+static void SortFilesForDynamicFilter(vector<DuckLakeFileListEntry> &files,
+                                      const vector<DynamicFilterColumn> &dynamic_filter_columns) {
+	if (files.size() < 2 || dynamic_filter_columns.empty()) {
+		return;
+	}
+	auto &column = dynamic_filter_columns[0];
+	const bool high_values_first = DynamicFilterSeeksHighValues(column.comparison_type);
+	const bool low_values_first = DynamicFilterSeeksLowValues(column.comparison_type);
+	if (!high_values_first && !low_values_first) {
+		return;
+	}
+	std::stable_sort(files.begin(), files.end(), [&](const auto &left, const auto &right) {
+		Value left_value;
+		Value right_value;
+		const bool left_has_value = DynamicFilterSortValue(left, column, high_values_first, left_value);
+		const bool right_has_value = DynamicFilterSortValue(right, column, high_values_first, right_value);
+		if (left_has_value != right_has_value) {
+			return left_has_value;
+		}
+		if (!left_has_value) {
+			return false;
+		}
+		return high_values_first ? left_value > right_value : left_value < right_value;
+	});
+}
+
+static bool TryCastStatsValue(const string &raw, const LogicalType &type, Value &out) {
+	if (raw.empty()) {
+		return false;
+	}
+	return Value(raw).DefaultTryCastAs(type, out, nullptr) && !out.IsNull();
+}
+
+static bool ConstantBetweenStats(const Value &constant, const AuxFileColumnStatsRow &stats, const LogicalType &type) {
+	Value min_value;
+	Value max_value;
+	Value typed_constant;
+	if (!TryCastStatsValue(stats.min_value, type, min_value) || !TryCastStatsValue(stats.max_value, type, max_value) ||
+	    !constant.DefaultTryCastAs(type, typed_constant, nullptr) || typed_constant.IsNull()) {
+		return true;
+	}
+	return min_value <= typed_constant && typed_constant <= max_value;
+}
+
+static bool StatsMayMatchConstant(ExpressionType comparison_type, const Value &constant,
+                                  const AuxFileColumnStatsRow &stats, const LogicalType &type) {
+	Value min_value;
+	Value max_value;
+	Value typed_constant;
+	if (!TryCastStatsValue(stats.min_value, type, min_value) || !TryCastStatsValue(stats.max_value, type, max_value) ||
+	    !constant.DefaultTryCastAs(type, typed_constant, nullptr) || typed_constant.IsNull()) {
+		return true;
+	}
+	switch (comparison_type) {
+	case ExpressionType::COMPARE_EQUAL:
+		return min_value <= typed_constant && typed_constant <= max_value;
+	case ExpressionType::COMPARE_NOTEQUAL:
+		return !(min_value == typed_constant && max_value == typed_constant);
+	case ExpressionType::COMPARE_GREATERTHANOREQUALTO:
+		return max_value >= typed_constant;
+	case ExpressionType::COMPARE_GREATERTHAN:
+		return max_value > typed_constant;
+	case ExpressionType::COMPARE_LESSTHANOREQUALTO:
+		return min_value <= typed_constant;
+	case ExpressionType::COMPARE_LESSTHAN:
+		return min_value < typed_constant;
+	default:
+		return true;
+	}
+}
+
+static bool FileMayMatchStatsFilter(const Expression &expr, const AuxFileColumnStatsRow &stats, const LogicalType &type) {
+	if (BoundComparisonExpression::IsComparison(expr)) {
+		auto &comparison = expr.Cast<BoundFunctionExpression>();
+		auto &left = BoundComparisonExpression::Left(comparison);
+		auto &right = BoundComparisonExpression::Right(comparison);
+		auto comparison_type = comparison.GetExpressionType();
+		const BoundConstantExpression *constant_expr = nullptr;
+		if (IsSimpleFilterSubject(left) && right.GetExpressionClass() == ExpressionClass::BOUND_CONSTANT) {
+			constant_expr = &right.Cast<BoundConstantExpression>();
+		} else if (IsSimpleFilterSubject(right) && left.GetExpressionClass() == ExpressionClass::BOUND_CONSTANT) {
+			constant_expr = &left.Cast<BoundConstantExpression>();
+			comparison_type = FlipComparisonExpression(comparison_type);
+		}
+		return !constant_expr ||
+		       StatsMayMatchConstant(comparison_type, constant_expr->GetValue(), stats, type);
+	}
+	switch (expr.GetExpressionClass()) {
+	case ExpressionClass::BOUND_OPERATOR: {
+		auto &op_expr = expr.Cast<BoundOperatorExpression>();
+		if (expr.GetExpressionType() != ExpressionType::COMPARE_IN || op_expr.GetChildren().size() < 2 ||
+		    !IsSimpleFilterSubject(*op_expr.GetChildren()[0])) {
+			return true;
+		}
+		for (idx_t i = 1; i < op_expr.GetChildren().size(); i++) {
+			auto &child = *op_expr.GetChildren()[i];
+			if (child.GetExpressionClass() != ExpressionClass::BOUND_CONSTANT) {
+				return true;
+			}
+			if (ConstantBetweenStats(child.Cast<BoundConstantExpression>().GetValue(), stats, type)) {
+				return true;
+			}
+		}
+		return false;
+	}
+	case ExpressionClass::BOUND_CONJUNCTION: {
+		auto &conjunction = expr.Cast<BoundConjunctionExpression>();
+		if (expr.GetExpressionType() == ExpressionType::CONJUNCTION_OR) {
+			for (auto &child : conjunction.GetChildren()) {
+				if (FileMayMatchStatsFilter(*child, stats, type)) {
+					return true;
+				}
+			}
+			return false;
+		}
+		for (auto &child : conjunction.GetChildren()) {
+			if (!FileMayMatchStatsFilter(*child, stats, type)) {
+				return false;
+			}
+		}
+		return true;
+	}
+	case ExpressionClass::BOUND_FUNCTION: {
+		auto &func = expr.Cast<BoundFunctionExpression>();
+		if (func.Function().GetName() == OptionalFilterScalarFun::NAME && func.BindInfo()) {
+			auto &data = func.BindInfo()->Cast<OptionalFilterFunctionData>();
+			return !data.child_filter_expr || FileMayMatchStatsFilter(*data.child_filter_expr, stats, type);
+		}
+		if (func.Function().GetName() == SelectivityOptionalFilterScalarFun::NAME && func.BindInfo()) {
+			auto &data = func.BindInfo()->Cast<SelectivityOptionalFilterFunctionData>();
+			return !data.child_filter_expr || FileMayMatchStatsFilter(*data.child_filter_expr, stats, type);
+		}
+		return true;
+	}
+	default:
+		return true;
+	}
+}
+
+static map<DataFileIndex, map<idx_t, AuxFileColumnStatsRow>> StatsByFileAndColumn(const string &stats_output) {
+	map<DataFileIndex, map<idx_t, AuxFileColumnStatsRow>> stats_by_file;
+	for (auto &row : ParseFileColumnStatsRows(stats_output)) {
+		stats_by_file[row.data_file_id][row.column_id.index] = std::move(row);
+	}
+	return stats_by_file;
+}
+
+static bool FileMayMatchFilters(const AuxCatalogFileRow &row, const FilterPushdownInfo *filter_info,
+                                const map<DataFileIndex, map<idx_t, AuxFileColumnStatsRow>> &stats_by_file) {
+	if (!filter_info || filter_info->column_filters.empty()) {
+		return true;
+	}
+	auto file_stats = stats_by_file.find(row.data_file_id);
+	if (file_stats == stats_by_file.end()) {
+		return true;
+	}
+	for (auto &entry : filter_info->column_filters) {
+		auto &column_filter = entry.second;
+		if (!column_filter.table_filter || !column_filter.table_filter->expr) {
+			continue;
+		}
+		auto stats = file_stats->second.find(column_filter.column_field_index);
+		if (stats == file_stats->second.end()) {
+			continue;
+		}
+		if (!FileMayMatchStatsFilter(*column_filter.table_filter->expr, stats->second, column_filter.column_type)) {
+			return false;
+		}
+	}
+	return true;
+}
