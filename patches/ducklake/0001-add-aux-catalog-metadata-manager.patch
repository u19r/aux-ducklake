+static void PopulateFileData(DuckLakeFileData &target, const string &path, idx_t file_size_bytes,
+                             optional_idx footer_size, const string &encryption_key) {
+	target.path = path;
+	target.file_size_bytes = file_size_bytes;
+	target.footer_size = footer_size;
+	target.encryption_key = encryption_key;
+}
