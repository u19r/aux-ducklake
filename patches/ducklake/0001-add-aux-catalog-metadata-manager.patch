+static bool ExtractInlinedTableName(const string &query, string &table_name) {
+	auto start = query.find("ducklake_inlined_data_");
+	if (start == string::npos) {
+		return false;
+	}
+	auto end = start;
+	while (end < query.size() && (StringUtil::CharacterIsAlphaNumeric(query[end]) || query[end] == '_')) {
+		end++;
+	}
+	table_name = query.substr(start, end - start);
+	return !table_name.empty();
+}
+
+static bool ExtractInlinedAggregateTableName(const string &query, string &table_name) {
+	if (query.find("COUNT(*)") == string::npos) {
+		return false;
+	}
+	return ExtractInlinedTableName(query, table_name);
+}
+
+static bool IsInlineFlushDeletePositionQuery(const string &query) {
+	return query.find("ducklake_inlined_data_") != string::npos && query.find("end_snapshot") != string::npos &&
+	       query.find("output_position") != string::npos;
+}
+
+static string ExtractInlineFlushFileOrder(const string &query) {
+	auto start = query.find("ORDER BY ");
+	if (start == string::npos) {
+		return string();
+	}
+	start += string("ORDER BY ").size();
+	auto end = query.find(") - 1 AS output_position", start);
+	if (end == string::npos || end <= start) {
+		return string();
+	}
+	string order = query.substr(start, end - start);
+	string sanitized;
+	sanitized.reserve(order.size());
+	bool previous_space = false;
+	for (auto ch : order) {
+		auto byte = static_cast<unsigned char>(ch);
+		if (std::isspace(byte)) {
+			if (!previous_space) {
+				sanitized.push_back(' ');
+			}
+			previous_space = true;
+			continue;
+		}
+		if (ch == '\t') {
+			throw IOException("aux_catalog inline flush order contains a tab");
+		}
+		sanitized.push_back(ch);
+		previous_space = false;
+	}
+	StringUtil::Trim(sanitized);
+	return sanitized;
+}
