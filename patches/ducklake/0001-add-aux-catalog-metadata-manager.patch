+static bool IsInlineFlushFileDeleteQuery(const string &query) {
+	return query.find("ducklake_inlined_delete_") != string::npos &&
+	       query.find("JOIN {METADATA_CATALOG}.ducklake_data_file") != string::npos &&
+	       query.find("existing_del") != string::npos;
