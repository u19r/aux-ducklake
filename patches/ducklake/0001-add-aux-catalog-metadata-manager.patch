+void RemoveCreatedObject(case_insensitive_map_t<case_insensitive_map_t<string>> &created_objects,
+                         const string &schema_name, const string &object_name, const string &object_type) {
+	auto schema_entry = created_objects.find(schema_name);
+	if (schema_entry == created_objects.end()) {
+		return;
+	}
+	auto &objects = schema_entry->second;
+	auto object_entry = objects.find(object_name);
+	if (object_entry == objects.end() || object_entry->second != object_type) {
+		return;
+	}
+	objects.erase(object_entry);
+	if (objects.empty()) {
+		created_objects.erase(schema_entry);
+	}
+}
+
+void RemoveOwnCreatedCatalogEntries(const case_insensitive_map_t<reference_set_t<CatalogEntry>> &entries,
+                                    case_insensitive_map_t<case_insensitive_map_t<string>> &created_objects,
+                                    const string &table_type, const string &view_type) {
+	for (auto &entry : entries) {
+		auto &schema_name = entry.first;
+		for (auto &catalog_ref : entry.second) {
+			auto &catalog_entry = catalog_ref.get();
+			auto object_type = catalog_entry.type == CatalogType::VIEW_ENTRY ? view_type : table_type;
+			RemoveCreatedObject(created_objects, schema_name, catalog_entry.name.GetIdentifierName(), object_type);
+		}
+	}
+}
+
+void RemoveOwnCreatedChanges(const TransactionChangeInformation &changes, SnapshotChangeInformation &other_changes) {
+	for (auto &schema_name : changes.created_schemas) {
+		other_changes.created_schemas.erase(schema_name);
+	}
+	for (auto &table_id : changes.altered_tables) {
+		other_changes.altered_tables.erase(table_id);
+	}
+	for (auto &view_id : changes.altered_views) {
+		other_changes.altered_views.erase(view_id);
+	}
+	RemoveOwnCreatedCatalogEntries(changes.created_tables, other_changes.created_tables, "table", "view");
+	RemoveOwnCreatedCatalogEntries(changes.created_scalar_macros, other_changes.created_scalar_macros, "scalar_macro",
+	                               "scalar_macro");
+	RemoveOwnCreatedCatalogEntries(changes.created_table_macros, other_changes.created_table_macros, "table_macro",
+	                               "table_macro");
+}
+
