+	       !flushed_inline_payload.empty() || !inline_file_delete_payload.empty();
+}
+
+static void AppendCommitAttemptMetadataSection(string &commit_attempt_payload, const string &operation,
+                                               const string &operation_payload) {
+	if (operation_payload.empty()) {
+		return;
+	}
+	bool section_open = false;
+	std::stringstream stream(operation_payload);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("read_snapshot\t", 0) == 0) {
+			continue;
+		}
+		if (line.rfind("commit_snapshot\t", 0) == 0) {
+			section_open = false;
+			continue;
+		}
+		if (!section_open) {
+			commit_attempt_payload += "metadata\t" + operation + "\n";
+			section_open = true;
+		}
+		commit_attempt_payload += line;
+		commit_attempt_payload += "\n";
+	}
+}
+
+static void AppendCommitAttemptSection(string &commit_attempt_payload, const string &section_header,
+                                       const string &operation_payload) {
+	if (operation_payload.empty()) {
+		return;
+	}
+	bool section_open = false;
+	std::stringstream stream(operation_payload);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("read_snapshot\t", 0) == 0) {
+			continue;
+		}
+		if (line.rfind("commit_snapshot\t", 0) == 0) {
+			section_open = false;
+			continue;
+		}
+		if (!section_open) {
+			commit_attempt_payload += section_header;
+			commit_attempt_payload += "\n";
+			section_open = true;
+		}
+		commit_attempt_payload += line;
+		commit_attempt_payload += "\n";
+	}
+}
+
+static string PendingCommitAttemptPayload(idx_t commit_snapshot_id, optional_idx read_snapshot_id,
+                                          DuckLakeSnapshotCommit &commit_info,
+                                          const string &create_schemas_payload,
+                                          const string &drop_schemas_payload,
+                                          const string &create_tables_payload,
+                                          const string &replace_tables_payload,
+                                          const string &add_columns_payload,
+	                                          const string &change_column_defaults_payload,
+	                                          const string &change_column_types_payload,
+	                                          const string &change_comments_payload,
+	                                          const string &change_view_comments_payload,
+	                                          const string &drop_columns_payload,
+                                          const string &rename_columns_payload,
+                                          const string &rename_tables_payload,
+                                          const string &change_partition_keys_payload,
+	                                          const string &change_sort_keys_payload,
+	                                          const string &merge_adjacent_payload,
+	                                          const string &rewrite_delete_payload,
+	                                          const string &data_mutation_payload,
+	                                          const string &register_inline_tables_payload,
+                                          const string &register_inline_rows_payload,
+                                          const string &inline_deletes_payload) {
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot_id);
+	if (read_snapshot_id.IsValid()) {
+		payload += StringUtil::Format("read_snapshot\t%d\n", read_snapshot_id.GetIndex());
+	}
+	AppendCommitInfoRows(payload, commit_info);
+	AppendCommitAttemptMetadataSection(payload, "CreateSchemas", create_schemas_payload);
+	AppendCommitAttemptMetadataSection(payload, "DropSchemas", drop_schemas_payload);
+	AppendCommitAttemptMetadataSection(payload, "CreateTables", create_tables_payload);
+	AppendCommitAttemptMetadataSection(payload, "ReplaceTables", replace_tables_payload);
+	AppendCommitAttemptMetadataSection(payload, "DropColumns", drop_columns_payload);
+	AppendCommitAttemptMetadataSection(payload, "AddColumns", add_columns_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangeColumnDefaults", change_column_defaults_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangeColumnTypes", change_column_types_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangeComments", change_comments_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangeViewComment", change_view_comments_payload);
+	AppendCommitAttemptMetadataSection(payload, "RenameColumns", rename_columns_payload);
+	AppendCommitAttemptMetadataSection(payload, "RenameTables", rename_tables_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangePartitionKeys", change_partition_keys_payload);
+	AppendCommitAttemptMetadataSection(payload, "ChangeSortKeys", change_sort_keys_payload);
+	AppendCommitAttemptSection(payload, "compaction\tMergeAdjacentFiles", merge_adjacent_payload);
+	AppendCommitAttemptSection(payload, "compaction\tRewriteDeleteFiles", rewrite_delete_payload);
+	AppendCommitAttemptSection(payload, "inline\tRegisterInlineTables", register_inline_tables_payload);
+	AppendCommitAttemptSection(payload, "inline\tRegisterInlineRows", register_inline_rows_payload);
+	AppendCommitAttemptSection(payload, "inline\tDeleteInlineRows", inline_deletes_payload);
+	AppendCommitAttemptSection(payload, "data_mutation", data_mutation_payload);
+	return payload;
+}
+
+static void AppendFilePayload(string &payload, const DuckLakeFileInfo &file, const string &resolved_path) {
+	RejectRuntimeField(resolved_path, "file paths");
+	if (!file.row_id_start.IsValid()) {
+		throw IOException("aux_catalog cannot append data file %d without row_id_start", file.id.index);
+	}
+	if (file.partition_id.IsValid() == file.partition_values.empty()) {
+		throw IOException("aux_catalog data file %d has inconsistent partition metadata", file.id.index);
+	}
+	payload += StringUtil::Format("file\t%d\t%d\t%s\t%d\t%d\t%d\t%s\t%s\t%s\t%s\t%s\n", file.id.index,
+	                              file.table_id.index,
+	                              resolved_path, file.row_count, file.file_size_bytes, file.row_id_start.GetIndex(),
+	                              file.mapping_id.IsValid() ? std::to_string(file.mapping_id.index) : "",
+	                              file.footer_size.IsValid() ? std::to_string(file.footer_size.GetIndex()) : "",
+	                              file.begin_snapshot.IsValid() ? std::to_string(file.begin_snapshot.GetIndex()) : "",
+	                              file.max_partial_file_snapshot.IsValid()
+	                                  ? std::to_string(file.max_partial_file_snapshot.GetIndex())
+	                                  : "",
+	                              AuxCatalogEncodeEncryptionKey(file.encryption_key));
+	if (file.partition_id.IsValid()) {
+		payload += StringUtil::Format("file_partition_set\t%d\t%d\t%d\n", file.id.index, file.table_id.index,
+		                              file.partition_id.GetIndex());
+	}
+	for (auto &partition_value : file.partition_values) {
+		auto value = partition_value.partition_value.IsNull() ? string("__HIVE_DEFAULT_PARTITION__")
+		                                                     : partition_value.partition_value.ToString();
+		RejectRuntimeField(value, "partition values");
+		payload += StringUtil::Format("file_partition\t%d\t%d\t%d\t%s\n", file.id.index, file.table_id.index,
+		                              partition_value.partition_column_idx, value);
+	}
+	for (auto &raw_stats : file.column_stats) {
+		auto column_stats = DuckLakeColumnStatsInfo::FromColumnStats(raw_stats.first, raw_stats.second);
+		if (column_stats.null_count == "NULL") {
+			continue;
+		}
+		auto min_value = SqlLiteralToPayloadValue(column_stats.min_val);
+		auto max_value = SqlLiteralToPayloadValue(column_stats.max_val);
+		if (column_stats.contains_nan == "true") {
+			min_value.clear();
+			max_value.clear();
+		}
+		auto extra_stats = SqlLiteralToPayloadValue(column_stats.extra_stats);
+		RejectRuntimeField(min_value, "file column stats min values");
+		RejectRuntimeField(max_value, "file column stats max values");
+		RejectRuntimeField(extra_stats, "file column stats extra stats");
+		payload += StringUtil::Format("file_column_stats\t%d\t%d\t%d\t%s\t%s\t%s\t%s\t%s\n", file.id.index,
+		                              file.table_id.index, column_stats.column_id.index, column_stats.value_count,
+		                              column_stats.null_count, min_value, max_value, extra_stats);
+	}
+}
