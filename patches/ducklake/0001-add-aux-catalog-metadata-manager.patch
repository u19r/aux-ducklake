+static unique_ptr<QueryResult> BuildAggregateResult(ClientContext &context, idx_t row_count,
+                                                    const vector<AuxAggregateColumnStats> &stats) {
+	vector<string> names;
+	vector<LogicalType> types;
+	names.push_back("col1");
+	types.push_back(LogicalType::BIGINT);
+	for (idx_t i = 0; i < stats.size(); i++) {
+		names.push_back(StringUtil::Format("col%d", i * 4 + 2));
+		types.push_back(LogicalType::VARCHAR);
+		names.push_back(StringUtil::Format("col%d", i * 4 + 3));
+		types.push_back(LogicalType::VARCHAR);
+		names.push_back(StringUtil::Format("col%d", i * 4 + 4));
+		types.push_back(LogicalType::BIGINT);
+		names.push_back(StringUtil::Format("col%d", i * 4 + 5));
+		types.push_back(LogicalType::BOOLEAN);
+	}
+	vector<Value> values;
+	values.push_back(Value::BIGINT(NumericCast<int64_t>(row_count)));
+	for (auto &column_stats : stats) {
+		if (column_stats.has_value) {
+			values.push_back(Value(column_stats.min_value));
+			values.push_back(Value(column_stats.max_value));
+		} else {
+			values.push_back(Value(LogicalType::VARCHAR));
+			values.push_back(Value(LogicalType::VARCHAR));
+		}
+		values.push_back(Value::BIGINT(NumericCast<int64_t>(column_stats.non_null_count)));
+		values.push_back(Value::BOOLEAN(false));
+	}
+	AuxCatalogResultBuilder builder(context, std::move(names), std::move(types));
+	builder.AppendRow(values);
+	return builder.Finish();
+}
