+static void RejectRuntimeField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static string HexEncode(const string &value) {
+	static constexpr char HEX[] = "0123456789abcdef";
+	string result;
+	result.reserve(value.size() * 2);
+	for (auto c : value) {
+		auto byte = static_cast<unsigned char>(c);
+		result.push_back(HEX[byte >> 4]);
+		result.push_back(HEX[byte & 0x0F]);
+	}
+	return result;
+}
+
+static string SerializeDuckDbValue(const Value &value) {
+	MemoryStream stream;
+	BinarySerializer serializer(stream);
+	serializer.Begin();
+	value.Serialize(serializer);
+	serializer.End();
+	return string(const_char_ptr_cast(stream.GetData()), stream.GetPosition());
+}
+
+static string EncodeValue(const Value &value) {
+	if (value.IsNull()) {
+		return "n:";
+	}
+	switch (value.type().id()) {
+	case LogicalTypeId::BOOLEAN:
+		return value.GetValue<bool>() ? "b:1" : "b:0";
+	case LogicalTypeId::TINYINT:
+		return "i:" + std::to_string(value.GetValue<int8_t>());
+	case LogicalTypeId::SMALLINT:
+		return "i:" + std::to_string(value.GetValue<int16_t>());
+	case LogicalTypeId::INTEGER:
+		return "i:" + std::to_string(value.GetValue<int32_t>());
+	case LogicalTypeId::BIGINT:
+		return "i:" + std::to_string(value.GetValue<int64_t>());
+	case LogicalTypeId::UTINYINT:
+		return "i:" + std::to_string(value.GetValue<uint8_t>());
+	case LogicalTypeId::USMALLINT:
+		return "i:" + std::to_string(value.GetValue<uint16_t>());
+	case LogicalTypeId::UINTEGER:
+		return "i:" + std::to_string(value.GetValue<uint32_t>());
+	case LogicalTypeId::UBIGINT:
+		return "i:" + std::to_string(value.GetValue<uint64_t>());
+	case LogicalTypeId::VARCHAR:
+		return "s:" + HexEncode(value.GetValue<string>());
+	case LogicalTypeId::BLOB:
+		return "x:" + HexEncode(value.GetValue<string>());
+	case LogicalTypeId::FLOAT:
+	case LogicalTypeId::DOUBLE:
+	case LogicalTypeId::HUGEINT:
+	case LogicalTypeId::UHUGEINT:
+	case LogicalTypeId::DECIMAL:
+	case LogicalTypeId::DATE:
+	case LogicalTypeId::TIME:
+	case LogicalTypeId::TIME_NS:
+	case LogicalTypeId::TIME_TZ:
+	case LogicalTypeId::TIMESTAMP:
+	case LogicalTypeId::TIMESTAMP_SEC:
+	case LogicalTypeId::TIMESTAMP_MS:
+	case LogicalTypeId::TIMESTAMP_NS:
+	case LogicalTypeId::TIMESTAMP_TZ:
+	case LogicalTypeId::TIMESTAMP_TZ_NS:
+	case LogicalTypeId::INTERVAL:
+	case LogicalTypeId::UUID:
+	case LogicalTypeId::LIST:
+	case LogicalTypeId::STRUCT:
+	case LogicalTypeId::MAP:
+		return "v:" + HexEncode(value.ToString());
+	case LogicalTypeId::VARIANT:
+		return "d:" + HexEncode(SerializeDuckDbValue(value));
+	default:
+		throw NotImplementedException("aux_catalog data inlining does not support type %s yet", value.type().ToString());
+	}
+}
+
+struct LatestInlinedTable {
+	string table_name;
+	idx_t schema_version = 0;
+};
+
+static LatestInlinedTable LatestInlinedTableFor(const DuckLakeTableInfo &table) {
+	LatestInlinedTable result;
+	idx_t latest_schema_version = 0;
+	for (auto &inlined_table : table.inlined_data_tables) {
+		if (inlined_table.schema_version >= latest_schema_version) {
+			latest_schema_version = inlined_table.schema_version;
+			result.table_name = inlined_table.table_name;
+			result.schema_version = inlined_table.schema_version;
+		}
+	}
+	return result;
+}
+
+static bool FindNewInlinedTableInfo(const vector<DuckLakeTableInfo> &new_inlined_tables, TableIndex table_id,
+                                    DuckLakeTableInfo &table_info) {
+	for (auto &entry : new_inlined_tables) {
+		if (entry.id == table_id) {
+			table_info = entry;
+			return true;
+		}
+	}
+	return false;
+}
+
+static bool FindNewTableInfo(const vector<DuckLakeTableInfo> &new_tables, TableIndex table_id,
+                             DuckLakeTableInfo &table_info) {
+	for (auto &entry : new_tables) {
+		if (entry.id == table_id) {
+			table_info = entry;
+			return true;
+		}
+	}
+	return false;
+}
+
+static const DuckLakeTableInfo *FindPersistedTableInfo(const DuckLakeCatalogInfo &catalog, TableIndex table_id) {
+	for (auto &table : catalog.tables) {
+		if (table.id == table_id) {
+			return &table;
+		}
+	}
+	return nullptr;
+}
+
+static bool SameInlineColumnSchema(const DuckLakeColumnInfo &left, const DuckLakeColumnInfo &right) {
+	if (left.id != right.id || left.name != right.name || left.type != right.type ||
+	    left.nulls_allowed != right.nulls_allowed || left.children.size() != right.children.size()) {
+		return false;
+	}
+	for (idx_t child_idx = 0; child_idx < left.children.size(); child_idx++) {
+		if (!SameInlineColumnSchema(left.children[child_idx], right.children[child_idx])) {
+			return false;
+		}
+	}
+	return true;
+}
+
+static bool SameInlineColumnSchema(const DuckLakeTableInfo &left, const DuckLakeTableInfo &right) {
+	if (left.columns.size() != right.columns.size()) {
+		return false;
+	}
+	for (idx_t column_idx = 0; column_idx < left.columns.size(); column_idx++) {
+		if (!SameInlineColumnSchema(left.columns[column_idx], right.columns[column_idx])) {
+			return false;
+		}
+	}
+	return true;
+}
+
+static idx_t SchemaVersionFromInlinedTableName(const string &table_name) {
+	const string prefix = "ducklake_inlined_data_";
+	if (table_name.rfind(prefix, 0) != 0) {
+		throw IOException("aux_catalog cannot parse inlined table name: %s", table_name);
+	}
+	auto id_start = prefix.size();
+	auto id_end = table_name.find('_', id_start);
+	if (id_end == string::npos || id_end + 1 >= table_name.size()) {
+		throw IOException("aux_catalog cannot parse inlined table name: %s", table_name);
+	}
+	return AuxCatalogParseIndex(table_name.substr(id_end + 1), "inlined table schema version");
+}
+
+static vector<idx_t> InlineNextRowIdsFromOutput(const string &output) {
+	vector<idx_t> next_row_ids;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("inline_table_stats\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 3) {
+			throw IOException("aux_catalog runtime returned invalid inline_table_stats row: %s", line);
+		}
+		next_row_ids.push_back(AuxCatalogParseIndex(fields[2], "inline next row id"));
+	}
+	return next_row_ids;
+}
+
+unordered_map<string, idx_t>
+AuxCatalogMetadataManager::StoredInlineNextRowIds(const vector<string> &inlined_table_names, DuckLakeSnapshot snapshot) {
+	unordered_map<string, idx_t> next_row_ids;
+	if (inlined_table_names.empty()) {
+		return next_row_ids;
+	}
+	string payload = StringUtil::Format("snapshot_id=%d\n", snapshot.snapshot_id);
+	for (auto &inlined_table_name : inlined_table_names) {
+		RejectRuntimeField(inlined_table_name, "inlined table names");
+		payload += "inlined_table_name=" + inlined_table_name + "\n";
+	}
+	auto output = RuntimeExecute("ReadInlineRowsForGlobalStatsBatch", payload);
+	auto parsed = InlineNextRowIdsFromOutput(output);
+	if (parsed.size() != inlined_table_names.size()) {
+		throw IOException("aux_catalog runtime returned %d inline stats rows for %d inlined tables", parsed.size(),
+		                  inlined_table_names.size());
+	}
+	for (idx_t i = 0; i < inlined_table_names.size(); i++) {
+		next_row_ids[inlined_table_names[i]] = parsed[i];
+	}
+	return next_row_ids;
+}
+
+static DuckLakeTableInfo LoadTableInfo(DuckLakeTransaction &transaction, TableIndex table_id,
+                                       const vector<DuckLakeTableInfo> &new_tables) {
+	DuckLakeTableInfo table_info;
+	auto current_snapshot = transaction.GetSnapshot();
+	auto table_entry = transaction.GetCatalog().GetEntryById(transaction, current_snapshot, table_id);
+	if (table_entry) {
+		auto &table = table_entry->Cast<DuckLakeTableEntry>();
+		table_info = table.GetTableInfo();
+		table_info.columns = table.GetTableColumns();
+		return table_info;
+	}
+	if (FindNewTableInfo(new_tables, table_id, table_info)) {
+		return table_info;
+	}
+	throw InternalException("Writing inlined data for a table that cannot be found in the catalog");
+}
+
+static string ResolveInlinedTableName(DuckLakeSnapshot &commit_snapshot, DuckLakeTransaction &transaction,
+                                      const DuckLakeInlinedDataInfo &entry, const vector<DuckLakeTableInfo> &new_tables,
+                                      const vector<DuckLakeTableInfo> &new_inlined_tables,
+                                      const DuckLakeTableInfo *persisted_table,
+                                      DuckLakeTableInfo &table_info) {
+	DuckLakeTableInfo new_inline_table_info;
+	auto has_new_inline_table = FindNewInlinedTableInfo(new_inlined_tables, entry.table_id, new_inline_table_info);
+	if (persisted_table) {
+		table_info = *persisted_table;
+		auto persisted_inline = LatestInlinedTableFor(table_info);
+		auto transaction_table_info = LoadTableInfo(transaction, entry.table_id, new_tables);
+		if (!persisted_inline.table_name.empty() &&
+		    (!has_new_inline_table || SameInlineColumnSchema(*persisted_table, new_inline_table_info)) &&
+		    SameInlineColumnSchema(*persisted_table, transaction_table_info)) {
+			return persisted_inline.table_name;
+		}
+	}
+	if (has_new_inline_table) {
+		table_info = new_inline_table_info;
+		return DuckLakeMetadataManager::InlinedTableNameFor(entry.table_id.index, commit_snapshot.schema_version);
+	}
+	table_info = LoadTableInfo(transaction, entry.table_id, new_tables);
+	auto existing_inline = LatestInlinedTableFor(table_info);
+	if (!existing_inline.table_name.empty()) {
+		return existing_inline.table_name;
+	}
+	return DuckLakeMetadataManager::InlinedTableNameFor(entry.table_id.index, commit_snapshot.schema_version);
+}
+
+static string InlineRowsPayload(const DuckLakeInlinedDataInfo &entry, const DuckLakeTableInfo &table,
+                                const string &inlined_table_name, idx_t schema_version,
+                                idx_t row_id_start, vector<int64_t> *emitted_row_ids = nullptr) {
+	if (!entry.data || !entry.data->data) {
+		throw InternalException("aux_catalog inlined data entry has no data collection");
+	}
+	RejectRuntimeField(inlined_table_name, "inlined table names");
+	string payload = StringUtil::Format("table\t%d\t%d\t%s\n", entry.table_id.index, schema_version, inlined_table_name);
+	idx_t row_id = row_id_start;
+	idx_t position = 0;
+	const bool has_preserved_row_ids = entry.data->HasPreservedRowIds();
+	const bool has_preserved_begin_snapshots = entry.data->HasPreservedBeginSnapshots();
+	for (auto &chunk : entry.data->data->Chunks()) {
+		if (chunk.ColumnCount() != table.columns.size()) {
+			throw InternalException("aux_catalog inlined data column count does not match table column count");
+		}
+			for (idx_t r = 0; r < chunk.size(); r++) {
+				int64_t emitted_row_id;
+				bool replaces_existing_row = false;
+				if (has_preserved_row_ids) {
+					auto staged_row_id = entry.data->row_ids[position];
+					emitted_row_id = DuckLakeConstants::IsTransactionLocalRowId(staged_row_id)
+					                     ? NumericCast<int64_t>(row_id++)
+					                     : staged_row_id;
+					replaces_existing_row = !DuckLakeConstants::IsTransactionLocalRowId(staged_row_id);
+				} else {
+					emitted_row_id = NumericCast<int64_t>(row_id++);
+				}
+				if (replaces_existing_row && emitted_row_ids) {
+					emitted_row_ids->push_back(emitted_row_id);
+				}
+			auto preserved_begin_snapshot =
+			    has_preserved_begin_snapshots ? entry.data->GetBeginSnapshotId(position) : optional_idx();
+			if (preserved_begin_snapshot.IsValid()) {
+				payload += StringUtil::Format("row_begin\t%lld\t%d", emitted_row_id, preserved_begin_snapshot.GetIndex());
+			} else {
+				payload += StringUtil::Format("row\t%lld", emitted_row_id);
+			}
+			for (idx_t col_idx = 0; col_idx < chunk.ColumnCount(); col_idx++) {
+				payload += "\t";
+				payload += EncodeValue(chunk.GetValue(col_idx, r));
+			}
+			payload += "\n";
+			position++;
+		}
+	}
+	return payload;
+}
+
+static void AppendReplacementInlineDeletes(TableIndex table_id, const vector<int64_t> &row_ids,
+                                           const string &inlined_table_name,
+                                           string &pending_inline_deletes_payload) {
+	RejectRuntimeField(inlined_table_name, "inlined table names");
+	for (auto row_id : row_ids) {
+		if (DuckLakeConstants::IsTransactionLocalRowId(row_id)) {
+			continue;
+		}
+		pending_inline_deletes_payload +=
+		    StringUtil::Format("delete\t%d\t%s\t%lld\n", table_id.index, inlined_table_name, row_id);
+	}
+}
+
+string AuxCatalogMetadataManager::WriteNewInlinedTables(DuckLakeSnapshot commit_snapshot,
+                                                        const vector<DuckLakeTableInfo> &tables) {
+	if (tables.empty()) {
+		return string();
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &table : tables) {
+		auto inlined_table_name = DuckLakeMetadataManager::InlinedTableNameFor(table.id.index, commit_snapshot.schema_version);
+		RejectRuntimeField(inlined_table_name, "inlined table names");
+		payload += StringUtil::Format("table\t%d\t%d\t%s\n", table.id.index, commit_snapshot.schema_version,
+		                              inlined_table_name);
+	}
+	pending_register_inline_tables_payload += payload;
+	pending_metadata_batch = true;
+	return string();
+}
+
+string AuxCatalogMetadataManager::WriteNewInlinedData(DuckLakeSnapshot &commit_snapshot,
+                                                      const vector<DuckLakeInlinedDataInfo> &new_data,
+                                                      const vector<DuckLakeTableInfo> &new_tables,
+                                                      const vector<DuckLakeTableInfo> &new_inlined_data_tables_result) {
+	if (new_data.empty()) {
+		return string();
+	}
+	auto snapshot = GetSnapshot();
+	auto persisted_catalog = GetCatalogForSnapshot(*snapshot);
+	if (pending_register_inline_rows_payload.empty()) {
+		pending_register_inline_rows_payload +=
+		    StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	}
+	vector<string> next_row_id_table_names;
+	unordered_map<string, bool> needs_next_row_id;
+	for (auto &entry : new_data) {
+		if (entry.data->HasPreservedRowIds()) {
+			continue;
+		}
+		DuckLakeTableInfo table_info;
+		auto persisted_table = FindPersistedTableInfo(persisted_catalog, entry.table_id);
+		auto inlined_table_name =
+		    ResolveInlinedTableName(commit_snapshot, transaction, entry, new_tables, new_inlined_data_tables_result,
+		                            persisted_table, table_info);
+		if (!needs_next_row_id[inlined_table_name]) {
+			needs_next_row_id[inlined_table_name] = true;
+			next_row_id_table_names.push_back(inlined_table_name);
+		}
+	}
+	auto stored_next_row_ids = StoredInlineNextRowIds(next_row_id_table_names, *snapshot);
+	for (auto &entry : new_data) {
+		DuckLakeTableInfo table_info;
+		auto persisted_table = FindPersistedTableInfo(persisted_catalog, entry.table_id);
+		auto inlined_table_name =
+		    ResolveInlinedTableName(commit_snapshot, transaction, entry, new_tables, new_inlined_data_tables_result,
+		                            persisted_table, table_info);
+		vector<int64_t> emitted_row_ids;
+		auto row_id_start = entry.row_id_start;
+		if (!entry.data->HasPreservedRowIds()) {
+			row_id_start = MaxValue<idx_t>(row_id_start, stored_next_row_ids[inlined_table_name]);
+		}
+		auto payload = InlineRowsPayload(entry, table_info, inlined_table_name,
+		                                 SchemaVersionFromInlinedTableName(inlined_table_name), row_id_start,
+		                                 &emitted_row_ids);
+		pending_register_inline_rows_payload += payload;
+		AppendReplacementInlineDeletes(entry.table_id, emitted_row_ids, inlined_table_name, pending_inline_deletes_payload);
+	}
+	pending_metadata_batch = true;
+	return string();
+}
+
+string AuxCatalogMetadataManager::WriteNewInlinedDeletes(const vector<DuckLakeDeletedInlinedDataInfo> &new_deletes) {
+	if (new_deletes.empty()) {
+		return string();
+	}
+	for (auto &entry : new_deletes) {
+		RejectRuntimeField(entry.table_name, "inlined table names");
+		for (auto row_id : entry.deleted_row_ids) {
+			pending_inline_deletes_payload += "delete\t";
+			pending_inline_deletes_payload += std::to_string(entry.table_id.index);
+			pending_inline_deletes_payload += "\t";
+			pending_inline_deletes_payload += entry.table_name;
+			pending_inline_deletes_payload += "\t";
+			pending_inline_deletes_payload += std::to_string(row_id);
+			pending_inline_deletes_payload += "\n";
+		}
+	}
+	pending_metadata_batch = true;
+	return string();
+}
+
+string AuxCatalogMetadataManager::WriteNewInlinedFileDeletes(DuckLakeSnapshot &,
+                                                             const vector<DuckLakeInlinedFileDeletionInfo> &new_deletes) {
+	if (new_deletes.empty()) {
+		return string();
+	}
+	for (auto &entry : new_deletes) {
+		for (auto &file_entry : entry.file_deletions.file_deletes) {
+			auto file_id = file_entry.first;
+			for (auto row_id : file_entry.second) {
+				pending_inline_file_delete_payload += StringUtil::Format(
+				    "inline_file_delete\t%d\t%d\t%d\n", entry.table_id.index, file_id, row_id);
+			}
+		}
+	}
+	pending_metadata_batch = true;
+	return string();
+}
+
+string AuxCatalogMetadataManager::GetInlinedDeletionTableName(TableIndex table_id, DuckLakeSnapshot snapshot,
+                                                              bool create_if_not_exists) {
+	auto payload = StringUtil::Format("table_id=%d\nsnapshot_id=%d\n", table_id.index, snapshot.snapshot_id);
+	auto output = RuntimeExecute("InlineFileDeletionsExist", payload);
+	if (output.find("inline_file_deletion_exists=true") != string::npos || create_if_not_exists) {
+		return DuckLakeMetadataManager::InlinedFileDeletionTableName(table_id);
+	}
+	return string();
+}
+
+void AuxCatalogMetadataManager::DeleteInlinedData(const DuckLakeInlinedTableInfo &inlined_table) {
+	throw NotImplementedException("aux_catalog full inlined-data deletion is not implemented yet: %s",
+	                              inlined_table.table_name);
+}
+
+void AuxCatalogMetadataManager::DeleteFlushedInlinedData(const DuckLakeInlinedTableInfo &inlined_table,
+                                                         idx_t flush_snapshot_id) {
+	RejectRuntimeField(inlined_table.table_name, "inlined table name");
+	std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+	pending_inline_flushes.push_back({inlined_table.table_name, flush_snapshot_id});
+}
