+	       query.find("FROM {METADATA_CATALOG}.ducklake_data_file") != string::npos &&
+	       query.find("end_snapshot IS NOT NULL") != string::npos &&
+	       query.find("UNION ALL") != string::npos;
+}
+
+static bool IsInlineFileDeleteRowsQuery(const string &query) {
+	return query.find("ducklake_inlined_delete_") != string::npos && query.find("SELECT file_id, row_id") != string::npos &&
+	       query.find("WHERE begin_snapshot <= {SNAPSHOT_ID}") != string::npos;
+}
+
+static idx_t ExtractInlineFileDeleteTableId(const string &query) {
+	auto start = query.find("ducklake_inlined_delete_");
+	if (start == string::npos) {
+		throw IOException("aux_catalog could not find inline file delete table name");
+	}
+	start += string("ducklake_inlined_delete_").size();
+	auto end = start;
+	while (end < query.size() && query[end] >= '0' && query[end] <= '9') {
+		end++;
+	}
+	if (end == start) {
+		throw IOException("aux_catalog could not extract inline file delete table id");
+	}
+	return AuxCatalogParseIndex(query.substr(start, end - start), "inline delete table id");
+}
