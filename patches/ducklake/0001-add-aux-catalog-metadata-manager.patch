+static void RejectConfigField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static DuckLakeMetadata ParseMetadataOptionsOutput(const string &output) {
+	DuckLakeMetadata metadata;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("config_option_count=", 0) == 0) {
+			continue;
+		}
+		if (line.rfind("config_option\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 5) {
+			throw IOException("aux_catalog runtime returned invalid config option row: %s", line);
+		}
+		DuckLakeTag tag {fields[1], fields[2]};
+		if (fields[3] == "global") {
+			metadata.tags.push_back(std::move(tag));
+			continue;
+		}
+		if (fields[3] == "schema") {
+			DuckLakeSchemaSetting setting;
+			setting.schema_id = SchemaIndex(AuxCatalogParseIndex(fields[4], "schema setting scope id"));
+			setting.tag = std::move(tag);
+			metadata.schema_settings.push_back(std::move(setting));
+			continue;
+		}
+		if (fields[3] == "table") {
+			DuckLakeTableSetting setting;
+			setting.table_id = TableIndex(AuxCatalogParseIndex(fields[4], "table setting scope id"));
+			setting.tag = std::move(tag);
+			metadata.table_settings.push_back(std::move(setting));
+			continue;
+		}
+		throw IOException("aux_catalog runtime returned unsupported config option scope: %s", fields[3]);
+	}
+	return metadata;
+}
+
+DuckLakeMetadata AuxCatalogMetadataManager::LoadDuckLake() {
+	auto output = RuntimeExecute("ListConfigOptions", string());
+	return ParseMetadataOptionsOutput(output);
+}
+
+void AuxCatalogMetadataManager::SetConfigOption(const DuckLakeConfigOption &option) {
+	RejectConfigField(option.option.key, "config option keys");
+	RejectConfigField(option.option.value, "config option values");
+	string scope = "global";
+	string scope_id;
+	if (option.table_id.IsValid()) {
+		scope = "table";
+		scope_id = std::to_string(option.table_id.index);
+	} else if (option.schema_id.IsValid()) {
+		scope = "schema";
+		scope_id = std::to_string(option.schema_id.index);
+	}
+	auto payload = StringUtil::Format("key=%s\nvalue=%s\nscope=%s\n", option.option.key, option.option.value, scope);
+	if (!scope_id.empty()) {
+		payload += "scope_id=" + scope_id + "\n";
+	}
+	RuntimeExecute("SetConfigOption", payload);
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_runtime_bridge.cpp b/src/metadata_manager/aux_catalog_runtime_bridge.cpp
new file mode 100644
index 00000000..8d1aeee2
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_runtime_bridge.cpp
@@ -0,0 +1,248 @@
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include <cstdlib>
+#include <exception>
+#include <memory>
+#include <mutex>
+
+#ifndef _WIN32
+#include <dlfcn.h>
+#endif
+
+namespace duckdb {
+
+namespace {
+
+struct DuckLakeRuntimeBuffer {
+	uint8_t *ptr;
+	size_t len;
+};
+
+using RuntimeProbe = int (*)(const uint8_t *, size_t, DuckLakeRuntimeBuffer *);
+using RuntimeFree = void (*)(uint8_t *, size_t);
+using RuntimeShutdown = int (*)();
+
+static constexpr idx_t MAX_RESPONSE_BYTES = 2 * 1024 * 1024;
+
+string RuntimeLibraryPath() {
+	auto path = std::getenv("AUX_DUCKLAKE_RUNTIME_LIBRARY");
+	if (!path || !path[0]) {
+		return string();
+	}
+	return path;
+}
+
+string RuntimeBackend() {
+	auto backend = std::getenv("AUX_DUCKLAKE_CATALOG_BACKEND");
+	if (!backend || !backend[0]) {
+		return "foundationdb";
+	}
+	if (StringUtil::CIEquals(backend, "fdb") || StringUtil::CIEquals(backend, "foundationdb")) {
+		return "foundationdb";
+	}
+	throw InvalidConfigurationException("unsupported AUX_DUCKLAKE_CATALOG_BACKEND=%s", backend);
+}
+
+string RuntimeRequest(const string &operation, const string &payload, uint64_t catalog_id, idx_t page_offset,
+                      const string &page_etag) {
+	auto header = StringUtil::Format(
+	    "aux-ducklake-runtime/2\nrequest_id=ducklake-cpp-probe\nbackend=%s\ncatalog_id=%llu\noperation=%s\npayload_len=%d\n",
+	    RuntimeBackend(), static_cast<unsigned long long>(catalog_id), operation, payload.size());
+	if (!page_etag.empty()) {
+		header += StringUtil::Format("page_offset=%d\npage_etag=%s\n", page_offset, page_etag);
+	}
+	return header + "\n" + payload;
+}
+
+bool TryHeaderValue(const string &header, const string &key, string &result) {
+	auto prefix = key + "=";
+	idx_t offset = 0;
+	while (offset < header.size()) {
+		auto end = header.find('\n', offset);
+		if (end == string::npos) {
+			end = header.size();
+		}
+		auto line = header.substr(offset, end - offset);
+		if (line.rfind(prefix, 0) == 0) {
+			result = line.substr(prefix.size());
+			return true;
+		}
+		offset = end + 1;
+	}
+	return false;
+}
+
+string HeaderValue(const string &header, const string &key) {
+	string result;
+	if (TryHeaderValue(header, key, result)) {
+		return result;
+	}
+	throw IOException("aux_catalog runtime response missing required field %s", key);
+}
+
+idx_t ParsePayloadLength(const string &value, const string &operation) {
+	try {
+		size_t parsed_bytes = 0;
+		auto parsed = std::stoull(value, &parsed_bytes);
+		if (parsed_bytes != value.size()) {
+			throw IOException("aux_catalog runtime operation %s returned invalid payload length", operation);
+		}
+		return NumericCast<idx_t>(parsed);
+	} catch (std::exception &) {
+		throw IOException("aux_catalog runtime operation %s returned invalid payload length", operation);
+	}
+}
+
+struct RuntimeResponsePage {
+	string payload;
+	string page_etag;
+	optional_idx next_page_offset;
+};
+
+RuntimeResponsePage DecodeRuntimePayload(const string &frame, const string &operation) {
+	auto split = frame.find("\n\n");
+	if (split == string::npos) {
+		throw IOException("aux_catalog runtime operation %s returned an invalid frame", operation);
+	}
+	auto header = frame.substr(0, split);
+	auto payload = frame.substr(split + 2);
+	if (HeaderValue(header, "status") != "ok") {
+		if (StringUtil::Contains(payload, "conflict committing data mutation")) {
+			throw IOException("aux_catalog runtime operation %s failed: %s", operation, payload);
+		}
+		if (StringUtil::Contains(payload, "conflict")) {
+			throw TransactionException("Transaction conflict - %s", payload);
+		}
+		throw IOException("aux_catalog runtime operation %s failed: %s", operation, payload);
+	}
+	auto payload_len = ParsePayloadLength(HeaderValue(header, "payload_len"), operation);
+	if (payload_len != payload.size()) {
+		throw IOException("aux_catalog runtime operation %s returned mismatched payload length", operation);
+	}
+	RuntimeResponsePage page;
+	page.payload = std::move(payload);
+	string next_page_offset;
+	if (TryHeaderValue(header, "next_page_offset", next_page_offset)) {
+		page.next_page_offset = optional_idx(ParsePayloadLength(next_page_offset, operation));
+		page.page_etag = HeaderValue(header, "page_etag");
+	}
+	return page;
+}
+
+#ifndef _WIN32
+template <class T>
+T LoadSymbol(void *library, const char *name, const string &path) {
+	auto symbol = dlsym(library, name);
+	if (!symbol) {
+		throw IOException("aux_catalog runtime library %s is missing symbol %s", path, name);
+	}
+	return reinterpret_cast<T>(symbol);
+}
+
+struct LoadedRuntimeLibrary {
+	explicit LoadedRuntimeLibrary(const string &path_p) : path(path_p) {
+		handle = dlopen(path.c_str(), RTLD_NOW | RTLD_LOCAL);
+		if (!handle) {
+			throw IOException("failed to open aux_catalog runtime library %s: %s", path, dlerror());
+		}
+		probe = LoadSymbol<RuntimeProbe>(handle, "ducklake_catalog_runtime_probe", path);
+		free_buffer = LoadSymbol<RuntimeFree>(handle, "ducklake_catalog_runtime_free", path);
+		shutdown = LoadSymbol<RuntimeShutdown>(handle, "ducklake_catalog_runtime_shutdown", path);
+	}
+
+	~LoadedRuntimeLibrary() {
+		if (!handle) {
+			return;
+		}
+		if (shutdown) {
+			shutdown();
+		}
+		// FoundationDB owns a process-global network thread. At process teardown,
+		// leave the runtime image mapped so that abandoned FDB thread stack frames
+		// cannot return through an unloaded Rust dylib.
+	}
+
+	string path;
+	void *handle = nullptr;
+	RuntimeProbe probe = nullptr;
+	RuntimeFree free_buffer = nullptr;
+	RuntimeShutdown shutdown = nullptr;
+};
+
+LoadedRuntimeLibrary &RuntimeLibraryForPath(const string &path) {
+	static std::mutex library_lock;
+	static std::unique_ptr<LoadedRuntimeLibrary> library;
+	std::lock_guard<std::mutex> guard(library_lock);
+	if (!library) {
+		library.reset(new LoadedRuntimeLibrary(path));
+		return *library;
+	}
+	if (library->path != path) {
+		throw InvalidConfigurationException("AUX_DUCKLAKE_RUNTIME_LIBRARY changed after the runtime was loaded");
+	}
+	return *library;
+}
+#endif
+
+} // namespace
+
+bool AuxCatalogRuntimeBridge::IsConfigured() {
+	return !RuntimeLibraryPath().empty();
+}
+
+string AuxCatalogRuntimeBridge::Execute(const string &operation, const string &payload) {
+	return Execute(operation, payload, 1);
+}
+
+string AuxCatalogRuntimeBridge::Execute(const string &operation, const string &payload, uint64_t catalog_id) {
+	auto path = RuntimeLibraryPath();
+	if (path.empty()) {
+		return string();
+	}
+#ifdef _WIN32
+	throw InvalidConfigurationException("aux_catalog runtime library loading is not implemented on Windows");
+#else
+	auto &library = RuntimeLibraryForPath(path);
+	string output;
+	idx_t page_offset = 0;
+	string page_etag;
+	while (true) {
+		auto request = RuntimeRequest(operation, payload, catalog_id, page_offset, page_etag);
+		DuckLakeRuntimeBuffer response {nullptr, 0};
+		auto status = library.probe(reinterpret_cast<const uint8_t *>(request.data()), request.size(), &response);
+		if (status != 0) {
+			if (response.ptr) {
+				library.free_buffer(response.ptr, response.len);
+			}
+			throw IOException("aux_catalog runtime operation %s failed with ffi status %d", operation, status);
+		}
+		if (!response.ptr || response.len > MAX_RESPONSE_BYTES) {
+			if (response.ptr) {
+				library.free_buffer(response.ptr, response.len);
+			}
+			throw IOException("aux_catalog runtime operation %s returned an invalid buffer", operation);
+		}
+		string frame(reinterpret_cast<const char *>(response.ptr), response.len);
+		library.free_buffer(response.ptr, response.len);
+		auto page = DecodeRuntimePayload(frame, operation);
+		output += page.payload;
+		if (!page.next_page_offset.IsValid()) {
+			break;
+		}
+		auto next_page_offset = page.next_page_offset.GetIndex();
+		if (next_page_offset <= page_offset || page.page_etag.empty()) {
+			throw IOException("aux_catalog runtime operation %s returned an invalid page continuation", operation);
+		}
+		page_offset = next_page_offset;
+		page_etag = std::move(page.page_etag);
+	}
+	return "runtime_bridge=cpp_ffi\n" + output;
+#endif
+}
+
+string AuxCatalogRuntimeBridge::Probe(const string &operation, const string &payload) {
+	return Execute(operation, payload);
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_schema_changes.cpp b/src/metadata_manager/aux_catalog_schema_changes.cpp
new file mode 100644
index 00000000..4b800316
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_schema_changes.cpp
@@ -0,0 +1,294 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "metadata_manager/aux_catalog_schema_payload.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include <sstream>
+namespace duckdb {
+
+static void RejectSchemaField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+static void AppendDropTablePayload(string &payload, TableIndex table_id) {
+	payload += StringUtil::Format("table\t%d\n", table_id.index);
+}
+static void AppendDropColumnPayload(string &payload, const DuckLakeDroppedColumn &column) {
+	payload += StringUtil::Format("column\t%d\t%d\n", column.table_id.index, column.field_id.index);
+}
+
+static void AppendRenameTablePayload(string &payload, const DuckLakeTableInfo &table) {
+	RejectSchemaField(table.name, "table names");
+	payload += StringUtil::Format("table\t%d\t%s\n", table.id.index, table.name);
+}
+
+static string SchemaRuntimePayload(DuckLakeSnapshot &commit_snapshot, optional_idx read_snapshot_id,
+                                   const string &payload) {
+	auto out = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	if (read_snapshot_id.IsValid()) {
+		out += StringUtil::Format("read_snapshot\t%d\n", read_snapshot_id.GetIndex());
+	}
+	out += payload;
+	return out;
+}
+
+static optional_ptr<const DuckLakeSortInfo> FindExistingSort(const vector<DuckLakeSortInfo> &existing_sorts,
+                                                             TableIndex table_id) {
+	for (auto &sort : existing_sorts) {
+		if (sort.table_id == table_id) {
+			return optional_ptr<const DuckLakeSortInfo>(&sort);
+		}
+	}
+	return nullptr;
+}
+
+static bool IsMissingSortReset(optional_ptr<const DuckLakeSortInfo> existing_sort, const DuckLakeSortInfo &new_sort) {
+	return !existing_sort && !new_sort.id.IsValid() && new_sort.fields.empty();
+}
+
+static vector<const DuckLakeSortInfo *> ChangedSorts(const vector<DuckLakeSortInfo> &existing_sorts,
+                                                     const vector<DuckLakeSortInfo> &new_sorts) {
+	vector<const DuckLakeSortInfo *> changed_sorts;
+	for (auto &new_sort : new_sorts) {
+		auto existing_sort = FindExistingSort(existing_sorts, new_sort.table_id);
+		if (existing_sort && *existing_sort == new_sort) {
+			continue;
+		}
+		if (IsMissingSortReset(existing_sort, new_sort)) {
+			continue;
+		}
+		changed_sorts.push_back(&new_sort);
+	}
+	return changed_sorts;
+}
+
+static optional_ptr<const DuckLakePartitionInfo>
+FindExistingPartition(const vector<DuckLakePartitionInfo> &existing_partitions, TableIndex table_id) {
+	for (auto &partition : existing_partitions) {
+		if (partition.table_id == table_id) {
+			return optional_ptr<const DuckLakePartitionInfo>(&partition);
+		}
+	}
+	return nullptr;
+}
+
+static bool IsMissingPartitionReset(optional_ptr<const DuckLakePartitionInfo> existing_partition,
+                                    const DuckLakePartitionInfo &new_partition) {
+	return !existing_partition && !new_partition.id.IsValid() && new_partition.fields.empty();
+}
+
+static vector<const DuckLakePartitionInfo *>
+ChangedPartitions(const vector<DuckLakePartitionInfo> &existing_partitions,
+                  const vector<DuckLakePartitionInfo> &new_partitions) {
+	vector<const DuckLakePartitionInfo *> changed_partitions;
+	for (auto &new_partition : new_partitions) {
+		auto existing_partition = FindExistingPartition(existing_partitions, new_partition.table_id);
+		if (existing_partition && *existing_partition == new_partition) {
+			continue;
+		}
+		if (IsMissingPartitionReset(existing_partition, new_partition)) {
+			continue;
+		}
+		changed_partitions.push_back(&new_partition);
+	}
+	return changed_partitions;
+}
+
+static string SortDirectionValue(OrderType sort_direction) {
+	return sort_direction == OrderType::DESCENDING ? "DESC" : "ASC";
+}
+
+static string NullOrderValue(OrderByNullType null_order) {
+	return null_order == OrderByNullType::NULLS_FIRST ? "NULLS_FIRST" : "NULLS_LAST";
+}
+
+static void AppendSortPayload(string &payload, const DuckLakeSortInfo &sort) {
+	payload += StringUtil::Format("sort\t%d\t%s\n", sort.table_id.index,
+	                              sort.id.IsValid() ? std::to_string(sort.id.GetIndex()) : "");
+	if (!sort.id.IsValid()) {
+		return;
+	}
+	for (auto &field : sort.fields) {
+		auto sort_direction = SortDirectionValue(field.sort_direction);
+		auto null_order = NullOrderValue(field.null_order);
+		RejectSchemaField(field.expression, "sort expressions");
+		RejectSchemaField(field.dialect, "sort dialects");
+		payload += StringUtil::Format("sort_field\t%d\t%d\t%d\t%s\t%s\t%s\t%s\n", sort.table_id.index,
+		                              sort.id.GetIndex(), field.sort_key_index, field.expression, field.dialect,
+		                              sort_direction, null_order);
+	}
+}
+
+static void AppendPartitionPayload(string &payload, const DuckLakePartitionInfo &partition) {
+	payload += StringUtil::Format("partition\t%d\t%s\n", partition.table_id.index,
+	                              partition.id.IsValid() ? std::to_string(partition.id.GetIndex()) : "");
+	if (!partition.id.IsValid()) {
+		return;
+	}
+	for (auto &field : partition.fields) {
+		RejectSchemaField(field.transform, "partition transforms");
+		payload += StringUtil::Format("partition_field\t%d\t%d\t%d\t%d\t%s\n", partition.table_id.index,
+		                              partition.id.GetIndex(), field.partition_key_index, field.field_id.index,
+		                              field.transform);
+	}
+}
+
+idx_t AuxCatalogMetadataManager::GetNextColumnId(TableIndex table_id) {
+	auto output = RuntimeExecute("GetNextColumnId", StringUtil::Format("table_id=%d\n", table_id.index));
+	return AuxCatalogParseIndex(AuxCatalogRequireValue(output, "next_column_id"), "next column id");
+}
+
+bool AuxCatalogMetadataManager::TryAddColumns(DuckLakeSnapshot &commit_snapshot,
+                                              const vector<DuckLakeNewColumn> &new_columns) {
+	if (new_columns.empty()) {
+		return false;
+	}
+	auto table_id = new_columns[0].table_id;
+	string payload;
+	for (auto &column : new_columns) {
+		if (column.table_id != table_id) {
+			throw NotImplementedException("aux_catalog ALTER TABLE currently supports one table per commit");
+		}
+		AppendColumnPayload(payload, column);
+	}
+	pending_add_columns_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropTables(DuckLakeSnapshot &commit_snapshot, const set<TableIndex> &dropped_tables) {
+	if (dropped_tables.empty()) {
+		return false;
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &table_id : dropped_tables) {
+		AppendDropTablePayload(payload, table_id);
+	}
+	pending_drop_tables_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryRenameColumns(DuckLakeSnapshot &commit_snapshot,
+                                                 const vector<DuckLakeTableInfo> &existing_tables,
+                                                 const vector<DuckLakeDroppedColumn> &dropped_columns,
+                                                 const vector<DuckLakeNewColumn> &new_columns) {
+	if (!IsRenameColumnPayload(existing_tables, dropped_columns, new_columns)) {
+		return false;
+	}
+	string payload;
+	for (auto &column : new_columns) {
+		AppendRenameColumnPayload(payload, existing_tables, column);
+	}
+	pending_rename_columns_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryChangeColumnTypes(DuckLakeSnapshot &commit_snapshot,
+                                                     const vector<DuckLakeTableInfo> &existing_tables,
+                                                     const vector<DuckLakeDroppedColumn> &dropped_columns,
+                                                     const vector<DuckLakeNewColumn> &new_columns) {
+	if (!IsColumnTypeChangePayload(existing_tables, dropped_columns, new_columns)) {
+		return false;
+	}
+	string payload;
+	for (auto &column : new_columns) {
+		AppendChangeColumnTypePayload(payload, existing_tables, column);
+	}
+	pending_change_column_types_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryChangeColumnDefaults(DuckLakeSnapshot &commit_snapshot,
+                                                        const vector<DuckLakeTableInfo> &existing_tables,
+                                                        const vector<DuckLakeDroppedColumn> &dropped_columns,
+                                                        const vector<DuckLakeNewColumn> &new_columns) {
+	if (!IsColumnDefaultChangePayload(existing_tables, dropped_columns, new_columns)) {
+		return false;
+	}
+	string payload;
+	for (auto &column : new_columns) {
+		AppendColumnPayload(payload, column);
+	}
+	pending_change_column_defaults_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryChangePartitionKeys(DuckLakeSnapshot &commit_snapshot,
+                                                       const vector<DuckLakePartitionInfo> &existing_partitions,
+                                                       const vector<DuckLakePartitionInfo> &new_partitions) {
+	if (new_partitions.empty()) {
+		return false;
+	}
+	auto changed_partitions = ChangedPartitions(existing_partitions, new_partitions);
+	if (changed_partitions.empty()) {
+		return true;
+	}
+	string payload;
+	for (auto &partition : changed_partitions) {
+		payload.clear();
+		AppendPartitionPayload(payload, *partition);
+		pending_change_partition_keys_payload += SchemaRuntimePayload(commit_snapshot, active_read_snapshot_id, payload);
+	}
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryChangeSortKeys(DuckLakeSnapshot &commit_snapshot,
+                                                  const vector<DuckLakeSortInfo> &existing_sorts,
+                                                  const vector<DuckLakeSortInfo> &new_sorts) {
+	if (new_sorts.empty()) {
+		return false;
+	}
+	auto changed_sorts = ChangedSorts(existing_sorts, new_sorts);
+	if (changed_sorts.empty()) {
+		return true;
+	}
+	for (auto &changed_sort : changed_sorts) {
+		string payload;
+		AppendSortPayload(payload, *changed_sort);
+		pending_change_sort_keys_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	}
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropColumns(DuckLakeSnapshot &commit_snapshot,
+                                               const vector<DuckLakeDroppedColumn> &dropped_columns) {
+	if (dropped_columns.empty()) {
+		return false;
+	}
+	auto table_id = dropped_columns[0].table_id;
+	string payload;
+	for (auto &column : dropped_columns) {
+		if (column.table_id != table_id) {
+			throw NotImplementedException("aux_catalog DROP COLUMN currently supports one table per commit");
+		}
+		AppendDropColumnPayload(payload, column);
+	}
+	pending_drop_columns_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryRenameTables(DuckLakeSnapshot &commit_snapshot,
+                                                const vector<DuckLakeTableInfo> &renamed_tables) {
+	if (renamed_tables.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &table : renamed_tables) {
+		AppendRenameTablePayload(payload, table);
+	}
+	pending_rename_tables_payload += SchemaRuntimePayload(commit_snapshot, optional_idx(), payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_schema_payload.cpp b/src/metadata_manager/aux_catalog_schema_payload.cpp
new file mode 100644
index 00000000..2bde9286
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_schema_payload.cpp
@@ -0,0 +1,216 @@
+#include "metadata_manager/aux_catalog_schema_payload.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+
+namespace duckdb {
+
+static void RejectColumnPayloadField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static void AppendColumnPayloadRow(string &payload, const DuckLakeNewColumn &column) {
+	RejectColumnPayloadField(column.column_info.name, "column names");
+	RejectColumnPayloadField(column.column_info.type, "column types");
+	auto initial_default =
+	    column.column_info.initial_default.IsNull() ? string() : column.column_info.initial_default.ToString();
+	auto default_value =
+	    column.column_info.default_value.IsNull() ? string("NULL") : column.column_info.default_value.ToString();
+	auto default_value_type =
+	    column.column_info.default_value_type.empty() ? string("literal") : column.column_info.default_value_type;
+	RejectColumnPayloadField(initial_default, "column initial defaults");
+	RejectColumnPayloadField(default_value, "column defaults");
+	RejectColumnPayloadField(default_value_type, "column default types");
+	payload += StringUtil::Format("column\t%d\t%d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", column.table_id.index,
+	                              column.column_info.id.index, column.column_info.name, column.column_info.type,
+	                              column.column_info.nulls_allowed ? "true" : "false",
+	                              column.parent_idx.IsValid() ? std::to_string(column.parent_idx.GetIndex()) : "",
+	                              initial_default, default_value, default_value_type);
+}
+
+void AppendColumnPayload(string &payload, const DuckLakeNewColumn &column) {
+	AppendColumnPayloadRow(payload, column);
+	for (auto &child : column.column_info.children) {
+		DuckLakeNewColumn child_column;
+		child_column.table_id = column.table_id;
+		child_column.column_info = child;
+		child_column.parent_idx = optional_idx(column.column_info.id.index);
+		AppendColumnPayload(payload, child_column);
+	}
+}
+
+static optional_ptr<const DuckLakeColumnInfo> FindExistingTopLevelColumn(const vector<DuckLakeTableInfo> &existing_tables,
+                                                                         TableIndex table_id, FieldIndex field_id) {
+	for (auto &table : existing_tables) {
+		if (table.id != table_id) {
+			continue;
+		}
+		for (auto &column : table.columns) {
+			if (column.id == field_id) {
+				return optional_ptr<const DuckLakeColumnInfo>(&column);
+			}
+		}
+	}
+	return nullptr;
+}
+
+static optional_ptr<const DuckLakeColumnInfo> FindColumnByFieldId(const vector<DuckLakeColumnInfo> &columns,
+                                                                  FieldIndex field_id, optional_idx &parent_idx) {
+	for (auto &column : columns) {
+		if (column.id == field_id) {
+			return optional_ptr<const DuckLakeColumnInfo>(&column);
+		}
+		optional_idx child_parent_idx(column.id.index);
+		auto child = FindColumnByFieldId(column.children, field_id, child_parent_idx);
+		if (child) {
+			parent_idx = child_parent_idx;
+			return child;
+		}
+	}
+	return nullptr;
+}
+
+static optional_ptr<const DuckLakeColumnInfo> FindExistingColumn(const vector<DuckLakeTableInfo> &existing_tables,
+                                                                 TableIndex table_id, FieldIndex field_id,
+                                                                 optional_idx &parent_idx) {
+	parent_idx = optional_idx();
+	for (auto &table : existing_tables) {
+		if (table.id != table_id) {
+			continue;
+		}
+		return FindColumnByFieldId(table.columns, field_id, parent_idx);
+	}
+	return nullptr;
+}
+
+static bool IsSameColumnReplacement(const DuckLakeDroppedColumn &dropped_column, const DuckLakeNewColumn &new_column) {
+	return dropped_column.table_id == new_column.table_id && dropped_column.field_id == new_column.column_info.id;
+}
+
+static string ValueFingerprint(const Value &value) {
+	return value.IsNull() ? string("<NULL>") : value.ToString();
+}
+
+static bool IsSameDefaultMetadata(const DuckLakeColumnInfo &existing, const DuckLakeColumnInfo &replacement) {
+	return ValueFingerprint(existing.initial_default) == ValueFingerprint(replacement.initial_default) &&
+	       ValueFingerprint(existing.default_value) == ValueFingerprint(replacement.default_value) &&
+	       existing.default_value_type == replacement.default_value_type;
+}
+
+bool IsRenameColumnPayload(const vector<DuckLakeTableInfo> &existing_tables,
+                           const vector<DuckLakeDroppedColumn> &dropped_columns,
+                           const vector<DuckLakeNewColumn> &new_columns) {
+	if (dropped_columns.empty() || dropped_columns.size() != new_columns.size()) {
+		return false;
+	}
+	for (idx_t i = 0; i < dropped_columns.size(); i++) {
+		if (!IsSameColumnReplacement(dropped_columns[i], new_columns[i])) {
+			return false;
+		}
+		optional_idx existing_parent_idx;
+		auto existing =
+		    FindExistingColumn(existing_tables, dropped_columns[i].table_id, dropped_columns[i].field_id, existing_parent_idx);
+		if (!existing || !existing->children.empty()) {
+			return false;
+		}
+		auto &replacement = new_columns[i].column_info;
+		if (existing_parent_idx != new_columns[i].parent_idx) {
+			return false;
+		}
+		if (StringUtil::CIEquals(existing->name, replacement.name) || existing->type != replacement.type) {
+			return false;
+		}
+		if (!existing_parent_idx.IsValid() && existing->nulls_allowed != replacement.nulls_allowed) {
+			return false;
+		}
+	}
+	return true;
+}
+
+void AppendRenameColumnPayload(string &payload, const vector<DuckLakeTableInfo> &existing_tables,
+                               const DuckLakeNewColumn &renamed_column) {
+	optional_idx parent_idx;
+	auto existing = FindExistingColumn(existing_tables, renamed_column.table_id, renamed_column.column_info.id, parent_idx);
+	if (!existing) {
+		throw InternalException("aux_catalog could not find renamed column %d in existing catalog",
+		                        renamed_column.column_info.id.index);
+	}
+	DuckLakeNewColumn payload_column;
+	payload_column.table_id = renamed_column.table_id;
+	payload_column.column_info = renamed_column.column_info;
+	payload_column.column_info.name = renamed_column.column_info.name;
+	payload_column.parent_idx = parent_idx;
+	AppendColumnPayload(payload, payload_column);
+}
+
+bool IsColumnTypeChangePayload(const vector<DuckLakeTableInfo> &existing_tables,
+                               const vector<DuckLakeDroppedColumn> &dropped_columns,
+                               const vector<DuckLakeNewColumn> &new_columns) {
+	if (dropped_columns.empty() || dropped_columns.size() != new_columns.size()) {
+		return false;
+	}
+	for (idx_t i = 0; i < dropped_columns.size(); i++) {
+		if (!IsSameColumnReplacement(dropped_columns[i], new_columns[i])) {
+			return false;
+		}
+		optional_idx existing_parent_idx;
+		auto existing =
+		    FindExistingColumn(existing_tables, dropped_columns[i].table_id, dropped_columns[i].field_id, existing_parent_idx);
+		if (!existing || !existing->children.empty()) {
+			return false;
+		}
+		auto &replacement = new_columns[i].column_info;
+		if (existing_parent_idx != new_columns[i].parent_idx) {
+			return false;
+		}
+		if (!StringUtil::CIEquals(existing->name, replacement.name) || existing->type == replacement.type) {
+			return false;
+		}
+		if (!existing_parent_idx.IsValid() && existing->nulls_allowed != replacement.nulls_allowed) {
+			return false;
+		}
+	}
+	return true;
+}
+
+void AppendChangeColumnTypePayload(string &payload, const vector<DuckLakeTableInfo> &existing_tables,
+                                   const DuckLakeNewColumn &changed_column) {
+	optional_idx parent_idx;
+	auto existing = FindExistingColumn(existing_tables, changed_column.table_id, changed_column.column_info.id, parent_idx);
+	if (!existing) {
+		throw InternalException("aux_catalog could not find changed column %d in existing catalog",
+		                        changed_column.column_info.id.index);
+	}
+	DuckLakeNewColumn payload_column;
+	payload_column.table_id = changed_column.table_id;
+	payload_column.column_info = changed_column.column_info;
+	payload_column.parent_idx = parent_idx;
+	AppendColumnPayload(payload, payload_column);
+}
+
+bool IsColumnDefaultChangePayload(const vector<DuckLakeTableInfo> &existing_tables,
+                                  const vector<DuckLakeDroppedColumn> &dropped_columns,
+                                  const vector<DuckLakeNewColumn> &new_columns) {
+	if (dropped_columns.empty() || dropped_columns.size() != new_columns.size()) {
+		return false;
+	}
+	for (idx_t i = 0; i < dropped_columns.size(); i++) {
+		if (!IsSameColumnReplacement(dropped_columns[i], new_columns[i])) {
+			return false;
+		}
+		auto existing = FindExistingTopLevelColumn(existing_tables, dropped_columns[i].table_id, dropped_columns[i].field_id);
+		if (!existing || !existing->children.empty()) {
+			return false;
+		}
+		auto &replacement = new_columns[i].column_info;
+		if (!StringUtil::CIEquals(existing->name, replacement.name) || existing->type != replacement.type ||
+		    existing->nulls_allowed != replacement.nulls_allowed || IsSameDefaultMetadata(*existing, replacement)) {
+			return false;
+		}
+	}
+	return true;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_snapshots.cpp b/src/metadata_manager/aux_catalog_snapshots.cpp
new file mode 100644
index 00000000..7c7c0b15
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_snapshots.cpp
@@ -0,0 +1,168 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+
+#include "duckdb/common/string_util.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include <algorithm>
+#include <sstream>
+
+namespace duckdb {
+
+static int64_t ParseInt64(const string &value, const char *field_name) {
+	try {
+		return std::stoll(value);
+	} catch (std::exception &ex) {
+		throw IOException("aux_catalog runtime returned invalid %s '%s': %s", field_name, value, ex.what());
+	}
+}
+
+static vector<idx_t> ParseSnapshotIds(const string &value) {
+	vector<idx_t> ids;
+	std::stringstream stream(value);
+	string part;
+	while (std::getline(stream, part, ',')) {
+		StringUtil::Trim(part);
+		if (part.empty()) {
+			continue;
+		}
+		ids.push_back(AuxCatalogParseIndex(part, "snapshot id"));
+	}
+	return ids;
+}
+
+struct SnapshotSelection {
+	vector<idx_t> requested_ids;
+	bool has_older_than = false;
+	int64_t older_than_micros = 0;
+	bool protects_latest = false;
+};
+
+static int64_t SnapshotMicrosFromFilter(const string &filter) {
+	auto start = filter.find('\'');
+	if (start == string::npos) {
+		throw IOException("aux_catalog received invalid snapshot timestamp filter: %s", filter);
+	}
+	start++;
+	auto end = filter.find('\'', start);
+	if (end == string::npos) {
+		throw IOException("aux_catalog received invalid snapshot timestamp filter: %s", filter);
+	}
+	auto timestamp_text = filter.substr(start, end - start);
+	auto timestamp = Value(timestamp_text).DefaultCastAs(LogicalType::TIMESTAMP_TZ).GetValue<timestamp_tz_t>();
+	return timestamp.value;
+}
+
+static SnapshotSelection SnapshotSelectionFromExpireFilter(const string &filter) {
+	SnapshotSelection selection;
+	if (filter.empty()) {
+		return selection;
+	}
+	selection.protects_latest = filter.find("snapshot_id !=") != string::npos;
+	if (filter.find("snapshot_time") != string::npos) {
+		selection.has_older_than = true;
+		selection.older_than_micros = SnapshotMicrosFromFilter(filter);
+		return selection;
+	}
+	const string marker = "snapshot_id IN (";
+	auto start = filter.find(marker);
+	if (start == string::npos) {
+		return selection;
+	}
+	start += marker.size();
+	auto end = filter.find(')', start);
+	if (end == string::npos) {
+		throw IOException("aux_catalog received invalid snapshot filter: %s", filter);
+	}
+	selection.requested_ids = ParseSnapshotIds(filter.substr(start, end - start));
+	return selection;
+}
+
+static string JoinSnapshotIds(const vector<idx_t> &ids) {
+	string result;
+	for (auto id : ids) {
+		if (!result.empty()) {
+			result += ",";
+		}
+		result += std::to_string(id);
+	}
+	return result;
+}
+
+static Value ParseNullableSnapshotString(const string &field) {
+	if (field.empty()) {
+		return Value();
+	}
+	if (field == "\\0") {
+		return Value(string());
+	}
+	return Value(field);
+}
+
+static vector<DuckLakeSnapshotInfo> ParseSnapshotRows(const string &output) {
+	vector<DuckLakeSnapshotInfo> snapshots;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("snapshot\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 7 && fields.size() != 8 && fields.size() != 9) {
+			throw IOException("aux_catalog runtime returned invalid snapshot row: %s", line);
+		}
+		DuckLakeSnapshotInfo snapshot;
+		snapshot.id = AuxCatalogParseIndex(fields[1], "snapshot id");
+		snapshot.time = timestamp_tz_t(ParseInt64(fields[2], "snapshot time"));
+		snapshot.schema_version = AuxCatalogParseIndex(fields[3], "snapshot schema version");
+		snapshot.next_file_id = AuxCatalogParseIndex(fields[4], "snapshot next file id");
+		if (fields.size() == 9) {
+			snapshot.change_info.changes_made = fields[5];
+			snapshot.author = ParseNullableSnapshotString(fields[6]);
+			snapshot.commit_message = ParseNullableSnapshotString(fields[7]);
+			snapshot.commit_extra_info = ParseNullableSnapshotString(fields[8]);
+		} else if (fields.size() == 8) {
+			snapshot.change_info.changes_made = fields[5];
+			snapshot.author = ParseNullableSnapshotString(fields[6]);
+			snapshot.commit_message = ParseNullableSnapshotString(fields[7]);
+			snapshot.commit_extra_info = Value();
+		} else {
+			snapshot.change_info.changes_made = string();
+			snapshot.author = ParseNullableSnapshotString(fields[5]);
+			snapshot.commit_message = ParseNullableSnapshotString(fields[6]);
+			snapshot.commit_extra_info = Value();
+		}
+		snapshots.push_back(std::move(snapshot));
+	}
+	return snapshots;
+}
+
+vector<DuckLakeSnapshotInfo> AuxCatalogMetadataManager::GetAllSnapshots(const string &filter) {
+	auto selection = SnapshotSelectionFromExpireFilter(filter);
+	string payload;
+	if (selection.has_older_than) {
+		payload = "older_than_micros=" + std::to_string(selection.older_than_micros) + "\n";
+	}
+	if (!selection.requested_ids.empty()) {
+		payload += "snapshot_ids=" + JoinSnapshotIds(selection.requested_ids) + "\n";
+	}
+	if (selection.protects_latest) {
+		payload += "protect_latest=true\n";
+	}
+	auto output = RuntimeExecute("ListSnapshots", payload);
+	auto snapshots = ParseSnapshotRows(output);
+	return snapshots;
+}
+
+void AuxCatalogMetadataManager::DeleteSnapshots(const vector<DuckLakeSnapshotInfo> &snapshots) {
+	vector<idx_t> ids;
+	for (auto &snapshot : snapshots) {
+		ids.push_back(snapshot.id);
+	}
+	if (ids.empty()) {
+		return;
+	}
+	auto joined_ids = JoinSnapshotIds(ids);
+	RuntimeExecute("ExpireSnapshots", "snapshot_ids=" + joined_ids + "\nsnapshot_kind=ducklake\n");
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_tags.cpp b/src/metadata_manager/aux_catalog_tags.cpp
new file mode 100644
index 00000000..d567a651
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_tags.cpp
@@ -0,0 +1,91 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+
+namespace duckdb {
+
+static void RejectCommentField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static bool IsKnownTable(const DuckLakeCatalogInfo &catalog, idx_t table_id) {
+	for (auto &table : catalog.tables) {
+		if (table.id.index == table_id) {
+			return true;
+		}
+	}
+	return false;
+}
+
+static string CommentValueKind(const Value &value) {
+	return value.IsNull() ? "null" : "value";
+}
+
+static string CommentValuePayload(const Value &value) {
+	if (value.IsNull()) {
+		return string();
+	}
+	auto text = value.ToString();
+	RejectCommentField(text, "comments");
+	return text;
+}
+
+static void AppendTableCommentPayload(string &payload, const DuckLakeTagInfo &tag) {
+	if (tag.key != "comment") {
+		throw NotImplementedException("aux_catalog only supports table comment tags currently");
+	}
+	auto value = CommentValuePayload(tag.value);
+	payload += StringUtil::Format("table_comment\t%d\t%s\t%s\n", tag.id, CommentValueKind(tag.value), value);
+}
+
+static void AppendColumnCommentPayload(string &payload, const DuckLakeColumnTagInfo &tag) {
+	if (tag.key != "comment") {
+		throw NotImplementedException("aux_catalog only supports column comment tags currently");
+	}
+	auto value = CommentValuePayload(tag.value);
+	payload += StringUtil::Format("column_comment\t%d\t%d\t%s\t%s\n", tag.table_id.index, tag.field_index.index,
+	                              CommentValueKind(tag.value), value);
+}
+
+static string CommentRuntimePayload(DuckLakeSnapshot &commit_snapshot, const string &payload) {
+	return StringUtil::Format("commit_snapshot\t%d\n%s", commit_snapshot.snapshot_id, payload);
+}
+
+bool AuxCatalogMetadataManager::TryChangeTags(DuckLakeSnapshot &commit_snapshot,
+                                              const DuckLakeCatalogInfo &existing_catalog,
+                                              const vector<DuckLakeTagInfo> &new_tags,
+                                              const vector<DuckLakeColumnTagInfo> &new_column_tags) {
+	if (new_tags.empty() && new_column_tags.empty()) {
+		return false;
+	}
+	if (!new_column_tags.empty()) {
+		for (auto &tag : new_tags) {
+			if (!IsKnownTable(existing_catalog, tag.id)) {
+				throw NotImplementedException("aux_catalog cannot mix column comments with view comments currently");
+			}
+		}
+	}
+	if (new_tags.size() == 1 && new_column_tags.empty() && !IsKnownTable(existing_catalog, new_tags[0].id) &&
+	    new_tags[0].key == "comment") {
+		return TryChangeViewComment(commit_snapshot, new_tags[0]);
+	}
+	string payload;
+	for (auto &tag : new_tags) {
+		if (!IsKnownTable(existing_catalog, tag.id)) {
+			throw NotImplementedException("aux_catalog view comments and generic object tags are not implemented yet");
+		}
+		AppendTableCommentPayload(payload, tag);
+	}
+	for (auto &tag : new_column_tags) {
+		AppendColumnCommentPayload(payload, tag);
+	}
+	pending_change_comments_payload += CommentRuntimePayload(commit_snapshot, payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_views.cpp b/src/metadata_manager/aux_catalog_views.cpp
new file mode 100644
index 00000000..316f5d11
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_views.cpp
@@ -0,0 +1,124 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+
+namespace duckdb {
+
+static void RejectViewField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos || value.find('\x1f') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs, newlines, or unit separators yet", field_name);
+	}
+}
+
+static string CommentTagValue(const vector<DuckLakeTag> &tags) {
+	string comment;
+	for (auto &tag : tags) {
+		if (tag.key == "comment") {
+			comment = tag.value;
+			continue;
+		}
+		throw NotImplementedException("aux_catalog only supports view comment tags currently");
+	}
+	return comment;
+}
+
+static string AliasPayload(const vector<string> &aliases) {
+	string payload;
+	for (auto &alias : aliases) {
+		RejectViewField(alias, "view aliases");
+		if (!payload.empty()) {
+			payload.push_back('\x1f');
+		}
+		payload += alias;
+	}
+	return payload;
+}
+
+static string CommentValueKind(const Value &value) {
+	return value.IsNull() ? "null" : "value";
+}
+
+static string CommentValuePayload(const Value &value) {
+	if (value.IsNull()) {
+		return string();
+	}
+	auto text = value.ToString();
+	RejectViewField(text, "view comments");
+	return text;
+}
+
+static void AppendViewPayload(string &payload, const DuckLakeViewInfo &view) {
+	RejectViewField(view.uuid, "view UUIDs");
+	RejectViewField(view.name, "view names");
+	RejectViewField(view.dialect, "view dialects");
+	RejectViewField(view.sql, "view SQL");
+	auto aliases = AliasPayload(view.column_aliases);
+	auto comment = CommentTagValue(view.tags);
+	RejectViewField(comment, "view comments");
+	payload += StringUtil::Format("view\t%d\t%d\t%s\t%s\t%s\t%s\t%s\t%s\n", view.id.index, view.schema_id.index,
+	                              view.uuid, view.name, view.dialect, view.sql, aliases, comment);
+}
+
+static void AppendRenameViewPayload(string &payload, const DuckLakeViewInfo &view) {
+	RejectViewField(view.name, "view names");
+	payload += StringUtil::Format("view\t%d\t%s\n", view.id.index, view.name);
+}
+
+static void AppendDropViewPayload(string &payload, TableIndex view_id) {
+	payload += StringUtil::Format("view\t%d\n", view_id.index);
+}
+
+bool AuxCatalogMetadataManager::TryCreateViews(DuckLakeSnapshot &, const vector<DuckLakeViewInfo> &new_views) {
+	if (new_views.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &view : new_views) {
+		AppendViewPayload(payload, view);
+	}
+	RuntimeExecute("CreateViews", payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryRenameViews(DuckLakeSnapshot &, const vector<DuckLakeViewInfo> &renamed_views) {
+	if (renamed_views.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &view : renamed_views) {
+		AppendRenameViewPayload(payload, view);
+	}
+	RuntimeExecute("RenameViews", payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropViews(DuckLakeSnapshot &, const set<TableIndex> &dropped_views) {
+	if (dropped_views.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &view_id : dropped_views) {
+		AppendDropViewPayload(payload, view_id);
+	}
+	RuntimeExecute("DropViews", payload);
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryChangeViewComment(DuckLakeSnapshot &commit_snapshot, const DuckLakeTagInfo &tag) {
