+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+
+namespace duckdb {
+
+static void RejectMacroField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos || value.find('\x1f') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs, newlines, or unit separators yet", field_name);
+	}
+}
+
+static string MacroDefaultValue(const Value &value) {
+	return value.IsNull() ? "NULL" : value.ToString();
+}
+
+static void AppendMacroPayload(string &payload, const DuckLakeMacroInfo &macro) {
+	RejectMacroField(macro.macro_name, "macro names");
+	payload += StringUtil::Format("macro\t%d\t%d\t%s\n", macro.macro_id.index, macro.schema_id.index, macro.macro_name);
+	for (idx_t impl_id = 0; impl_id < macro.implementations.size(); impl_id++) {
+		auto &implementation = macro.implementations[impl_id];
+		RejectMacroField(implementation.dialect, "macro dialects");
+		RejectMacroField(implementation.sql, "macro SQL");
+		RejectMacroField(implementation.type, "macro types");
+		payload += StringUtil::Format("macro_impl\t%d\t%d\t%s\t%s\t%s\n", macro.macro_id.index, impl_id,
+		                              implementation.dialect, implementation.sql, implementation.type);
+		for (idx_t param_id = 0; param_id < implementation.parameters.size(); param_id++) {
+			auto &parameter = implementation.parameters[param_id];
+			auto default_value = MacroDefaultValue(parameter.default_value);
+			RejectMacroField(parameter.parameter_name, "macro parameter names");
+			RejectMacroField(parameter.parameter_type, "macro parameter types");
+			RejectMacroField(default_value, "macro parameter default values");
+			RejectMacroField(parameter.default_value_type, "macro parameter default types");
+			payload += StringUtil::Format("macro_param\t%d\t%d\t%d\t%s\t%s\t%s\t%s\n", macro.macro_id.index,
+			                              impl_id, param_id, parameter.parameter_name, parameter.parameter_type,
+			                              default_value, parameter.default_value_type);
+		}
+	}
+}
+
+static void AppendDropMacroPayload(string &payload, MacroIndex macro_id) {
+	payload += StringUtil::Format("macro\t%d\n", macro_id.index);
+}
+
+bool AuxCatalogMetadataManager::TryCreateMacros(DuckLakeSnapshot &commit_snapshot,
+                                                const vector<DuckLakeMacroInfo> &new_macros) {
+	if (new_macros.empty()) {
+		return false;
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &macro : new_macros) {
+		AppendMacroPayload(payload, macro);
+	}
+	pending_create_macros_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropMacros(DuckLakeSnapshot &commit_snapshot, const set<MacroIndex> &dropped_macros) {
+	if (dropped_macros.empty()) {
+		return false;
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &macro_id : dropped_macros) {
+		AppendDropMacroPayload(payload, macro_id);
+	}
+	pending_drop_macros_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_metadata_manager.cpp b/src/metadata_manager/aux_catalog_metadata_manager.cpp
new file mode 100644
index 00000000..6c9a5c8c
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_metadata_manager.cpp
@@ -0,0 +1,1287 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "storage/ducklake_catalog.hpp"
+#include "storage/ducklake_table_entry.hpp"
+#include "storage/ducklake_transaction.hpp"
+#include <array>
+#include <cstdlib>
+#include <sstream>
+#include <unordered_map>
+#include <unordered_set>
+
+namespace duckdb {
+static void RejectRuntimeField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static string SqlLiteralToPayloadValue(const string &value) {
+	if (value == "NULL") {
+		return string();
+	}
+	if (value.size() < 2 || value.front() != '\'' || value.back() != '\'') {
+		return value;
+	}
+	string out;
+	for (idx_t i = 1; i + 1 < value.size(); i++) {
+		if (value[i] == '\'' && i + 2 < value.size() && value[i + 1] == '\'') {
+			out.push_back('\'');
+			i++;
+		} else {
+			out.push_back(value[i]);
+		}
+	}
+	return out;
+}
+
+static idx_t RequireRuntimeIndex(const string &output, const string &key) {
+	return AuxCatalogParseIndex(AuxCatalogRequireValue(output, key), key.c_str());
+}
+
+static uint64_t RequireRuntimeUInt64(const string &output, const string &key) {
+	return AuxCatalogParseUInt64(AuxCatalogRequireValue(output, key), key.c_str());
+}
+
+static vector<TableIndex> OptionalRuntimeTableIndexList(const string &output, const string &key) {
+	vector<TableIndex> result;
+	auto value = AuxCatalogRequireValue(output, key);
+	if (value.empty()) {
+		return result;
+	}
+	idx_t start = 0;
+	for (idx_t i = 0; i <= value.size(); i++) {
+		if (i == value.size() || value[i] == ',') {
+			result.emplace_back(AuxCatalogParseIndex(value.substr(start, i - start), key.c_str()));
+			start = i + 1;
+		}
+	}
+	return result;
+}
+
+static string JoinTabularFields(const vector<string> &fields) {
+	string line;
+	for (idx_t i = 0; i < fields.size(); i++) {
+		if (i > 0) {
+			line += "\t";
+		}
+		line += fields[i];
+	}
+	return line;
+}
+
+static string RewriteInlinedTableNameForTableId(const string &table_name, idx_t requested_id, idx_t persisted_id) {
+	auto requested_prefix = StringUtil::Format("ducklake_inlined_data_%d_", requested_id);
+	if (!StringUtil::StartsWith(table_name, requested_prefix)) {
+		return table_name;
+	}
+	return StringUtil::Format("ducklake_inlined_data_%d_%s", persisted_id,
+	                          table_name.substr(requested_prefix.size()));
+}
+
+TableIndex AuxCatalogMetadataManager::RemapCreatedTableId(TableIndex table_id) const {
+	auto entry = created_table_id_remaps.find(table_id.index);
+	if (entry == created_table_id_remaps.end()) {
+		return table_id;
+	}
+	return TableIndex(entry->second);
+}
+
+string AuxCatalogMetadataManager::RemapCreatedInlinedTableName(const string &table_name) const {
+	for (auto &entry : created_table_id_remaps) {
+		auto rewritten = RewriteInlinedTableNameForTableId(table_name, entry.first, entry.second);
+		if (rewritten != table_name) {
+			return rewritten;
+		}
+	}
+	return table_name;
+}
+
+void AuxCatalogMetadataManager::RegisterCreatedTableRemap(TableIndex requested_table_id, TableIndex persisted_table_id) {
+	if (requested_table_id == persisted_table_id) {
+		return;
+	}
+	created_table_id_remaps[requested_table_id.index] = persisted_table_id.index;
+}
+
+static void RewriteInlineTablePayloadTableId(string &payload, idx_t requested_id, idx_t persisted_id) {
+	if (payload.empty() || requested_id == persisted_id) {
+		return;
+	}
+	std::stringstream stream(payload);
+	string rewritten;
+	string line;
+	while (std::getline(stream, line)) {
+		auto fields = StringUtil::Split(line, "\t");
+		if (fields.size() >= 4 && fields[0] == "table" &&
+		    AuxCatalogParseIndex(fields[1], "inline table remap table id") == requested_id) {
+			fields[1] = std::to_string(persisted_id);
+			fields[3] = RewriteInlinedTableNameForTableId(fields[3], requested_id, persisted_id);
+			line = JoinTabularFields(fields);
+		} else if (fields.size() == 4 && fields[0] == "delete" &&
+		           AuxCatalogParseIndex(fields[1], "inline delete remap table id") == requested_id) {
+			fields[1] = std::to_string(persisted_id);
+			fields[2] = RewriteInlinedTableNameForTableId(fields[2], requested_id, persisted_id);
+			line = JoinTabularFields(fields);
+		} else if (fields.size() == 3 && fields[0] == "inline_table") {
+			fields[1] = RewriteInlinedTableNameForTableId(fields[1], requested_id, persisted_id);
+			line = JoinTabularFields(fields);
+		}
+		rewritten += line;
+		rewritten += "\n";
+	}
+	payload = std::move(rewritten);
+}
+
+static bool ParseInlinedTableName(const string &table_name, idx_t &table_id, idx_t &schema_version) {
+	const string prefix = "ducklake_inlined_data_";
+	if (table_name.rfind(prefix, 0) != 0) {
+		return false;
+	}
+	auto id_start = prefix.size();
+	auto id_end = table_name.find('_', id_start);
+	if (id_end == string::npos || id_end + 1 >= table_name.size()) {
+		return false;
+	}
+	try {
+		table_id = NumericCast<idx_t>(std::stoull(table_name.substr(id_start, id_end - id_start)));
+		schema_version = NumericCast<idx_t>(std::stoull(table_name.substr(id_end + 1)));
+		return true;
+	} catch (std::exception &) {
+		return false;
+	}
+}
+
+static bool AppendGeneratedInlineFlushDeletes(string &payload, const string &query) {
+	bool found = false;
+	idx_t search_from = 0;
+	const string table_prefix = "ducklake_inlined_data_";
+	const string snapshot_marker = "begin_snapshot <= ";
+	while (true) {
+		auto table_start = query.find(table_prefix, search_from);
+		if (table_start == string::npos) {
+			return found;
+		}
+		auto table_end = table_start;
+		while (table_end < query.size() &&
+		       (StringUtil::CharacterIsAlphaNumeric(query[table_end]) || query[table_end] == '_')) {
+			table_end++;
+		}
+		auto table_name = query.substr(table_start, table_end - table_start);
+		idx_t table_id;
+		idx_t schema_version;
+		if (!ParseInlinedTableName(table_name, table_id, schema_version)) {
+			search_from = table_end;
+			continue;
+		}
+		auto snapshot_start = query.find(snapshot_marker, table_end);
+		if (snapshot_start == string::npos) {
+			search_from = table_end;
+			continue;
+		}
+		snapshot_start += snapshot_marker.size();
+		auto snapshot_end = snapshot_start;
+		while (snapshot_end < query.size() && StringUtil::CharacterIsDigit(query[snapshot_end])) {
+			snapshot_end++;
+		}
+		if (snapshot_end == snapshot_start) {
+			search_from = snapshot_end;
+			continue;
+		}
+		auto flush_snapshot = AuxCatalogParseIndex(query.substr(snapshot_start, snapshot_end - snapshot_start),
+		                                 "generated inline flush snapshot");
+		payload += StringUtil::Format("inline_table\t%s\t%d\n", table_name, flush_snapshot);
+		found = true;
+		search_from = snapshot_end;
+	}
+}
+
+static void ApplyCreatedTableRemaps(const string &output, string &pending_register_inline_tables_payload,
+                                    string &pending_register_inline_rows_payload,
+                                    string &pending_inline_deletes_payload, string &pending_flushed_inline_payload,
+                                    optional_ptr<DuckLakeTransaction> transaction = nullptr,
+                                    optional_ptr<AuxCatalogMetadataManager> manager = nullptr) {
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		auto fields = StringUtil::Split(line, "\t");
+		if (fields.empty() || fields[0] != "created_table") {
+			continue;
+		}
+		if (fields.size() != 5) {
+			throw IOException("aux_catalog CreateTables returned invalid created_table row: %s", line);
+		}
+		auto requested_id = AuxCatalogParseIndex(fields[1], "created table requested id");
+		auto persisted_id = AuxCatalogParseIndex(fields[2], "created table persisted id");
+		if (manager) {
+			manager->RegisterCreatedTableRemap(TableIndex(requested_id), TableIndex(persisted_id));
+		}
+		if (transaction) {
+			transaction->ApplyExternalCreatedTableRemap(TableIndex(requested_id), TableIndex(persisted_id));
+		}
+		RewriteInlineTablePayloadTableId(pending_register_inline_tables_payload, requested_id, persisted_id);
+		RewriteInlineTablePayloadTableId(pending_register_inline_rows_payload, requested_id, persisted_id);
+		RewriteInlineTablePayloadTableId(pending_inline_deletes_payload, requested_id, persisted_id);
+		RewriteInlineTablePayloadTableId(pending_flushed_inline_payload, requested_id, persisted_id);
+	}
+}
+
+string AuxCatalogMetadataManager::PendingInlineFlushPayload() const {
+	string payload;
+	std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+	for (auto &flush : pending_inline_flushes) {
+		payload += StringUtil::Format("inline_table\t%s\t%d\n", flush.table_name, flush.flush_snapshot_id);
+	}
+	return payload;
+}
+
+static unordered_map<string, unordered_set<idx_t>> InlineDeleteRowIdsByTableName(const string &payload) {
+	unordered_map<string, unordered_set<idx_t>> deleted;
+	std::stringstream stream(payload);
+	string line;
+	while (std::getline(stream, line)) {
+		auto fields = StringUtil::Split(line, "\t");
+		if (fields.size() == 4 && fields[0] == "delete") {
+			deleted[fields[2]].insert(AuxCatalogParseIndex(fields[3], "inline delete row id"));
+		}
+	}
+	return deleted;
+}
+
+static void PromoteDeletedRowBeginPayloads(string &inline_rows_payload, const string &inline_deletes_payload) {
+	if (inline_rows_payload.empty() || inline_deletes_payload.empty()) {
+		return;
+	}
+	auto deleted_by_table = InlineDeleteRowIdsByTableName(inline_deletes_payload);
+	if (deleted_by_table.empty()) {
+		return;
+	}
+	std::stringstream stream(inline_rows_payload);
+	string rewritten;
+	string line;
+	string current_table_name;
+	while (std::getline(stream, line)) {
+		auto fields = StringUtil::Split(line, "\t");
+		if (fields.size() == 4 && fields[0] == "table") {
+			current_table_name = fields[3];
+		} else if (fields.size() >= 4 && fields[0] == "row_begin" && !current_table_name.empty()) {
+			auto table_deletes = deleted_by_table.find(current_table_name);
+			auto row_id = AuxCatalogParseIndex(fields[1], "inline row_begin row id");
+			if (table_deletes != deleted_by_table.end() && table_deletes->second.count(row_id) > 0) {
+				line = "row\t" + fields[1];
+				for (idx_t i = 3; i < fields.size(); i++) {
+					line += "\t";
+					line += fields[i];
+				}
+			}
+		}
+		rewritten += line;
+		rewritten += "\n";
+	}
+	inline_rows_payload = std::move(rewritten);
+}
+
+static string CommentTagValue(const vector<DuckLakeTag> &tags) {
+	string comment;
+	for (auto &tag : tags) {
+		if (tag.key == "comment") {
+			comment = tag.value;
+			continue;
+		}
+		throw NotImplementedException("aux_catalog only supports comment tags currently");
+	}
+	return comment;
+}
+
+static void AppendColumnPayload(string &payload, TableIndex table_id, const DuckLakeColumnInfo &column,
+                                optional_idx parent_id) {
+	RejectRuntimeField(column.name, "column names");
+	RejectRuntimeField(column.type, "column types");
+	auto comment = CommentTagValue(column.tags);
+	auto initial_default = column.initial_default.IsNull() ? string() : column.initial_default.ToString();
+	auto default_value = column.default_value.IsNull() ? string("NULL") : column.default_value.ToString();
+	auto default_value_type = column.default_value_type.empty() ? string("literal") : column.default_value_type;
+	RejectRuntimeField(comment, "column comments");
+	RejectRuntimeField(initial_default, "column initial defaults");
+	RejectRuntimeField(default_value, "column defaults");
+	RejectRuntimeField(default_value_type, "column default types");
+	payload += StringUtil::Format("column\t%d\t%d\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", table_id.index, column.id.index,
+	                              column.name, column.type, column.nulls_allowed ? "true" : "false",
+	                              parent_id.IsValid() ? std::to_string(parent_id.GetIndex()) : "", comment,
+	                              initial_default, default_value, default_value_type);
+	for (auto &child : column.children) {
+		AppendColumnPayload(payload, table_id, child, column.id.index);
+	}
+}
+
+static void AppendTablePayload(string &payload, const DuckLakeTableInfo &table) {
+	RejectRuntimeField(table.uuid, "table UUIDs");
+	RejectRuntimeField(table.name, "table names");
+	RejectRuntimeField(table.path, "table paths");
+	auto comment = CommentTagValue(table.tags);
+	RejectRuntimeField(comment, "table comments");
+	payload += StringUtil::Format("table\t%d\t%d\t%s\t%s\t%s\t%s\n", table.id.index, table.schema_id.index,
+	                              table.uuid, table.name, table.path, comment);
+	for (auto &column : table.columns) {
+		AppendColumnPayload(payload, table.id, column, optional_idx());
+	}
+}
+
+static void AppendDroppedDataFilesPayload(string &payload, const string &dropped_data_files_payload) {
+	std::stringstream stream(dropped_data_files_payload);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		payload += "dropped_data_file\t" + line + "\n";
+	}
+}
+
+static unordered_set<idx_t> DroppedTableIds(const string &drop_tables_payload) {
+	unordered_set<idx_t> dropped;
+	std::stringstream stream(drop_tables_payload);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("commit_snapshot\t", 0) == 0) {
+			continue;
+		}
+		std::stringstream row(line);
+		string tag;
+		string table_id;
+		std::getline(row, tag, '\t');
+		std::getline(row, table_id, '\t');
+		if (tag != "table" || table_id.empty()) {
+			throw IOException("aux_catalog invalid pending table drop row: %s", line);
+		}
+		dropped.insert(AuxCatalogParseIndex(table_id, "dropped table id"));
+	}
+	return dropped;
+}
+
+static bool IsTableScopedMetadataRowForDroppedTable(const string &line, const unordered_set<idx_t> &dropped_tables) {
+	if (line.empty() || line.rfind("commit_snapshot\t", 0) == 0 || line.rfind("read_snapshot\t", 0) == 0) {
+		return false;
+	}
+	std::stringstream row(line);
+	string tag;
+	string table_id;
+	std::getline(row, tag, '\t');
+	std::getline(row, table_id, '\t');
+	if (table_id.empty()) {
+		return false;
+	}
+	static const unordered_set<string> TABLE_SCOPED_TAGS = {"column",        "table",      "partition",
+	                                                        "partition_field", "sort",       "sort_field",
+	                                                        "table_comment", "column_comment"};
+	if (!TABLE_SCOPED_TAGS.count(tag)) {
+		return false;
+	}
+	return dropped_tables.count(AuxCatalogParseIndex(table_id, "table-scoped metadata table id")) > 0;
+}
+
+static void RemoveDroppedTableMetadataRows(string &payload, const unordered_set<idx_t> &dropped_tables) {
+	if (payload.empty() || dropped_tables.empty()) {
+		return;
+	}
+	string filtered;
+	bool kept_data_row = false;
+	std::stringstream stream(payload);
+	string line;
+	while (std::getline(stream, line)) {
+		if (IsTableScopedMetadataRowForDroppedTable(line, dropped_tables)) {
+			continue;
+		}
+		if (!line.empty() && line.rfind("commit_snapshot\t", 0) != 0 && line.rfind("read_snapshot\t", 0) != 0) {
+			kept_data_row = true;
+		}
+		filtered += line;
+		filtered += "\n";
+	}
+	payload = kept_data_row ? std::move(filtered) : string();
+}
+
+static void RemovePendingMetadataForDroppedTables(const string &drop_tables_payload, string &add_columns_payload,
+                                                 string &change_column_defaults_payload,
+                                                 string &change_column_types_payload,
+                                                 string &change_comments_payload, string &drop_columns_payload,
+                                                 string &rename_columns_payload, string &rename_tables_payload,
+                                                 string &change_partition_keys_payload,
+                                                 string &change_sort_keys_payload) {
+	auto dropped_tables = DroppedTableIds(drop_tables_payload);
+	RemoveDroppedTableMetadataRows(add_columns_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(change_column_defaults_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(change_column_types_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(change_comments_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(drop_columns_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(rename_columns_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(rename_tables_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(change_partition_keys_payload, dropped_tables);
+	RemoveDroppedTableMetadataRows(change_sort_keys_payload, dropped_tables);
+}
+
+static void AppendDataMutationRows(string &payload, const string &append_files_payload, const string &delete_files_payload,
+                                   const string &flushed_inline_payload,
+                                   const string &inline_file_delete_payload,
+                                   const string &dropped_data_files_payload) {
+	payload += append_files_payload;
+	payload += delete_files_payload;
+	payload += flushed_inline_payload;
+	payload += inline_file_delete_payload;
+	AppendDroppedDataFilesPayload(payload, dropped_data_files_payload);
+}
+
+static void AppendCommitInfoField(string &payload, const string &field_name, const Value &value) {
+	if (value.IsNull()) {
+		return;
+	}
+	auto text = value.DefaultCastAs(LogicalType::VARCHAR).GetValue<string>();
+	RejectRuntimeField(text, field_name.c_str());
+	payload += field_name;
+	payload += "\t";
+	payload += text;
+	payload += "\n";
+}
+
+static void AppendCommitInfoRows(string &payload, DuckLakeSnapshotCommit &commit_info) {
+	AppendCommitInfoField(payload, "commit_author", commit_info.author);
+	AppendCommitInfoField(payload, "commit_message", commit_info.commit_message);
+	AppendCommitInfoField(payload, "commit_extra_info", commit_info.commit_extra_info);
+}
+
+static string PendingDataMutationPayload(const string &append_files_payload, const string &delete_files_payload, const string &flushed_inline_payload,
+                                         const string &inline_file_delete_payload, const string &dropped_data_files_payload,
+                                         idx_t commit_snapshot_id, optional_idx read_snapshot_id,
+                                         DuckLakeSnapshotCommit &commit_info) {
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot_id);
+	if (read_snapshot_id.IsValid()) {
+		payload += StringUtil::Format("read_snapshot\t%d\n", read_snapshot_id.GetIndex());
+	}
+	AppendCommitInfoRows(payload, commit_info);
+	AppendDataMutationRows(payload, append_files_payload, delete_files_payload, flushed_inline_payload,
+	                       inline_file_delete_payload, dropped_data_files_payload);
+	return payload;
+}
+
+static bool HasPendingCommitAttemptMetadata(const string &add_columns_payload, const string &change_column_defaults_payload,
+                                            const string &change_column_types_payload,
+                                            const string &change_comments_payload,
+                                            const string &drop_columns_payload,
+                                            const string &rename_columns_payload,
+                                            const string &rename_tables_payload,
+                                            const string &change_partition_keys_payload,
+                                            const string &change_sort_keys_payload) {
+	return !add_columns_payload.empty() || !change_column_defaults_payload.empty() ||
+	       !change_column_types_payload.empty() || !change_comments_payload.empty() || !drop_columns_payload.empty() ||
+	       !rename_columns_payload.empty() || !rename_tables_payload.empty() || !change_partition_keys_payload.empty() ||
+	       !change_sort_keys_payload.empty();
+}
+
+static bool HasPendingDataMutationPayload(const string &append_files_payload, const string &delete_files_payload,
+                                          const string &flushed_inline_payload,
+                                          const string &inline_file_delete_payload,
+                                          const string &dropped_data_files_payload) {
