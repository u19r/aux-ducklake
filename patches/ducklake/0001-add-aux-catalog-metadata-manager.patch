+DELETE FROM {METADATA_CATALOG}.ducklake_column_mapping;
+)";
+	for (auto &mapping : mappings) {
+		query += StringUtil::Format("INSERT INTO {METADATA_CATALOG}.ducklake_column_mapping VALUES (%d, %d, %s);\n",
+		                            mapping.mapping_id.index, mapping.table_id.index, SQLString(mapping.map_type));
+		for (auto &column : mapping.map_columns) {
+			auto parent = column.parent_column.IsValid() ? std::to_string(column.parent_column.GetIndex()) : "NULL";
+			query += StringUtil::Format(
+			    "INSERT INTO {METADATA_CATALOG}.ducklake_name_mapping VALUES (%d, %d, %s, %d, %s, %s);\n",
+			    mapping.mapping_id.index, column.column_id, SQLString(column.source_name), column.target_field_id.index,
+			    parent, column.hive_partition ? "true" : "false");
+		}
+	}
+	SubstituteCatalogPlaceholders(query);
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		result->GetErrorObject().Throw("Failed to refresh aux column mapping mirror tables: ");
+	}
