+void AuxCatalogMetadataManager::RefreshPartitionInfoMirrorTable(DuckLakeSnapshot snapshot) {
+	EnsurePartitionInfoMirrorTable();
+	EnsureDataFileMirrorTable();
+	auto catalog = GetCatalogForSnapshot(snapshot);
+	string query = "DELETE FROM {METADATA_CATALOG}.ducklake_partition_info;\n";
+	for (auto &partition : catalog.partitions) {
+		if (!partition.id.IsValid()) {
+			continue;
+		}
+		query += StringUtil::Format(
+			    "INSERT INTO {METADATA_CATALOG}.ducklake_partition_info VALUES (%d, %d, NULL, NULL);\n",
+			    partition.id.GetIndex(), partition.table_id.index);
+	}
+	query += R"(
+INSERT INTO {METADATA_CATALOG}.ducklake_partition_info
+SELECT DISTINCT data.partition_id, data.table_id, NULL, NULL
+FROM {METADATA_CATALOG}.ducklake_data_file data
+WHERE data.partition_id IS NOT NULL
+  AND NOT EXISTS (
+      SELECT 1
+      FROM {METADATA_CATALOG}.ducklake_partition_info partition_info
+      WHERE partition_info.partition_id = data.partition_id
+        AND partition_info.table_id = data.table_id
+  );
+)";
+	SubstituteCatalogPlaceholders(query);
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		result->GetErrorObject().Throw("Failed to refresh aux partition info mirror table: ");
+	}
+}
