+void AuxCatalogMetadataManager::InitializeDuckLake(bool, DuckLakeEncryption encryption) {
+	auto data_path = StorePath(transaction.GetCatalog().DataPath());
+	RejectRuntimeField(data_path, "data path");
+	auto encrypted = encryption == DuckLakeEncryption::ENCRYPTED ? "true" : "false";
+	auto payload = StringUtil::Format("version=%s\ncreated_by=DuckDB %s\ndata_path=%s\nencrypted=%s\n", GetVersionString(),
+	                                  DuckDB::SourceID(), data_path, encrypted);
+	auto output = RuntimeExecute("InitializeDuckLake", payload);
+	std::fwrite(output.data(), 1, output.size(), stdout);
+}
