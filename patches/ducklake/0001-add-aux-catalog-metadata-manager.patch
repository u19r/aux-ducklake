diff --git a/src/metadata_manager/aux_catalog_catalog_snapshot.cpp b/src/metadata_manager/aux_catalog_catalog_snapshot.cpp
new file mode 100644
index 00000000..d37e6861
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_catalog_snapshot.cpp
@@ -0,0 +1,305 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "storage/ducklake_catalog.hpp"
+#include "storage/ducklake_transaction.hpp"
+#include <sstream>
+#include <unordered_map>
+
+namespace duckdb {
+
+static bool AddChildColumn(vector<DuckLakeColumnInfo> &columns, FieldIndex parent_id, DuckLakeColumnInfo &column_info) {
+	for (auto &column : columns) {
+		if (column.id == parent_id) {
+			column.children.push_back(std::move(column_info));
+			return true;
+		}
+		if (AddChildColumn(column.children, parent_id, column_info)) {
+			return true;
+		}
+	}
+	return false;
+}
+
+static vector<string> ParseAliases(const string &value) {
+	vector<string> aliases;
+	idx_t start = 0;
+	for (idx_t i = 0; i <= value.size(); i++) {
+		if (i == value.size() || value[i] == '\x1f') {
+			auto alias = value.substr(start, i - start);
+			if (!alias.empty()) {
+				aliases.push_back(std::move(alias));
+			}
+			start = i + 1;
+		}
+	}
+	return aliases;
+}
+
+using SnapshotFields = vector<string>;
+
+struct AuxCatalogSnapshotRows {
+	vector<SnapshotFields> schemas;
+	vector<SnapshotFields> tables;
+	vector<SnapshotFields> columns;
+	vector<SnapshotFields> views;
+	vector<SnapshotFields> macros;
+	vector<SnapshotFields> macro_impls;
+	vector<SnapshotFields> macro_params;
+	vector<SnapshotFields> inlined_tables;
+	vector<SnapshotFields> partitions;
+	vector<SnapshotFields> sorts;
+};
+
+static void AppendSnapshotRow(vector<SnapshotFields> &target, SnapshotFields fields, idx_t field_count,
+                              const char *row_name, const string &line) {
+	if (fields.size() != field_count) {
+		throw IOException("aux_catalog runtime returned invalid %s: %s", row_name, line);
+	}
+	target.push_back(std::move(fields));
+}
+
+static AuxCatalogSnapshotRows ParseCatalogSnapshotRows(const string &output) {
+	AuxCatalogSnapshotRows rows;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.empty()) {
+			continue;
+		}
+		auto &kind = fields[0];
+		if (kind == "schema") {
+			AppendSnapshotRow(rows.schemas, std::move(fields), 5, "schema row", line);
+		} else if (kind == "table") {
+			AppendSnapshotRow(rows.tables, std::move(fields), 7, "table row", line);
+		} else if (kind == "column") {
+			AppendSnapshotRow(rows.columns, std::move(fields), 11, "column row", line);
+		} else if (kind == "view") {
+			AppendSnapshotRow(rows.views, std::move(fields), 9, "view row", line);
+		} else if (kind == "macro") {
+			AppendSnapshotRow(rows.macros, std::move(fields), 4, "macro row", line);
+		} else if (kind == "macro_impl") {
+			AppendSnapshotRow(rows.macro_impls, std::move(fields), 6, "macro implementation row", line);
+		} else if (kind == "macro_param") {
+			AppendSnapshotRow(rows.macro_params, std::move(fields), 8, "macro parameter row", line);
+		} else if (kind == "inlined_table") {
+			AppendSnapshotRow(rows.inlined_tables, std::move(fields), 4, "inlined table row", line);
+		} else if (kind == "partition") {
+			AppendSnapshotRow(rows.partitions, std::move(fields), 6, "partition row", line);
+		} else if (kind == "sort") {
+			AppendSnapshotRow(rows.sorts, std::move(fields), 8, "sort row", line);
+		}
+	}
+	return rows;
+}
+
+static DuckLakeTableInfo &CatalogTableById(DuckLakeCatalogInfo &catalog,
+                                           const std::unordered_map<idx_t, idx_t> &table_offsets, TableIndex table_id,
+                                           const char *row_name) {
+	auto entry = table_offsets.find(table_id.index);
+	if (entry == table_offsets.end()) {
+		throw IOException("aux_catalog runtime returned %s for unknown table id %d", row_name, table_id.index);
+	}
+	return catalog.tables[entry->second];
+}
+
+static DuckLakeMacroInfo &CatalogMacroById(DuckLakeCatalogInfo &catalog,
+                                           const std::unordered_map<idx_t, idx_t> &macro_offsets, MacroIndex macro_id,
+                                           const char *row_name) {
+	auto entry = macro_offsets.find(macro_id.index);
+	if (entry == macro_offsets.end()) {
+		throw IOException("aux_catalog runtime returned %s for unknown macro id %d", row_name, macro_id.index);
+	}
+	return catalog.macros[entry->second];
+}
+
+DuckLakeCatalogInfo AuxCatalogMetadataManager::GetCatalogForSnapshot(DuckLakeSnapshot snapshot) {
+	auto output = RuntimeExecute("GetCatalogForSnapshot",
+	                             StringUtil::Format("snapshot_id=%d\nsnapshot_kind=ducklake\n", snapshot.snapshot_id));
+	auto &ducklake_catalog = transaction.GetCatalog();
+	DuckLakeCatalogInfo catalog;
+	DuckLakeSchemaInfo schema;
+	schema.id = SchemaIndex(0);
+	schema.uuid = transaction.GenerateUUID();
+	schema.name = "main";
+	schema.path = ducklake_catalog.DataPath() + "main" + ducklake_catalog.Separator();
+	catalog.schemas.push_back(std::move(schema));
+	auto rows = ParseCatalogSnapshotRows(output);
+	std::unordered_map<idx_t, idx_t> table_offsets;
+	std::unordered_map<idx_t, idx_t> macro_offsets;
+
+	for (auto &fields : rows.schemas) {
+		DuckLakeSchemaInfo schema;
+		schema.id = SchemaIndex(AuxCatalogParseIndex(fields[1], "schema id"));
+		schema.uuid = fields[2];
+		schema.name = fields[3];
+		schema.path = fields[4];
+		catalog.schemas.push_back(std::move(schema));
+	}
+
+	for (auto &fields : rows.tables) {
+		DuckLakeTableInfo table;
+		table.id = TableIndex(AuxCatalogParseIndex(fields[1], "table id"));
+		table.schema_id = SchemaIndex(AuxCatalogParseIndex(fields[2], "schema id"));
+		table.uuid = fields[3];
+		table.name = fields[4];
+		table.path = fields[5].empty() ? catalog.schemas[0].path : fields[5];
+		if (!fields[6].empty()) {
+			table.tags.push_back({"comment", fields[6]});
+		}
+		table_offsets[table.id.index] = catalog.tables.size();
+		catalog.tables.push_back(std::move(table));
+	}
+
+	for (auto &fields : rows.columns) {
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "column table id"));
+		auto &table_entry = CatalogTableById(catalog, table_offsets, table_id, "column");
+		DuckLakeColumnInfo column;
+		column.id = FieldIndex(AuxCatalogParseIndex(fields[2], "column id"));
+		column.name = fields[3];
+		column.type = fields[4];
+		column.nulls_allowed = fields[5] == "true";
+		if (fields[5] != "true" && fields[5] != "false") {
+			throw IOException("aux_catalog runtime returned invalid nulls_allowed value: %s", fields[5]);
+		}
+		if (!fields[7].empty()) {
+			column.tags.push_back({"comment", fields[7]});
+		}
+		if (!fields[8].empty()) {
+			column.initial_default = Value(fields[8]);
+		}
+		column.default_value = fields[9] == "NULL" ? Value() : Value(fields[9]);
+		column.default_value_type = fields[10].empty() ? "literal" : fields[10];
+		if (fields[6].empty()) {
+			table_entry.columns.push_back(std::move(column));
+		} else if (!AddChildColumn(table_entry.columns, FieldIndex(AuxCatalogParseIndex(fields[6], "parent column id")),
+		                           column)) {
+			throw IOException("aux_catalog runtime returned column %s before its parent", fields[3]);
+		}
+	}
+
+	for (auto &fields : rows.views) {
+		DuckLakeViewInfo view;
+		view.id = TableIndex(AuxCatalogParseIndex(fields[1], "view id"));
+		view.schema_id = SchemaIndex(AuxCatalogParseIndex(fields[2], "view schema id"));
+		view.uuid = fields[3];
+		view.name = fields[4];
+		view.dialect = fields[5];
+		view.sql = fields[6];
+		view.column_aliases = ParseAliases(fields[7]);
+		if (!fields[8].empty()) {
+			view.tags.push_back({"comment", fields[8]});
+		}
+		catalog.views.push_back(std::move(view));
+	}
+
+	for (auto &fields : rows.macros) {
+		DuckLakeMacroInfo macro;
+		macro.macro_id = MacroIndex(AuxCatalogParseIndex(fields[1], "macro id"));
+		macro.schema_id = SchemaIndex(AuxCatalogParseIndex(fields[2], "macro schema id"));
+		macro.macro_name = fields[3];
+		macro_offsets[macro.macro_id.index] = catalog.macros.size();
+		catalog.macros.push_back(std::move(macro));
+	}
+
+	for (auto &fields : rows.macro_impls) {
+		auto macro_id = MacroIndex(AuxCatalogParseIndex(fields[1], "macro implementation macro id"));
+		auto &macro_entry = CatalogMacroById(catalog, macro_offsets, macro_id, "implementation");
+		DuckLakeMacroImplementation implementation;
+		implementation.dialect = fields[3];
+		implementation.sql = fields[4];
+		implementation.type = fields[5];
+		macro_entry.implementations.push_back(std::move(implementation));
+	}
+
+	for (auto &fields : rows.macro_params) {
+		auto macro_id = MacroIndex(AuxCatalogParseIndex(fields[1], "macro parameter macro id"));
+		auto impl_id = AuxCatalogParseIndex(fields[2], "macro parameter implementation id");
+		auto &macro_entry = CatalogMacroById(catalog, macro_offsets, macro_id, "parameter");
+		if (impl_id >= macro_entry.implementations.size()) {
+			throw IOException("aux_catalog runtime returned parameter for unknown macro implementation %d", impl_id);
+		}
+		DuckLakeMacroParameters parameter;
+		parameter.parameter_name = fields[4];
+		parameter.parameter_type = fields[5];
+		parameter.default_value = fields[6] == "NULL" ? Value() : Value(fields[6]);
+		parameter.default_value_type = fields[7];
+		macro_entry.implementations[impl_id].parameters.push_back(std::move(parameter));
+	}
+
+	for (auto &fields : rows.inlined_tables) {
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "inlined table id"));
+		auto &table_entry = CatalogTableById(catalog, table_offsets, table_id, "inlined table");
+		DuckLakeInlinedTableInfo inlined_table;
+		inlined_table.table_name = fields[2];
+		inlined_table.schema_version = AuxCatalogParseIndex(fields[3], "inlined table schema version");
+		table_entry.inlined_data_tables.push_back(std::move(inlined_table));
+	}
+
+	std::unordered_map<idx_t, idx_t> partition_offsets;
+	for (auto &fields : rows.partitions) {
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "partition table id"));
+		auto partition_id = AuxCatalogParseIndex(fields[2], "partition id");
+		auto partition_offset = partition_offsets.find(table_id.index);
+		if (partition_offset == partition_offsets.end()) {
+			DuckLakePartitionInfo partition_info;
+			partition_info.id = partition_id;
+			partition_info.table_id = table_id;
+			partition_offsets[table_id.index] = catalog.partitions.size();
+			catalog.partitions.push_back(std::move(partition_info));
+		} else if (catalog.partitions[partition_offset->second].id != partition_id) {
+			throw IOException("aux_catalog runtime returned multiple partition ids for table id %d", table_id.index);
+		}
+		auto &partition_entry = catalog.partitions[partition_offsets[table_id.index]];
+		DuckLakePartitionFieldInfo field;
+		field.partition_key_index = AuxCatalogParseIndex(fields[3], "partition key index");
+		field.field_id = FieldIndex(AuxCatalogParseIndex(fields[4], "partition column id"));
+		field.transform = fields[5];
+		partition_entry.fields.push_back(std::move(field));
+	}
+
+	std::unordered_map<idx_t, idx_t> sort_offsets;
+	for (auto &fields : rows.sorts) {
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[1], "sort table id"));
+		auto sort_id = AuxCatalogParseIndex(fields[2], "sort id");
+		auto sort_offset = sort_offsets.find(table_id.index);
+		if (sort_offset == sort_offsets.end()) {
+			DuckLakeSortInfo sort_info;
+			sort_info.id = sort_id;
+			sort_info.table_id = table_id;
+			sort_offsets[table_id.index] = catalog.sorts.size();
+			catalog.sorts.push_back(std::move(sort_info));
+		} else if (catalog.sorts[sort_offset->second].id != sort_id) {
+			throw IOException("aux_catalog runtime returned multiple sort ids for table id %d", table_id.index);
+		}
+		auto &sort_entry = catalog.sorts[sort_offsets[table_id.index]];
+		DuckLakeSortFieldInfo field;
+		field.sort_key_index = AuxCatalogParseIndex(fields[3], "sort key index");
+		field.expression = fields[4];
+		field.dialect = fields[5];
+		if (StringUtil::CIEquals(fields[6], "DESC")) {
+			field.sort_direction = OrderType::DESCENDING;
+		} else if (StringUtil::CIEquals(fields[6], "ASC")) {
+			field.sort_direction = OrderType::ASCENDING;
+		} else {
+			throw IOException("aux_catalog runtime returned invalid sort direction: %s", fields[6]);
+		}
+		if (StringUtil::CIEquals(fields[7], "NULLS_FIRST")) {
+			field.null_order = OrderByNullType::NULLS_FIRST;
+		} else if (StringUtil::CIEquals(fields[7], "NULLS_LAST")) {
+			field.null_order = OrderByNullType::NULLS_LAST;
+		} else {
+			throw IOException("aux_catalog runtime returned invalid sort null order: %s", fields[7]);
+		}
+		sort_entry.fields.push_back(std::move(field));
+	}
+	return catalog;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_change_feed.cpp b/src/metadata_manager/aux_catalog_change_feed.cpp
new file mode 100644
index 00000000..fb34c187
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_change_feed.cpp
@@ -0,0 +1,160 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "storage/ducklake_table_entry.hpp"
+#include <sstream>
+#include <unordered_map>
+
+namespace duckdb {
+
+static DuckLakeFileData ParseOptionalFileData(const vector<string> &fields, idx_t path_index, idx_t size_index,
+                                              const char *field_name) {
+	DuckLakeFileData file;
+	if (fields[path_index].empty()) {
+		return file;
+	}
+	file.path = fields[path_index];
+	file.file_size_bytes = AuxCatalogParseIndex(fields[size_index], field_name);
+	return file;
+}
+
+static unordered_map<idx_t, idx_t> ParseInlineFileDeletionMap(const string &value) {
+	unordered_map<idx_t, idx_t> result;
+	idx_t start = 0;
+	for (idx_t i = 0; i <= value.size(); i++) {
+		if (i != value.size() && value[i] != ',') {
+			continue;
+		}
+		if (i == start) {
+			start = i + 1;
+			continue;
+		}
+		auto part = value.substr(start, i - start);
+		auto separator = part.find(':');
+		if (separator == string::npos) {
+			throw IOException("aux_catalog runtime returned invalid inline file deletion '%s'", part);
+		}
+		auto row_id = AuxCatalogParseIndex(part.substr(0, separator), "inline file deletion row id");
+		auto snapshot_id = AuxCatalogParseIndex(part.substr(separator + 1), "inline file deletion snapshot id");
+		result[row_id] = snapshot_id;
+		start = i + 1;
+	}
+	return result;
+}
+
+vector<DuckLakeFileListEntry> AuxCatalogMetadataManager::GetTableInsertions(DuckLakeTableEntry &table,
+	DuckLakeSnapshot start_snapshot,
+	DuckLakeSnapshot end_snapshot) {
+	auto output = RuntimeExecute(
+	    "ListDataFileChanges",
+	    StringUtil::Format("table_id=%d\nstart_snapshot_id=%d\nend_snapshot_id=%d\n", table.GetTableId().index,
+	                       start_snapshot.snapshot_id, end_snapshot.snapshot_id));
+	vector<DuckLakeFileListEntry> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("change_file\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 9 && fields.size() != 10 && fields.size() != 11 && fields.size() != 13) {
+			throw IOException("aux_catalog runtime returned invalid change file row: %s", line);
+		}
+		if (fields[1] != "added") {
+			continue;
+		}
+		auto snapshot_id = AuxCatalogParseIndex(fields[2], "change snapshot id");
+		auto data_file_id = AuxCatalogParseIndex(fields[3], "change data file id");
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[4], "change table id"));
+		if (table_id != table.GetTableId()) {
+			throw IOException("aux_catalog runtime returned change for table %d while reading table %d", table_id.index,
+			                  table.GetTableId().index);
+		}
+		DuckLakeFileListEntry entry;
+		entry.file_id = DataFileIndex(data_file_id);
+		entry.data_file_id = data_file_id;
+		entry.snapshot_id = snapshot_id;
+		entry.file.path = fields[5];
+		entry.file.file_size_bytes = AuxCatalogParseIndex(fields[7], "change file size bytes");
+		entry.row_id_start = AuxCatalogParseIndex(fields[8], "change row id start");
+		if (fields.size() >= 10 && !fields[9].empty()) {
+			entry.mapping_id = MappingIndex(AuxCatalogParseIndex(fields[9], "change file mapping id"));
+		}
+		if (fields.size() == 13) {
+			if (!fields[11].empty()) {
+				entry.snapshot_filter_min = AuxCatalogParseIndex(fields[11], "change snapshot filter min");
+			}
+			if (!fields[12].empty()) {
+				entry.snapshot_filter_max = AuxCatalogParseIndex(fields[12], "change snapshot filter max");
+			}
+		}
+		files.push_back(std::move(entry));
+	}
+	return files;
+}
+
+vector<DuckLakeDeleteScanEntry> AuxCatalogMetadataManager::GetTableDeletions(DuckLakeTableEntry &table,
+	DuckLakeSnapshot start_snapshot,
+	DuckLakeSnapshot end_snapshot) {
+	auto output = RuntimeExecute(
+	    "ListTableDeletions",
+	    StringUtil::Format("table_id=%d\nstart_snapshot_id=%d\nend_snapshot_id=%d\n", table.GetTableId().index,
+	                       start_snapshot.snapshot_id, end_snapshot.snapshot_id));
+	vector<DuckLakeDeleteScanEntry> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("delete_scan\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 17 && fields.size() != 18 && fields.size() != 19) {
+			throw IOException("aux_catalog runtime returned invalid delete scan row: %s", line);
+		}
+		auto kind = fields[1];
+		if (kind != "partial" && kind != "full") {
+			throw IOException("aux_catalog runtime returned invalid delete scan kind: %s", fields[1]);
+		}
+		auto snapshot_id = AuxCatalogParseIndex(fields[2], "delete scan snapshot id");
+		auto data_file_id = AuxCatalogParseIndex(fields[3], "delete scan data file id");
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[4], "delete scan table id"));
+		if (table_id != table.GetTableId()) {
+			throw IOException("aux_catalog runtime returned deletion for table %d while reading table %d",
+			                  table_id.index, table.GetTableId().index);
+		}
+
+		DuckLakeDeleteScanEntry entry;
+		entry.file_id = DataFileIndex(data_file_id);
+		entry.file.path = fields[5];
+		entry.row_count = AuxCatalogParseIndex(fields[6], "delete scan row count");
+		entry.file.file_size_bytes = AuxCatalogParseIndex(fields[7], "delete scan file size bytes");
+		entry.row_id_start = AuxCatalogParseIndex(fields[8], "delete scan row id start");
+		idx_t delete_offset = 9;
+		if (fields.size() >= 18) {
+			if (!fields[9].empty()) {
+				entry.mapping_id = MappingIndex(AuxCatalogParseIndex(fields[9], "delete scan mapping id"));
+			}
+			delete_offset = 10;
+		}
+		entry.delete_file = ParseOptionalFileData(fields, delete_offset + 1, delete_offset + 3, "delete file size bytes");
+		entry.previous_delete_file =
+		    ParseOptionalFileData(fields, delete_offset + 5, delete_offset + 7, "previous delete file size bytes");
+		entry.snapshot_id = snapshot_id;
+		if (kind == "partial") {
+			entry.start_snapshot = snapshot_id;
+			entry.end_snapshot = snapshot_id;
+		}
+		if (fields.size() == 19 && !fields[18].empty()) {
+			entry.inlined_file_deletions = ParseInlineFileDeletionMap(fields[18]);
+			entry.start_snapshot = start_snapshot.snapshot_id;
+			entry.end_snapshot = end_snapshot.snapshot_id;
+		}
+		files.push_back(std::move(entry));
+	}
+	return files;
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_cleanup.cpp b/src/metadata_manager/aux_catalog_cleanup.cpp
new file mode 100644
index 00000000..48d5b7be
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_cleanup.cpp
@@ -0,0 +1,219 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "duckdb/main/appender.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "storage/ducklake_transaction.hpp"
+#include <sstream>
+
+namespace duckdb {
+
+namespace {
+
+struct AuxCatalogCleanupFileRow {
+	string kind;
+	DataFileIndex data_file_id;
+	TableIndex table_id;
+	string path;
+};
+
+struct AuxCatalogKnownFileRow {
+	string kind;
+	DataFileIndex id;
+	TableIndex table_id;
+	string path;
+};
+
+static vector<AuxCatalogCleanupFileRow> ParseCleanupRows(const string &output) {
+	vector<AuxCatalogCleanupFileRow> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("cleanup_file\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 5) {
+			throw IOException("aux_catalog runtime returned invalid cleanup file row: %s", line);
+		}
+		AuxCatalogCleanupFileRow file;
+		file.kind = fields[1];
+		if (file.kind != "data" && file.kind != "delete") {
+			throw IOException("aux_catalog runtime returned invalid cleanup file kind: %s", file.kind);
+		}
+		file.data_file_id = DataFileIndex(AuxCatalogParseIndex(fields[2], "cleanup file id"));
+		file.table_id = TableIndex(AuxCatalogParseIndex(fields[3], "cleanup table id"));
+		file.path = fields[4];
+		files.push_back(std::move(file));
+	}
+	return files;
+}
+
+static vector<AuxCatalogKnownFileRow> ParseKnownFileRows(const string &output) {
+	vector<AuxCatalogKnownFileRow> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("known_file\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 5) {
+			throw IOException("aux_catalog runtime returned invalid known cleanup file row: %s", line);
+		}
+		AuxCatalogKnownFileRow file;
+		file.kind = fields[1];
+		if (file.kind != "data" && file.kind != "delete") {
+			throw IOException("aux_catalog runtime returned invalid known cleanup file kind: %s", file.kind);
+		}
+		file.id = DataFileIndex(AuxCatalogParseIndex(fields[2], "known cleanup file id"));
+		file.table_id = TableIndex(AuxCatalogParseIndex(fields[3], "known cleanup table id"));
+		file.path = fields[4];
+		files.push_back(std::move(file));
+	}
+	return files;
+}
+
+static string CleanupIdentity(DataFileIndex id, const string &path) {
+	return std::to_string(id.index) + "\t" + path;
+}
+
+static string JoinCleanupFileTokens(const vector<DuckLakeFileForCleanup> &files,
+                                    const unordered_map<string, string> &tokens_by_identity) {
+	string result;
+	for (auto &file : files) {
+		auto entry = tokens_by_identity.find(CleanupIdentity(file.id, file.path));
+		if (entry == tokens_by_identity.end()) {
+			throw IOException("aux_catalog cleanup lost object kind for file id %s path: %s",
+			                  std::to_string(file.id.index), file.path);
+		}
+		if (!result.empty()) {
+			result += ",";
+		}
+		result += entry->second;
+	}
+	return result;
+}
+
+static string CleanupRuntimePayload(const string &tokens) {
+	string payload;
+	std::stringstream stream(tokens);
+	string token;
+	while (std::getline(stream, token, ',')) {
+		if (token.empty()) {
+			continue;
+		}
+		auto separator = token.find(':');
+		if (separator == string::npos) {
+			throw IOException("aux_catalog cleanup token missing object kind: %s", token);
+		}
+		payload += "cleanup_file\t" + token.substr(0, separator) + "\t" + token.substr(separator + 1) + "\n";
+	}
+	return payload;
+}
+
+static string ListOldFilesRuntimePayload(const string &filter) {
+	return StringUtil::Format("cleanup_all=%s\nfilter=%s\n", filter.empty() ? "true" : "false", filter);
+}
+
+static string CleanupPathIdentity(string path) {
+	return StringUtil::Replace(path, "\\", "/");
+}
+
+} // namespace
+
+vector<DuckLakeFileForCleanup> AuxCatalogMetadataManager::GetOrphanFilesForCleanup(const string &filter,
+                                                                                   const string &) {
+	auto output = RuntimeExecute("ListKnownFilesForCleanup", string());
+	auto rows = ParseKnownFileRows(output);
+	const string temp_table = "__aux_catalog_known_cleanup_files";
+	auto create_temp_query = StringUtil::Format("CREATE OR REPLACE TEMPORARY TABLE %s(full_path VARCHAR)", temp_table);
+	auto create_temp_res = transaction.ExecuteRaw(create_temp_query);
+	if (create_temp_res->HasError()) {
+		create_temp_res->GetErrorObject().Throw("Failed to create aux_catalog temporary file list for cleanup: ");
+	}
+
+	auto drop_temp_table = [&]() {
+		try {
+			transaction.ExecuteRaw(StringUtil::Format("DROP TABLE IF EXISTS %s", temp_table));
+		} catch (...) {
+		}
+	};
+
+	try {
+		Appender appender(transaction.GetConnection(), Identifier(temp_table));
+		for (auto &known_file : rows) {
+			auto path = CleanupPathIdentity(known_file.path);
+			appender.AppendRow(path.c_str());
+		}
+		appender.Close();
+
+		auto query = StringUtil::Format(R"(SELECT filename
+FROM read_blob({DATA_PATH} || '**') files
+WHERE suffix(filename, '.parquet')
+AND NOT EXISTS (
+	SELECT 1 FROM %s known_files WHERE known_files.full_path = REPLACE(files.filename, '\', '/')
+)
+%s)",
+		                                  temp_table, filter);
+		SubstituteCatalogPlaceholders(query);
+		auto res = transaction.ExecuteRaw(query);
+		if (res->HasError()) {
+			res->GetErrorObject().Throw("Failed to get aux_catalog orphan files scheduled for deletion: ");
+		}
+
+		vector<DuckLakeFileForCleanup> result;
+		for (auto &row : *res) {
+			DuckLakeFileForCleanup info;
+			info.path = row.GetValue<string>(0);
+			result.push_back(std::move(info));
+		}
+		drop_temp_table();
+		return result;
+	} catch (...) {
+		drop_temp_table();
+		throw;
+	}
+}
+
+vector<DuckLakeFileForCleanup> AuxCatalogMetadataManager::GetFilesForCleanup(const string &filter, CleanupType type,
+                                                                             const string &separator) {
+	if (type == CleanupType::ORPHANED_FILES) {
+		return GetOrphanFilesForCleanup(filter, separator);
+	}
+	if (type != CleanupType::OLD_FILES) {
+		throw NotImplementedException("aux_catalog file cleanup type is not implemented yet");
+	}
+	auto output = RuntimeExecute("ListOldFilesForCleanup", ListOldFilesRuntimePayload(filter));
+	auto rows = ParseCleanupRows(output);
+	cleanup_file_tokens_by_identity.clear();
+	vector<DuckLakeFileForCleanup> files;
+	files.reserve(rows.size());
+	for (auto &row : rows) {
+		DuckLakeFileForCleanup file;
+		file.id = row.data_file_id;
+		file.path = row.path;
+		file.time = timestamp_tz_t(0);
+		cleanup_file_tokens_by_identity[CleanupIdentity(file.id, file.path)] =
+		    row.kind + ":" + std::to_string(row.data_file_id.index);
+		files.push_back(std::move(file));
+	}
+	return files;
+}
+
+void AuxCatalogMetadataManager::RemoveFilesScheduledForCleanup(
+    const vector<DuckLakeFileForCleanup> &cleaned_up_files) {
+	if (cleaned_up_files.empty()) {
+		return;
+	}
+	auto ids = JoinCleanupFileTokens(cleaned_up_files, cleanup_file_tokens_by_identity);
+	RuntimeExecute("RemoveCleanupFiles", CleanupRuntimePayload(ids));
+	auto snapshot = GetSnapshot();
+	if (snapshot) {
+		RefreshScheduledCleanupMirrorTable();
+	}
+}
+
+} // namespace duckdb
diff --git a/src/metadata_manager/aux_catalog_column_mappings.cpp b/src/metadata_manager/aux_catalog_column_mappings.cpp
new file mode 100644
index 00000000..6d0f7e0c
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_column_mappings.cpp
@@ -0,0 +1,463 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/sql_identifier.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "storage/ducklake_catalog.hpp"
+#include "storage/ducklake_transaction.hpp"
+#include <sstream>
+
+namespace duckdb {
+
+static string SqlUnquote(const string &value) {
+	auto trimmed = value;
+	StringUtil::Trim(trimmed);
+	if (trimmed == "NULL") {
+		return string();
+	}
+	if (trimmed.size() < 2 || trimmed.front() != '\'' || trimmed.back() != '\'') {
+		return trimmed;
+	}
+	string out;
+	for (idx_t i = 1; i + 1 < trimmed.size(); i++) {
+		if (trimmed[i] == '\'' && i + 2 < trimmed.size() && trimmed[i + 1] == '\'') {
+			out.push_back('\'');
+			i++;
+		} else {
+			out.push_back(trimmed[i]);
+		}
+	}
+	return out;
+}
+
+static vector<string> ParseSqlTupleValues(const string &tuple) {
+	vector<string> fields;
+	string current;
+	bool in_string = false;
+	for (idx_t i = 0; i < tuple.size(); i++) {
+		auto c = tuple[i];
+		if (c == '\'') {
+			current.push_back(c);
+			if (in_string && i + 1 < tuple.size() && tuple[i + 1] == '\'') {
+				current.push_back(tuple[++i]);
+				continue;
+			}
+			in_string = !in_string;
+			continue;
+		}
+		if (c == ',' && !in_string) {
+			StringUtil::Trim(current);
+			fields.push_back(current);
+			current.clear();
+			continue;
+		}
+		current.push_back(c);
+	}
+	StringUtil::Trim(current);
+	fields.push_back(current);
+	return fields;
+}
+
+static vector<vector<string>> ParseSqlTuples(const string &values) {
+	vector<vector<string>> rows;
+	bool in_string = false;
+	bool in_tuple = false;
+	idx_t tuple_start = 0;
+	for (idx_t i = 0; i < values.size(); i++) {
+		auto c = values[i];
+		if (c == '\'') {
+			if (in_string && i + 1 < values.size() && values[i + 1] == '\'') {
+				i++;
+				continue;
+			}
+			in_string = !in_string;
+			continue;
+		}
+		if (in_string) {
+			continue;
+		}
+		if (c == '(') {
+			in_tuple = true;
+			tuple_start = i + 1;
+			continue;
+		}
+		if (c == ')' && in_tuple) {
+			rows.push_back(ParseSqlTupleValues(values.substr(tuple_start, i - tuple_start)));
+			in_tuple = false;
+		}
+	}
+	return rows;
+}
+
+static string StatementValues(const string &query, const string &table_name) {
+	auto table_pos = query.find(table_name);
+	if (table_pos == string::npos) {
+		return string();
+	}
+	auto values_pos = query.find("VALUES", table_pos);
+	if (values_pos == string::npos) {
+		return string();
+	}
+	auto statement_end = query.find(';', values_pos);
+	if (statement_end == string::npos) {
+		statement_end = query.size();
+	}
+	return query.substr(values_pos + 6, statement_end - values_pos - 6);
+}
+
+static void RejectMappingField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static string ColumnMappingRuntimePayload(const string &query) {
+	auto mapping_values = StatementValues(query, "ducklake_column_mapping");
+	auto name_values = StatementValues(query, "ducklake_name_mapping");
+	if (mapping_values.empty() && name_values.empty()) {
+		return string();
+	}
+	if (mapping_values.empty() || name_values.empty()) {
+		throw NotImplementedException("aux_catalog column mapping batches must include mapping and name mapping rows");
+	}
+
+	string payload;
+	for (auto &fields : ParseSqlTuples(mapping_values)) {
+		if (fields.size() != 3) {
+			throw IOException("aux_catalog invalid ducklake_column_mapping insert tuple");
+		}
+		auto mapping_type = SqlUnquote(fields[2]);
+		RejectMappingField(mapping_type, "column mapping types");
+		payload += StringUtil::Format("mapping\t%d\t%d\t%s\n", AuxCatalogParseIndex(fields[0], "mapping id"),
+		                              AuxCatalogParseIndex(fields[1], "mapping table id"), mapping_type);
+	}
+	for (auto &fields : ParseSqlTuples(name_values)) {
+		if (fields.size() != 6) {
+			throw IOException("aux_catalog invalid ducklake_name_mapping insert tuple");
+		}
+		auto source_name = SqlUnquote(fields[2]);
+		RejectMappingField(source_name, "column mapping source names");
+		payload += StringUtil::Format("mapping_column\t%d\t%d\t%s\t%d\t%s\t%s\n",
+		                              AuxCatalogParseIndex(fields[0], "name mapping id"),
+		                              AuxCatalogParseIndex(fields[1], "name mapping column id"), source_name,
+		                              AuxCatalogParseIndex(fields[3], "name mapping target field id"),
+		                              StringUtil::CIEquals(fields[4], "NULL") ? string() : fields[4],
+		                              StringUtil::CIEquals(fields[5], "true") ? "true" : "false");
+	}
+	return payload;
+}
+
+static vector<DuckLakeColumnMappingInfo> ParseColumnMappingsOutput(const string &output) {
+	vector<DuckLakeColumnMappingInfo> mappings;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty()) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields[0] == "mapping") {
+			if (fields.size() != 4) {
+				throw IOException("aux_catalog runtime returned invalid mapping row: %s", line);
+			}
+			DuckLakeColumnMappingInfo mapping;
+			mapping.mapping_id = MappingIndex(AuxCatalogParseIndex(fields[1], "mapping id"));
+			mapping.table_id = TableIndex(AuxCatalogParseIndex(fields[2], "mapping table id"));
+			mapping.map_type = fields[3];
+			mappings.push_back(std::move(mapping));
+			continue;
+		}
+		if (fields[0] == "mapping_column") {
+			if (fields.size() != 7 || mappings.empty()) {
+				throw IOException("aux_catalog runtime returned invalid mapping column row: %s", line);
+			}
+			auto mapping_id = AuxCatalogParseIndex(fields[1], "mapping column mapping id");
+			if (mappings.back().mapping_id.index != mapping_id) {
+				throw IOException("aux_catalog runtime returned out-of-order mapping column for mapping %d", mapping_id);
+			}
+			DuckLakeNameMapColumnInfo column;
+			column.column_id = AuxCatalogParseIndex(fields[2], "mapping column id");
+			column.source_name = fields[3];
+			column.target_field_id = FieldIndex(AuxCatalogParseIndex(fields[4], "mapping target field id"));
+			column.parent_column = AuxCatalogParseOptionalIndex(fields[5], "mapping parent column");
+			column.hive_partition = AuxCatalogParseBool(fields[6], "mapping partition flag");
+			mappings.back().map_columns.push_back(std::move(column));
+		}
+	}
+	return mappings;
+}
+
+bool AuxCatalogMetadataManager::CommitColumnMappingSql(string &query) {
+	auto payload = ColumnMappingRuntimePayload(query);
+	if (payload.empty()) {
+		return false;
+	}
+	RuntimeExecute("CommitColumnMappings", payload);
+	RefreshColumnMappingMirrorTables();
+	return true;
+}
+
+vector<DuckLakeColumnMappingInfo> AuxCatalogMetadataManager::GetColumnMappings(optional_idx start_from) {
+	string payload;
+	if (start_from.IsValid()) {
+		payload = StringUtil::Format("start_from=%d\n", start_from.GetIndex());
+	}
+	auto output = RuntimeExecute("ListColumnMappings", payload);
+	return ParseColumnMappingsOutput(output);
+}
