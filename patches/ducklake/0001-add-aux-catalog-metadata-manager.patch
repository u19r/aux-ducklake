+bool AuxCatalogMetadataManager::TryAddDeleteFiles(DuckLakeSnapshot &,
+                                                  const vector<DuckLakeDeleteFileInfo> &new_delete_files,
+                                                  const vector<DuckLakeTableInfo> &new_tables,
+                                                  vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	if (new_delete_files.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &file : new_delete_files) {
+		auto path = GetRelativePath(file.table_id, file.path, new_tables, new_schemas_result);
+		AppendDeleteFilePayload(payload, file, FromRelativePath(file.table_id, path));
+		pending_delete_file_ids_payload += StringUtil::Format("delete_file_id\t%d\n", file.id.index);
+	}
+	pending_delete_files_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropDataFiles(DuckLakeSnapshot &, const set<DataFileIndex> &dropped_files) {
+	if (dropped_files.empty()) {
+		return false;
+	}
+	for (auto &file_id : dropped_files) {
+		pending_dropped_data_files_payload += std::to_string(file_id.index) + "\n";
+	}
+	pending_metadata_batch = true;
+	return true;
