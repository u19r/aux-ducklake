+uint64_t AuxCatalogMetadataManager::RuntimeCatalogId() {
+	if (runtime_catalog_id != 0) {
+		return runtime_catalog_id;
+	}
+	auto output = AuxCatalogRuntimeBridge::Execute("ResolveCatalogId", RuntimeAttachPayload(), 1);
+	runtime_catalog_id = RequireRuntimeUInt64(output, "runtime_catalog_id");
+	return runtime_catalog_id;
+}
+
+string AuxCatalogMetadataManager::RuntimeExecute(const string &operation, const string &payload) {
+	return AuxCatalogRuntimeBridge::Execute(operation, payload, RuntimeCatalogId());
+}
+
+string AuxCatalogMetadataManager::RuntimeAttachPayload() {
+	auto &ducklake_catalog = transaction.GetCatalog();
+	auto metadata_path = ducklake_catalog.MetadataPath();
+	auto metadata_database = ducklake_catalog.MetadataDatabaseName();
+	auto metadata_schema = ducklake_catalog.MetadataSchemaName();
+	RejectRuntimeField(metadata_path, "metadata path");
+	RejectRuntimeField(metadata_database, "metadata database");
+	RejectRuntimeField(metadata_schema, "metadata schema");
+	string payload = "metadata_path=" + metadata_path + "\nmetadata_database=" + metadata_database +
+	                 "\nmetadata_schema=" + metadata_schema + "\n";
+	auto catalog_identity = std::getenv("AUX_DUCKLAKE_RUNTIME_CATALOG_IDENTITY");
+	if (catalog_identity && catalog_identity[0] != '\0') {
+		string identity = catalog_identity;
+		RejectRuntimeField(identity, "runtime catalog identity");
+		payload += "catalog_identity=" + identity + "\n";
+	}
+	return payload;
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::AttachMetadata(const string &attach_query) {
+	auto output = AuxCatalogRuntimeBridge::Execute("AttachMetadata", RuntimeAttachPayload(), RuntimeCatalogId());
+	runtime_catalog_id = RequireRuntimeUInt64(output, "runtime_catalog_id");
+	std::fwrite(output.data(), 1, output.size(), stdout);
+	auto query = attach_query;
+	SubstituteCatalogPlaceholders(query);
+	query = StringUtil::Replace(query, "TYPE 'aux_catalog'", "TYPE 'duckdb'");
+	query = StringUtil::Replace(query, "TYPE aux_catalog", "TYPE duckdb");
+	query = StringUtil::Replace(query, "aux_catalog", "duckdb");
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		return result;
+	}
+	return result;
+}
+
+bool AuxCatalogMetadataManager::MetadataExists() {
+	// DuckLake resolves the implicit metadata schema after AttachMetadata returns.
+	// Create the SQL mirrors here so their qualified names use that resolved schema.
+	EnsureCatalogObjectMirrorTables();
+	EnsureColumnMappingMirrorTables();
+	EnsureDataFileMirrorTable();
+	EnsureDeleteFileMirrorTable();
+	EnsureScheduledCleanupMirrorTable();
+	EnsurePartitionValueMirrorTable();
+	EnsureFileColumnStatsMirrorTable();
+	EnsureTableColumnStatsMirrorTable();
+	auto output = RuntimeExecute("MetadataExists", string());
+	auto value = AuxCatalogRequireValue(output, "metadata_exists");
+	if (value == "true") {
+		return true;
+	}
+	if (value == "false") {
+		return false;
+	}
+	throw IOException("aux_catalog runtime returned invalid metadata_exists value: %s", value);
+}
