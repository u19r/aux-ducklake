+idx_t AuxCatalogMetadataManager::GetNetDataFileRowCount(TableIndex table_id, DuckLakeSnapshot snapshot) {
+	table_id = RemapCreatedTableId(table_id);
+	auto rows = ParseFileRows(RunListFilesForTable(table_id, snapshot), table_id);
+	idx_t count = 0;
+	for (auto &row : rows) {
+		count += row.row_count;
+		if (HasDeleteFile(row)) {
+			count -= MinValue(row.delete_count, count);
+		}
+		count -= MinValue<idx_t>(row.inlined_file_deletions.size(), count);
+	}
+	return count;
+}
