diff --git a/src/metadata_manager/aux_catalog_compaction.cpp b/src/metadata_manager/aux_catalog_compaction.cpp
new file mode 100644
index 00000000..048411fd
--- /dev/null
+++ b/src/metadata_manager/aux_catalog_compaction.cpp
@@ -0,0 +1,382 @@
+#include "metadata_manager/aux_catalog_metadata_manager.hpp"
+#include "metadata_manager/aux_catalog_tabular_payload.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/string_util.hpp"
+#include "metadata_manager/aux_catalog_runtime_bridge.hpp"
+#include "storage/ducklake_table_entry.hpp"
+#include <algorithm>
+#include <map>
+#include <set>
+#include <sstream>
+
+namespace duckdb {
+
+namespace {
+
+struct AuxCatalogFileRow {
+	DataFileIndex data_file_id;
+	TableIndex table_id;
+	string path;
+	idx_t row_count = 0;
+	idx_t file_size_bytes = 0;
+	optional_idx row_id_start;
+	MappingIndex mapping_id;
+	optional_idx begin_snapshot;
+	optional_idx max_partial_snapshot;
+	optional_idx schema_version;
+	string data_encryption_key;
+	vector<Value> partition_values;
+	bool has_delete_file = false;
+	DataFileIndex delete_file_id;
+	string delete_path;
+	idx_t delete_count = 0;
+	idx_t delete_file_size_bytes = 0;
+	idx_t delete_begin_snapshot = 0;
+	string delete_encryption_key;
+	set<idx_t> inlined_file_deletions;
+};
+
+static bool IsCompactionFileRowFieldCount(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {12, 13, 14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool CompactionFileRowHasMapping(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool CompactionFileRowHasInlineDeletions(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {13, 14, 16, 17, 18, 19, 20, 22});
+}
+
+static bool CompactionFileRowHasSnapshotBounds(idx_t count) {
+	return AuxCatalogFieldCountIs(count, {16, 17, 18, 19, 20, 22});
+}
+
+static set<idx_t> ParseInlinedFileDeletions(const string &value) {
+	set<idx_t> rows;
+	if (value.empty()) {
+		return rows;
+	}
+	idx_t start = 0;
+	for (idx_t i = 0; i <= value.size(); i++) {
+		if (i == value.size() || value[i] == ',') {
+			rows.insert(AuxCatalogParseIndex(value.substr(start, i - start), "inline file deletion row id"));
+			start = i + 1;
+		}
+	}
+	return rows;
+}
+
+static vector<AuxCatalogFileRow> ParseFileRows(const string &output, TableIndex expected_table_id) {
+	vector<AuxCatalogFileRow> files;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("file\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (!IsCompactionFileRowFieldCount(fields.size())) {
+			throw IOException("aux_catalog runtime returned invalid compaction file row: %s", line);
+		}
+		AuxCatalogFileRow file;
+		file.data_file_id = DataFileIndex(AuxCatalogParseIndex(fields[1], "data file id"));
+		file.table_id = TableIndex(AuxCatalogParseIndex(fields[2], "file table id"));
+		if (file.table_id != expected_table_id) {
+			throw IOException("aux_catalog runtime returned file for table %d while compacting table %d",
+			                  file.table_id.index, expected_table_id.index);
+		}
+		file.path = fields[3];
+		file.row_count = AuxCatalogParseIndex(fields[4], "file record count");
+		file.file_size_bytes = AuxCatalogParseIndex(fields[5], "file size bytes");
+		if (!fields[6].empty()) {
+			file.row_id_start = AuxCatalogParseIndex(fields[6], "row id start");
+		}
+		idx_t delete_offset = 7;
+		idx_t inline_offset = 12;
+		if (CompactionFileRowHasMapping(fields.size())) {
+			if (!fields[7].empty()) {
+				file.mapping_id = MappingIndex(AuxCatalogParseIndex(fields[7], "mapping id"));
+			}
+			delete_offset = 8;
+			inline_offset = 13;
+		}
+		file.has_delete_file = !fields[delete_offset].empty() && !fields[delete_offset + 2].empty();
+		if (file.has_delete_file) {
+			file.delete_file_id = DataFileIndex(AuxCatalogParseIndex(fields[delete_offset], "delete file id"));
+			file.delete_path = fields[delete_offset + 1];
+			file.delete_count = AuxCatalogParseIndex(fields[delete_offset + 2], "delete count");
+			file.delete_file_size_bytes = AuxCatalogParseIndex(fields[delete_offset + 3], "delete file size bytes");
+			file.delete_begin_snapshot = AuxCatalogParseIndex(fields[delete_offset + 4], "delete begin snapshot");
+		}
+		if (CompactionFileRowHasInlineDeletions(fields.size())) {
+			file.inlined_file_deletions = ParseInlinedFileDeletions(fields[inline_offset]);
+		}
+		if (CompactionFileRowHasSnapshotBounds(fields.size())) {
+			if (!fields[14].empty()) {
+				file.begin_snapshot = AuxCatalogParseIndex(fields[14], "data file begin snapshot");
+			}
+			if (!fields[15].empty()) {
+				file.max_partial_snapshot = AuxCatalogParseIndex(fields[15], "data file partial max snapshot");
+			}
+		}
+		if (fields.size() >= 18 && !fields[17].empty()) {
+			file.schema_version = AuxCatalogParseIndex(fields[17], "data file schema version");
+		}
+		if (fields.size() == 22) {
+			file.data_encryption_key = AuxCatalogDecodeEncryptionKey(fields[20]);
+			file.delete_encryption_key = AuxCatalogDecodeEncryptionKey(fields[21]);
+		}
+		files.push_back(std::move(file));
+	}
+	return files;
+}
+
+static map<idx_t, vector<Value>> ParsePartitionValueRows(const string &output, TableIndex expected_table_id) {
+	map<idx_t, vector<Value>> partition_values;
+	map<idx_t, vector<std::pair<idx_t, Value>>> ordered_partition_values;
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("file_partition_value\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 5) {
+			throw IOException("aux_catalog runtime returned invalid compaction partition value row: %s", line);
+		}
+		auto table_id = TableIndex(AuxCatalogParseIndex(fields[2], "partition value table id"));
+		if (table_id != expected_table_id) {
+			continue;
+		}
+		auto data_file_id = AuxCatalogParseIndex(fields[1], "partition value data file id");
+		auto partition_key_index = AuxCatalogParseIndex(fields[3], "partition key index");
+		auto partition_value = fields[4] == "__HIVE_DEFAULT_PARTITION__" ? Value() : Value(fields[4]);
+		ordered_partition_values[data_file_id].push_back(std::make_pair(partition_key_index, std::move(partition_value)));
+	}
+	for (auto &entry : ordered_partition_values) {
+		std::sort(entry.second.begin(), entry.second.end(), [](const auto &left, const auto &right) {
+			return left.first < right.first;
+		});
+		auto &values = partition_values[entry.first];
+		for (auto &partition_value : entry.second) {
+			values.push_back(std::move(partition_value.second));
+		}
+	}
+	return partition_values;
+}
+
+static string DataFileIdsPayload(const vector<AuxCatalogFileRow> &rows) {
+	string payload;
+	for (auto &row : rows) {
+		payload += StringUtil::Format("data_file_id\t%d\n", row.data_file_id.index);
+	}
+	return payload;
+}
+
+static void RejectCompactionField(const string &value, const char *field_name) {
+	if (value.find('\t') != string::npos || value.find('\n') != string::npos) {
+		throw NotImplementedException("aux_catalog %s cannot contain tabs or newlines yet", field_name);
+	}
+}
+
+static string SqlLiteralToCompactionPayloadValue(const string &value) {
+	if (value == "NULL") {
+		return string();
+	}
+	if (value.size() < 2 || value.front() != '\'' || value.back() != '\'') {
+		return value;
+	}
+	string out;
+	for (idx_t i = 1; i + 1 < value.size(); i++) {
+		if (value[i] == '\'' && i + 2 < value.size() && value[i + 1] == '\'') {
+			out.push_back('\'');
+			i++;
+		} else {
+			out.push_back(value[i]);
+		}
+	}
+	return out;
+}
+
+static void AppendMergeAdjacentSourcePayload(string &payload, const DuckLakeCompactedFileInfo &file) {
+	if (file.delete_file_id.IsValid()) {
+		throw NotImplementedException("aux_catalog merge-adjacent compaction does not support delete files yet");
+	}
+	payload += StringUtil::Format("source_file\t%d\t%d\n", file.table_index.index, file.source_id.index);
+}
+
+static void AppendRewriteDeleteSourcePayload(string &payload, const DuckLakeCompactedFileInfo &file) {
+	payload += StringUtil::Format("source_file\t%d\t%d\n", file.table_index.index, file.source_id.index);
+}
+
+static void AppendNewFilePayload(string &payload, const DuckLakeFileInfo &file, const string &resolved_path,
+                                 bool require_row_id_start) {
+	RejectCompactionField(resolved_path, "compacted file paths");
+	if (require_row_id_start && !file.row_id_start.IsValid()) {
+		// DuckLake omits metadata row_id_start when the replacement file stores row ids physically.
+		// The Rust catalog derives the metadata row range from the source files.
+	}
+	auto row_id_start = file.row_id_start.IsValid() ? std::to_string(file.row_id_start.GetIndex()) : string();
+	payload += StringUtil::Format("file\t%d\t%d\t%s\t%d\t%d\t%s\t%s\t%s\t%s\t%s\n", file.id.index,
+	                              file.table_id.index,
+	                              resolved_path, file.row_count, file.file_size_bytes, row_id_start,
+	                              file.mapping_id.IsValid() ? std::to_string(file.mapping_id.index) : "",
+	                              file.begin_snapshot.IsValid() ? std::to_string(file.begin_snapshot.GetIndex()) : "",
+	                              file.max_partial_file_snapshot.IsValid()
+	                                  ? std::to_string(file.max_partial_file_snapshot.GetIndex())
+	                                  : "",
+	                              AuxCatalogEncodeEncryptionKey(file.encryption_key));
+	for (auto &partition_value : file.partition_values) {
+		auto value = partition_value.partition_value.IsNull() ? string("__HIVE_DEFAULT_PARTITION__")
+		                                                     : partition_value.partition_value.ToString();
+		RejectCompactionField(value, "compaction partition values");
+		payload += StringUtil::Format("file_partition\t%d\t%d\t%d\t%s\n", file.id.index, file.table_id.index,
+		                              partition_value.partition_column_idx, value);
+	}
+	for (auto &raw_stats : file.column_stats) {
+		auto column_stats = DuckLakeColumnStatsInfo::FromColumnStats(raw_stats.first, raw_stats.second);
+		if (column_stats.null_count == "NULL") {
+			continue;
+		}
+		auto min_value = SqlLiteralToCompactionPayloadValue(column_stats.min_val);
+		auto max_value = SqlLiteralToCompactionPayloadValue(column_stats.max_val);
+		if (column_stats.contains_nan == "true") {
+			min_value.clear();
+			max_value.clear();
+		}
+		auto extra_stats = SqlLiteralToCompactionPayloadValue(column_stats.extra_stats);
+		RejectCompactionField(min_value, "compaction file column stats min values");
+		RejectCompactionField(max_value, "compaction file column stats max values");
+		RejectCompactionField(extra_stats, "compaction file column stats extra stats");
+		payload += StringUtil::Format("file_column_stats\t%d\t%d\t%d\t%s\t%s\t%s\t%s\t%s\n", file.id.index,
+		                              file.table_id.index, column_stats.column_id.index, column_stats.value_count,
+		                              column_stats.null_count, min_value, max_value, extra_stats);
+	}
+}
+
+} // namespace
+
+vector<DuckLakeCompactionFileEntry>
+AuxCatalogMetadataManager::GetFilesForCompaction(DuckLakeTableEntry &table, CompactionType type, double deletion_threshold,
+                                                 DuckLakeSnapshot snapshot, DuckLakeFileSizeOptions options) {
+	if (type != CompactionType::MERGE_ADJACENT_TABLES && type != CompactionType::REWRITE_DELETES) {
+		throw NotImplementedException("aux_catalog compaction type is not implemented yet");
+	}
+	auto rows = ParseFileRows(RunListFilesForTable(table.GetTableId(), snapshot), table.GetTableId());
+	auto partition_values =
+	    ParsePartitionValueRows(RuntimeExecute("ListFilePartitionValuesForDataFileIds", DataFileIdsPayload(rows)),
+	                            table.GetTableId());
+	vector<DuckLakeCompactionFileEntry> files;
+	idx_t max_size = options.max_file_size.IsValid() ? options.max_file_size.GetIndex() : options.target_file_size;
+	for (auto &row : rows) {
+		if (type == CompactionType::MERGE_ADJACENT_TABLES) {
+			if (row.has_delete_file || !row.inlined_file_deletions.empty() || row.file_size_bytes >= max_size) {
+				continue;
+			}
+			if (options.min_file_size.IsValid() && row.file_size_bytes < options.min_file_size.GetIndex()) {
+				continue;
+			}
+		} else {
+			auto total_deletes = row.delete_count + row.inlined_file_deletions.size();
+			if (total_deletes == 0 || row.row_count == 0) {
+				continue;
+			}
+			auto delete_ratio = static_cast<double>(total_deletes) / static_cast<double>(row.row_count);
+			if (delete_ratio < deletion_threshold) {
+				continue;
+			}
+		}
+		DuckLakeCompactionFileEntry entry;
+		entry.file.id = row.data_file_id;
+		entry.file.row_count = row.row_count;
+		entry.file.row_id_start = row.row_id_start;
+		entry.file.mapping_id = row.mapping_id;
+		auto table_partition = table.GetPartitionData();
+		if (table_partition) {
+			entry.file.partition_id = table_partition->partition_id;
+		}
+		auto partition_entry = partition_values.find(row.data_file_id.index);
+		if (partition_entry != partition_values.end()) {
+			entry.file.partition_values = std::move(partition_entry->second);
+		}
+		entry.file.begin_snapshot = row.begin_snapshot.IsValid() ? row.begin_snapshot.GetIndex() : snapshot.snapshot_id;
+		entry.max_partial_file_snapshot = row.max_partial_snapshot;
+		entry.file.data.path = row.path;
+		entry.file.data.file_size_bytes = row.file_size_bytes;
+		entry.file.data.encryption_key = row.data_encryption_key;
+		entry.schema_version = row.schema_version.IsValid() ? row.schema_version.GetIndex() : snapshot.schema_version;
+		if (type == CompactionType::REWRITE_DELETES) {
+			if (row.has_delete_file) {
+				DuckLakeCompactionDeleteFileData delete_file;
+				delete_file.id = row.data_file_id;
+				delete_file.delete_file_id = row.delete_file_id;
+				delete_file.row_count = row.delete_count;
+				delete_file.begin_snapshot = row.delete_begin_snapshot;
+				delete_file.data.path = row.delete_path;
+				delete_file.data.file_size_bytes = row.delete_file_size_bytes;
+				delete_file.data.encryption_key = row.delete_encryption_key;
+				entry.delete_files.push_back(std::move(delete_file));
+			}
+			entry.inlined_file_deletions = row.inlined_file_deletions;
+			entry.has_inlined_deletions = !row.inlined_file_deletions.empty();
+			auto total_deletes = row.delete_count + row.inlined_file_deletions.size();
+			entry.delete_ratio = static_cast<double>(total_deletes) / static_cast<double>(row.row_count);
+		}
+		files.push_back(std::move(entry));
+	}
+	return files;
+}
+
+bool AuxCatalogMetadataManager::TryMergeAdjacentFiles(DuckLakeSnapshot &,
+                                                      const vector<DuckLakeCompactedFileInfo> &compacted_files,
+                                                      const vector<DuckLakeFileInfo> &new_files,
+                                                      const vector<DuckLakeTableInfo> &new_tables,
+                                                      vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	if (compacted_files.empty() && new_files.empty()) {
+		return false;
+	}
+	if (compacted_files.empty()) {
+		throw NotImplementedException("aux_catalog merge-adjacent compaction requires source files");
+	}
+	string payload;
+	for (auto &file : compacted_files) {
+		AppendMergeAdjacentSourcePayload(payload, file);
+		pending_merge_adjacent_data_file_ids_payload += StringUtil::Format("data_file_id\t%d\n", file.source_id.index);
+	}
+	for (auto &file : new_files) {
+		auto path = GetRelativePath(file.table_id, file.file_name, new_tables, new_schemas_result);
+		AppendNewFilePayload(payload, file, FromRelativePath(file.table_id, path), true);
+		pending_merge_adjacent_data_file_ids_payload += StringUtil::Format("data_file_id\t%d\n", file.id.index);
+	}
+	pending_merge_adjacent_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryRewriteDeleteFiles(DuckLakeSnapshot &,
+                                                      const vector<DuckLakeCompactedFileInfo> &compacted_files,
+                                                      const vector<DuckLakeFileInfo> &new_files,
+                                                      const vector<DuckLakeTableInfo> &new_tables,
+                                                      vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	if (compacted_files.empty() && new_files.empty()) {
+		return false;
+	}
+	if (compacted_files.empty()) {
+		throw NotImplementedException("aux_catalog rewrite-delete compaction requires source files");
+	}
+	string payload;
+	for (auto &file : compacted_files) {
+		AppendRewriteDeleteSourcePayload(payload, file);
+	}
+	for (auto &file : new_files) {
+		auto path = GetRelativePath(file.table_id, file.file_name, new_tables, new_schemas_result);
+		AppendNewFilePayload(payload, file, FromRelativePath(file.table_id, path), false);
+	}
+	pending_rewrite_delete_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
