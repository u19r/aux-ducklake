+static unique_ptr<QueryResult> BuildInlineFileDeleteFlushResult(ClientContext &context, const string &output) {
+	vector<string> names {"file_id",        "path",          "path_is_relative", "row_id",
+	                      "begin_snapshot", "delete_file_id", "del_path",         "del_path_is_relative",
+	                      "del_begin_snapshot", "del_encryption_key", "del_format"};
+	vector<LogicalType> types {LogicalType::BIGINT,  LogicalType::VARCHAR, LogicalType::BOOLEAN, LogicalType::BIGINT,
+	                           LogicalType::BIGINT,  LogicalType::BIGINT,  LogicalType::VARCHAR, LogicalType::BOOLEAN,
+	                           LogicalType::BIGINT,  LogicalType::VARCHAR, LogicalType::VARCHAR};
+	AuxCatalogResultBuilder builder(context, std::move(names), std::move(types));
+	std::stringstream stream(output);
+	string line;
+	while (std::getline(stream, line)) {
+		if (line.empty() || line.rfind("inline_file_delete\t", 0) != 0) {
+			continue;
+		}
+		auto fields = AuxCatalogSplitTabLine(line);
+		if (fields.size() != 12) {
+			throw IOException("aux_catalog runtime returned invalid inline file deletion flush row: %s", line);
+		}
+		vector<Value> values;
+		values.push_back(Value::BIGINT(NumericCast<int64_t>(AuxCatalogParseIndex(fields[1], "inline delete file id"))));
+		values.push_back(Value(fields[2]));
+		values.push_back(Value::BOOLEAN(fields[3] == "true"));
+		values.push_back(Value::BIGINT(ParseI64(fields[4], "inline delete row id")));
+		values.push_back(Value::BIGINT(NumericCast<int64_t>(AuxCatalogParseIndex(fields[5], "inline delete begin snapshot"))));
+		if (fields[6].empty()) {
+			values.push_back(Value(LogicalType::BIGINT));
+			values.push_back(Value(LogicalType::VARCHAR));
+			values.push_back(Value(LogicalType::BOOLEAN));
+			values.push_back(Value(LogicalType::BIGINT));
+			values.push_back(Value(LogicalType::VARCHAR));
+			values.push_back(Value(LogicalType::VARCHAR));
+		} else {
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(AuxCatalogParseIndex(fields[6], "delete file id"))));
+			values.push_back(Value(fields[7]));
+			values.push_back(Value::BOOLEAN(fields[8] == "true"));
+			values.push_back(Value::BIGINT(NumericCast<int64_t>(AuxCatalogParseIndex(fields[9], "delete begin snapshot"))));
+			values.push_back(fields[10].empty() ? Value(LogicalType::VARCHAR) : Value(fields[10]));
+			values.push_back(fields[11].empty() ? Value(LogicalType::VARCHAR) : Value(fields[11]));
+		}
+		builder.AppendRow(values);
+	}
+	return builder.Finish();
+}
