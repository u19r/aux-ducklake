+idx_t AuxCatalogMetadataManager::GetNetInlinedRowCount(const string &inlined_table_name, DuckLakeSnapshot snapshot) {
+	vector<string> inlined_table_names {inlined_table_name};
+	return GetNetInlinedRowCount(inlined_table_names, snapshot);
+}
+
+idx_t AuxCatalogMetadataManager::GetNetInlinedRowCount(const vector<string> &inlined_table_names,
+                                                       DuckLakeSnapshot snapshot) {
+	if (inlined_table_names.empty()) {
+		return 0;
+	}
+	string payload = StringUtil::Format("snapshot_id=%d\n", snapshot.snapshot_id);
+	for (auto &inlined_table_name : inlined_table_names) {
+		auto remapped_table_name = RemapCreatedInlinedTableName(inlined_table_name);
+		RejectUnsafeInlinePayloadValue(remapped_table_name, "inlined table name");
+		payload += "inlined_table_name=" + remapped_table_name + "\n";
+	}
+	auto output = RuntimeExecute("ReadInlineRowsForGlobalStatsBatch", payload);
+	auto row_counts = InlineRowCountsFromOutput(output);
+	if (row_counts.size() != inlined_table_names.size()) {
+		throw IOException("aux_catalog runtime returned %d inline stats rows for %d inlined tables", row_counts.size(),
+		                  inlined_table_names.size());
+	}
+	idx_t total = 0;
+	for (auto row_count : row_counts) {
+		total += row_count;
+	}
+	return total;
+}
