+vector<DuckLakeTableSizeInfo> AuxCatalogMetadataManager::GetTableSizes(DuckLakeSnapshot snapshot) {
+	auto catalog = GetCatalogForSnapshot(snapshot);
+	auto output = RuntimeExecute("ListGlobalStatsInputsForSnapshot",
+	                             StringUtil::Format("snapshot_id=%d\ninclude_inline_stats=false\n"
+	                                                "include_file_column_stats=false\n",
+	                                                snapshot.snapshot_id));
+	auto rows = ParseFileRows(output);
+	map<TableIndex, idx_t> table_sizes_by_id;
+	vector<DuckLakeTableSizeInfo> table_sizes;
+	for (auto &table : catalog.tables) {
+		DuckLakeTableSizeInfo table_size;
+		table_size.schema_id = table.schema_id;
+		table_size.table_id = table.id;
+		table_size.table_name = table.name;
+		table_size.table_uuid = table.uuid;
+		table_sizes.push_back(std::move(table_size));
+		table_sizes_by_id[RemapCreatedTableId(table.id)] = table_sizes.size() - 1;
+	}
+	for (auto &row : rows) {
+		auto entry = table_sizes_by_id.find(row.table_id);
+		if (entry == table_sizes_by_id.end()) {
+			continue;
+		}
+		auto &table_size = table_sizes[entry->second];
+		table_size.file_count++;
+		table_size.file_size_bytes += row.file_size_bytes;
+		if (HasDeleteFile(row)) {
+			table_size.delete_file_count++;
+			table_size.delete_file_size_bytes += row.delete_file_size_bytes;
+		}
+	}
+	return table_sizes;
+}
+
+string AuxCatalogMetadataManager::RunPrunableListFilesForTable(DuckLakeTableEntry &table, DuckLakeSnapshot snapshot,
+                                                               const FilterPushdownInfo *filter_info) {
+	auto prune = TryBuildIdentityPartitionPrune(table, filter_info);
+	if (!prune.enabled) {
+		return RunListFilesForTable(table.GetTableId(), snapshot);
+	}
+	if (prune.needs_value_discovery) {
+		auto current = GetSnapshot();
+		if (current && snapshot.snapshot_id == current->snapshot_id) {
+			return RuntimeExecute("ListCurrentDataFilesForPartitionPrune",
+			                      PartitionPrunePayload(table.GetTableId(), prune));
+		}
+		return RuntimeExecute("ListDataFilesForPartitionPruneAt",
+		                      PartitionPruneAtPayload(table.GetTableId(), snapshot, prune));
+	}
+	auto current = GetSnapshot();
+	if (!current || current->snapshot_id != snapshot.snapshot_id) {
+		return RunListFilesForPartitionAt(table.GetTableId(), snapshot, prune.partition_key_index, prune.partition_value);
+	}
+	return RunListCurrentFilesForPartition(table.GetTableId(), prune.partition_key_index, prune.partition_value);
+}
+
+string AuxCatalogMetadataManager::RunListCurrentFilesForPartition(TableIndex table_id, idx_t partition_key_index,
+                                                                  const string &partition_value) {
+	return RuntimeExecute(
+	    "ListCurrentDataFilesForPartitionScan",
+	    StringUtil::Format("table_id=%d\npartition_key_index=%d\npartition_value=%s\n", table_id.index,
+	                       partition_key_index, partition_value));
+}
+
+string AuxCatalogMetadataManager::RunListFilesForPartitionAt(TableIndex table_id, DuckLakeSnapshot snapshot,
+                                                             idx_t partition_key_index,
+                                                             const string &partition_value) {
+	return RuntimeExecute(
+	    "ListDataFilesForPartitionScanAt",
+	    StringUtil::Format("snapshot_id=%d\ntable_id=%d\npartition_key_index=%d\npartition_value=%s\n",
+	                       snapshot.snapshot_id, table_id.index, partition_key_index, partition_value));
+}
+
+vector<DuckLakeFileListEntry> AuxCatalogMetadataManager::GetFilesForTable(DuckLakeTableEntry &table,
+                                                                          DuckLakeSnapshot snapshot,
+                                                                          const FilterPushdownInfo *filter_info) {
+	auto rows = ParseFileRows(RunPrunableListFilesForTable(table, snapshot, filter_info), table.GetTableId());
+	auto dynamic_filter_columns = DynamicFilterColumns(filter_info);
+	string stats_output;
+	map<DataFileIndex, map<idx_t, AuxFileColumnStatsRow>> stats_by_file;
+	if (filter_info && !filter_info->column_filters.empty() && !rows.empty()) {
+		stats_output = RuntimeExecute("ListCurrentMetadataFileColumnStatsForDataFileIds", DataFileIdsPayload(rows));
+		stats_by_file = StatsByFileAndColumn(stats_output);
+	}
+	vector<DuckLakeFileListEntry> files;
+	for (auto &row : rows) {
+		if (!FileMayMatchFilters(row, filter_info, stats_by_file)) {
+			continue;
+		}
+		DuckLakeFileListEntry entry;
+		entry.file_id = row.data_file_id;
+		entry.data_file_id = row.data_file_id.index;
+		entry.row_id_start = row.row_id_start;
+		entry.snapshot_id = row.begin_snapshot;
+		entry.snapshot_filter_max = row.snapshot_filter_max;
+		entry.mapping_id = row.mapping_id;
+		entry.inlined_file_deletions = row.inlined_file_deletions;
+		PopulateFileData(entry.file, row.path, row.file_size_bytes, row.data_file_footer_size,
+		                 row.data_encryption_key);
+		if (HasDeleteFile(row)) {
+			PopulateFileData(entry.delete_file, row.delete_path, row.delete_file_size_bytes, optional_idx(),
+			                 row.delete_encryption_key);
+		}
+		files.push_back(std::move(entry));
+	}
+	if (!dynamic_filter_columns.empty() && !files.empty()) {
+		AttachDynamicFilterStats(files, stats_output, dynamic_filter_columns);
+		SortFilesForDynamicFilter(files, dynamic_filter_columns);
+	}
+	return files;
+}
+
+vector<DuckLakeFileListExtendedEntry>
+AuxCatalogMetadataManager::GetExtendedFilesForTable(DuckLakeTableEntry &table, DuckLakeSnapshot snapshot,
+                                                    const FilterPushdownInfo *filter_info) {
+	auto rows = ParseFileRows(RunPrunableListFilesForTable(table, snapshot, filter_info), table.GetTableId());
+	vector<DuckLakeFileListExtendedEntry> files;
+	for (auto &row : rows) {
+		DuckLakeFileListExtendedEntry entry;
+		entry.file_id = row.data_file_id;
+		entry.row_count = row.row_count;
+		entry.row_id_start = row.row_id_start;
+		entry.mapping_id = row.mapping_id;
+		PopulateFileData(entry.file, row.path, row.file_size_bytes, row.data_file_footer_size,
+		                 row.data_encryption_key);
+		if (HasDeleteFile(row)) {
+			entry.delete_file_id = row.delete_file_id;
+			entry.delete_count = row.delete_count;
+			entry.delete_file_begin_snapshot = row.delete_begin_snapshot;
+			PopulateFileData(entry.delete_file, row.delete_path, row.delete_file_size_bytes, optional_idx(),
+			                 row.delete_encryption_key);
+		}
+		files.push_back(std::move(entry));
+	}
+	return files;
+}
