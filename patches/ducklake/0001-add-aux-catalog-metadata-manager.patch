+static bool HasDeleteFile(const AuxCatalogFileRow &row) {
+	return row.delete_file_id.IsValid();
+}
+
+struct IdentityPartitionPrune {
+	bool enabled = false;
+	bool needs_value_discovery = false;
+	idx_t partition_key_index = 0;
+	LogicalType column_type;
+	ExpressionType comparison = ExpressionType::COMPARE_EQUAL;
+	string partition_value;
+};
+
+static bool IsSimpleFilterSubject(const Expression &expr) {
+	return expr.GetExpressionClass() == ExpressionClass::BOUND_REF ||
+	       expr.GetExpressionClass() == ExpressionClass::BOUND_COLUMN_REF;
+}
+
+static bool IsSafePartitionValue(const string &value) {
+	return value.find('\t') == string::npos && value.find('\n') == string::npos;
+}
+
+static bool TryPartitionValueFromConstant(const Value &constant, const LogicalType &column_type, string &out) {
+	if (constant.IsNull()) {
+		return false;
+	}
+	Value casted;
+	if (!constant.DefaultTryCastAs(column_type, casted, nullptr) || casted.IsNull()) {
+		return false;
+	}
+	out = casted.ToString();
+	return IsSafePartitionValue(out);
+}
+
+static bool TryCollectIdentityComparisonValue(const Expression &expr, const LogicalType &column_type,
+                                              ExpressionType &comparison_out, string &out) {
+	if (BoundComparisonExpression::IsComparison(expr)) {
+		auto &comparison = expr.Cast<BoundFunctionExpression>();
+		auto comparison_type = comparison.GetExpressionType();
+		if (comparison_type != ExpressionType::COMPARE_EQUAL && comparison_type != ExpressionType::COMPARE_GREATERTHAN &&
+		    comparison_type != ExpressionType::COMPARE_GREATERTHANOREQUALTO &&
+		    comparison_type != ExpressionType::COMPARE_LESSTHAN &&
+		    comparison_type != ExpressionType::COMPARE_LESSTHANOREQUALTO) {
+			return false;
+		}
+		auto &left = BoundComparisonExpression::Left(comparison);
+		auto &right = BoundComparisonExpression::Right(comparison);
+		if (IsSimpleFilterSubject(left) && right.GetExpressionClass() == ExpressionClass::BOUND_CONSTANT) {
+			comparison_out = comparison_type;
+			return TryPartitionValueFromConstant(right.Cast<BoundConstantExpression>().GetValue(), column_type, out);
+		}
+		if (IsSimpleFilterSubject(right) && left.GetExpressionClass() == ExpressionClass::BOUND_CONSTANT) {
+			switch (comparison_type) {
+			case ExpressionType::COMPARE_GREATERTHAN:
+				comparison_out = ExpressionType::COMPARE_LESSTHAN;
+				break;
+			case ExpressionType::COMPARE_GREATERTHANOREQUALTO:
+				comparison_out = ExpressionType::COMPARE_LESSTHANOREQUALTO;
+				break;
+			case ExpressionType::COMPARE_LESSTHAN:
+				comparison_out = ExpressionType::COMPARE_GREATERTHAN;
+				break;
+			case ExpressionType::COMPARE_LESSTHANOREQUALTO:
+				comparison_out = ExpressionType::COMPARE_GREATERTHANOREQUALTO;
+				break;
+			default:
+				comparison_out = comparison_type;
+				break;
+			}
+			return TryPartitionValueFromConstant(left.Cast<BoundConstantExpression>().GetValue(), column_type, out);
+		}
+		return false;
+	}
+	if (expr.GetExpressionClass() != ExpressionClass::BOUND_CONJUNCTION ||
+	    expr.GetExpressionType() != ExpressionType::CONJUNCTION_AND) {
+		return false;
+	}
+	auto &conjunction = expr.Cast<BoundConjunctionExpression>();
+	for (auto &child : conjunction.GetChildren()) {
+		if (TryCollectIdentityComparisonValue(*child, column_type, comparison_out, out)) {
+			return true;
+		}
+	}
+	return false;
+}
+
+static IdentityPartitionPrune TryBuildIdentityPartitionPrune(DuckLakeTableEntry &table,
+                                                             const FilterPushdownInfo *filter_info) {
+	IdentityPartitionPrune result;
+	if (!filter_info || filter_info->column_filters.empty()) {
+		return result;
+	}
+	auto partition_data = table.GetPartitionData();
+	if (!partition_data) {
+		return result;
+	}
+	for (auto &field : partition_data->fields) {
+		if (field.transform.type != DuckLakeTransformType::IDENTITY) {
+			continue;
+		}
+		auto filter = filter_info->column_filters.find(field.field_id.index);
+		if (filter == filter_info->column_filters.end() || !filter->second.table_filter ||
+		    !filter->second.table_filter->expr) {
+			continue;
+		}
+		string partition_value;
+		ExpressionType comparison = ExpressionType::COMPARE_EQUAL;
+		if (!TryCollectIdentityComparisonValue(*filter->second.table_filter->expr, filter->second.column_type,
+		                                       comparison, partition_value)) {
+			continue;
+		}
+		result.enabled = true;
+		result.needs_value_discovery = comparison != ExpressionType::COMPARE_EQUAL;
+		result.partition_key_index = field.partition_key_index;
+		result.column_type = filter->second.column_type;
+		result.comparison = comparison;
+		result.partition_value = std::move(partition_value);
+		return result;
+	}
+	return result;
+}
+
+static string PartitionPruneComparisonName(ExpressionType comparison) {
+	switch (comparison) {
+	case ExpressionType::COMPARE_EQUAL:
+		return "equal";
+	case ExpressionType::COMPARE_GREATERTHAN:
+		return "greater_than";
+	case ExpressionType::COMPARE_GREATERTHANOREQUALTO:
+		return "greater_than_or_equal";
+	case ExpressionType::COMPARE_LESSTHAN:
+		return "less_than";
+	case ExpressionType::COMPARE_LESSTHANOREQUALTO:
+		return "less_than_or_equal";
+	default:
+		throw IOException("aux_catalog unsupported partition prune comparison");
+	}
+}
+
+static string PartitionPrunePayload(TableIndex table_id, const IdentityPartitionPrune &prune) {
+	if (!IsSafePartitionValue(prune.partition_value)) {
+		throw IOException("aux_catalog partition value is not safe for runtime payload: %s", prune.partition_value);
+	}
+	auto column_type = prune.column_type.ToString();
+	if (!IsSafePartitionValue(column_type)) {
+		throw IOException("aux_catalog partition column type is not safe for runtime payload: %s", column_type);
+	}
+	return StringUtil::Format("table_id=%d\npartition_key_index=%d\npartition_column_type=%s\ncomparison=%s\n"
+	                          "partition_value=%s\n",
+	                          table_id.index, prune.partition_key_index, column_type,
+	                          PartitionPruneComparisonName(prune.comparison), prune.partition_value);
+}
+
+static string PartitionPruneAtPayload(TableIndex table_id, DuckLakeSnapshot snapshot, const IdentityPartitionPrune &prune) {
+	return StringUtil::Format("snapshot_id=%d\n", snapshot.snapshot_id) +
+	       PartitionPrunePayload(table_id, prune);
+}
