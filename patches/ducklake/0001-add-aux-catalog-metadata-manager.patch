+void AuxCatalogMetadataManager::CommitPendingMetadataPayloads(DuckLakeSnapshot commit_snapshot,
+                                                             bool same_attempt_table_or_partition_metadata) {
+	if (!pending_drop_tables_payload.empty()) {
+		RemovePendingMetadataForDroppedTables(pending_drop_tables_payload, pending_add_columns_payload,
+		                                      pending_change_column_defaults_payload,
+		                                      pending_change_column_types_payload, pending_change_comments_payload,
+		                                      pending_drop_columns_payload, pending_rename_columns_payload,
+		                                      pending_rename_tables_payload, pending_change_partition_keys_payload,
+		                                      pending_change_sort_keys_payload);
+	}
+	string pending_replace_tables_payload;
+	if (!pending_drop_tables_payload.empty() && !pending_create_tables_payload.empty()) {
+		string payload;
+		std::stringstream drops(pending_drop_tables_payload);
+		string line;
+		while (std::getline(drops, line)) {
+			if (line.rfind("commit_snapshot\t", 0) == 0) {
+				continue;
+			}
+			if (line.rfind("table\t", 0) != 0) {
+				throw IOException("aux_catalog invalid pending table drop row: %s", line);
+			}
+			payload += "drop_table\t" + line.substr(6) + "\n";
+		}
+		payload += pending_create_tables_payload;
+		pending_replace_tables_payload = payload;
+		pending_drop_tables_payload.clear();
+		pending_create_tables_payload.clear();
+	}
+	if (!pending_drop_tables_payload.empty()) {
+		RuntimeExecute("DropTables", pending_drop_tables_payload);
+		pending_drop_tables_payload.clear();
+	}
+	auto has_typed_commit_attempt_metadata =
+	    !pending_create_schemas_payload.empty() ||
+	    !pending_drop_schemas_payload.empty() ||
+	    !pending_create_tables_payload.empty() ||
+	    !pending_replace_tables_payload.empty() ||
+	    HasPendingCommitAttemptMetadata(pending_add_columns_payload, pending_change_column_defaults_payload,
+	                                    pending_change_column_types_payload, pending_change_comments_payload,
+	                                    pending_drop_columns_payload, pending_rename_columns_payload,
+	                                    pending_rename_tables_payload, pending_change_partition_keys_payload,
+	                                    pending_change_sort_keys_payload);
+	has_typed_commit_attempt_metadata =
+	    has_typed_commit_attempt_metadata || !pending_change_view_comments_payload.empty();
+	auto explicit_inline_flush_payload = PendingInlineFlushPayload();
+	auto flushed_inline_payload = pending_flushed_inline_payload + explicit_inline_flush_payload;
+	string data_mutation_payload;
+	AppendDataMutationRows(data_mutation_payload, pending_append_files_payload, pending_delete_files_payload,
+	                       flushed_inline_payload, pending_inline_file_delete_payload, pending_dropped_data_files_payload);
+	auto has_data_mutation =
+	    HasPendingDataMutationPayload(pending_append_files_payload, pending_delete_files_payload, flushed_inline_payload,
+	                                  pending_inline_file_delete_payload, pending_dropped_data_files_payload);
+	auto has_compaction_payloads = !pending_merge_adjacent_payload.empty() || !pending_rewrite_delete_payload.empty();
+	auto has_inline_payloads = !pending_register_inline_tables_payload.empty() ||
+	                           !pending_register_inline_rows_payload.empty() || !pending_inline_deletes_payload.empty();
+	if ((has_typed_commit_attempt_metadata || has_compaction_payloads || has_inline_payloads || has_data_mutation) &&
+	    (!pending_metadata_batch || has_typed_commit_attempt_metadata || has_compaction_payloads)) {
+		auto commit_attempt_snapshot_id = commit_snapshot.snapshot_id;
+		auto inline_rows_payload = pending_register_inline_rows_payload;
+		PromoteDeletedRowBeginPayloads(inline_rows_payload, pending_inline_deletes_payload);
+		auto payload = PendingCommitAttemptPayload(commit_attempt_snapshot_id, active_read_snapshot_id,
+		                                           transaction.GetCommitInfo(), pending_create_schemas_payload,
+		                                           pending_drop_schemas_payload, pending_create_tables_payload,
+		                                           pending_replace_tables_payload, pending_add_columns_payload,
+		                                           pending_change_column_defaults_payload,
+		                                           pending_change_column_types_payload, pending_change_comments_payload,
+		                                           pending_change_view_comments_payload, pending_drop_columns_payload,
+		                                           pending_rename_columns_payload, pending_rename_tables_payload,
+		                                           pending_change_partition_keys_payload, pending_change_sort_keys_payload,
+		                                           pending_merge_adjacent_payload, pending_rewrite_delete_payload,
+		                                           data_mutation_payload, pending_register_inline_tables_payload,
+		                                           inline_rows_payload, pending_inline_deletes_payload);
+		auto output = RuntimeExecute("CommitAttempt", payload);
+		transaction.ApplyExternalMetadataCommit(RequireRuntimeIndex(output, "ducklake_schema_version"));
+		active_read_snapshot_id = commit_attempt_snapshot_id;
+		ApplyCreatedTableRemaps(output, pending_register_inline_tables_payload, pending_register_inline_rows_payload,
+		                         pending_inline_deletes_payload, pending_flushed_inline_payload, &transaction, *this);
+		pending_create_schemas_payload.clear();
+		pending_drop_schemas_payload.clear();
+		pending_create_tables_payload.clear();
+		pending_add_columns_payload.clear();
+		pending_change_column_defaults_payload.clear();
+		pending_change_column_types_payload.clear();
+		pending_change_comments_payload.clear();
+		pending_change_view_comments_payload.clear();
+		pending_drop_columns_payload.clear();
+		pending_rename_columns_payload.clear();
+		pending_rename_tables_payload.clear();
+		pending_change_partition_keys_payload.clear();
+		pending_change_sort_keys_payload.clear();
+		pending_register_inline_tables_payload.clear();
+		pending_register_inline_rows_payload.clear();
+		pending_inline_deletes_payload.clear();
+		pending_inline_file_delete_payload.clear();
+		pending_flushed_inline_payload.clear();
+		pending_merge_adjacent_payload.clear();
+		pending_merge_adjacent_data_file_ids_payload.clear();
+		pending_rewrite_delete_payload.clear();
+		{
+			std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+			pending_inline_flushes.clear();
+		}
+		pending_dropped_data_files_payload.clear();
+		pending_delete_files_payload.clear();
+		pending_delete_file_ids_payload.clear();
+		pending_append_files_payload.clear();
+		pending_append_data_file_ids_payload.clear();
+	}
+	if (!pending_register_inline_tables_payload.empty()) {
+		RuntimeExecute("RegisterInlineTables", pending_register_inline_tables_payload);
+		transaction.ApplyExternalDataMutationCommit(vector<TableIndex>());
+		pending_register_inline_tables_payload.clear();
+	}
+	if (!pending_register_inline_rows_payload.empty()) {
+		auto payload = pending_register_inline_rows_payload;
+		PromoteDeletedRowBeginPayloads(payload, pending_inline_deletes_payload);
+		AppendCommitInfoRows(payload, transaction.GetCommitInfo());
+		if (active_read_snapshot_id.IsValid() && !same_attempt_table_or_partition_metadata) {
+			payload = StringUtil::Format("read_snapshot\t%d\n", active_read_snapshot_id.GetIndex()) + payload;
+		}
+		RuntimeExecute("RegisterInlineRows", payload);
+		transaction.ApplyExternalDataMutationCommit(vector<TableIndex>());
+		pending_register_inline_rows_payload.clear();
+	}
+	if (!pending_inline_deletes_payload.empty()) {
+		auto payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id) + pending_inline_deletes_payload;
+		RuntimeExecute("DeleteInlineRows", payload);
+		transaction.ApplyExternalDataMutationCommit(vector<TableIndex>());
+		pending_inline_deletes_payload.clear();
+	}
+	if (!pending_drop_macros_payload.empty()) {
+		RuntimeExecute("DropMacros", pending_drop_macros_payload);
+		pending_drop_macros_payload.clear();
+	}
+	if (!pending_create_macros_payload.empty()) {
+		RuntimeExecute("CreateMacros", pending_create_macros_payload);
+		pending_create_macros_payload.clear();
+	}
+}
+
+void AuxCatalogMetadataManager::BeginCommitAttempt(DuckLakeSnapshot transaction_snapshot) {
+	commit_attempt_active = true;
+	active_read_snapshot_id = transaction_snapshot.snapshot_id;
+}
+
+void AuxCatalogMetadataManager::EndCommitAttempt() {
+	ClearPendingCommitPayloads();
+	commit_attempt_active = false;
+	active_read_snapshot_id = optional_idx();
+}
+
+void AuxCatalogMetadataManager::ClearPendingCommitPayloads() {
+	pending_metadata_batch = false;
+	pending_create_schemas_payload.clear();
+	pending_create_tables_payload.clear();
+	pending_drop_schemas_payload.clear();
+	pending_drop_tables_payload.clear();
+	pending_rename_tables_payload.clear();
+	pending_add_columns_payload.clear();
+	pending_drop_columns_payload.clear();
+	pending_rename_columns_payload.clear();
+	pending_change_column_defaults_payload.clear();
+	pending_change_column_types_payload.clear();
+	pending_change_comments_payload.clear();
+	pending_change_view_comments_payload.clear();
+	pending_change_partition_keys_payload.clear();
+	pending_change_sort_keys_payload.clear();
+	pending_register_inline_tables_payload.clear();
+	pending_register_inline_rows_payload.clear();
+	pending_inline_deletes_payload.clear();
+	pending_create_macros_payload.clear();
+	pending_drop_macros_payload.clear();
+	pending_inline_file_delete_payload.clear();
+	pending_flushed_inline_payload.clear();
+	pending_dropped_data_files_payload.clear();
+	pending_delete_files_payload.clear();
+	pending_delete_file_ids_payload.clear();
+	pending_append_files_payload.clear();
+	pending_append_data_file_ids_payload.clear();
+	pending_merge_adjacent_payload.clear();
+	pending_merge_adjacent_data_file_ids_payload.clear();
+	pending_rewrite_delete_payload.clear();
+	{
+		std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+		pending_inline_flushes.clear();
+	}
+}
+
+void AuxCatalogMetadataManager::CommitPendingDataMutation(DuckLakeSnapshot commit_snapshot, bool include_read_snapshot) {
+	auto explicit_inline_flush_payload = PendingInlineFlushPayload();
+	auto flushed_inline_payload = pending_flushed_inline_payload + explicit_inline_flush_payload;
+	if (pending_append_files_payload.empty() && pending_delete_files_payload.empty() &&
+	    pending_dropped_data_files_payload.empty() && flushed_inline_payload.empty() &&
+	    pending_inline_file_delete_payload.empty()) {
+		return;
+	}
+	auto payload = PendingDataMutationPayload(pending_append_files_payload, pending_delete_files_payload, flushed_inline_payload,
+	                                          pending_inline_file_delete_payload, pending_dropped_data_files_payload, commit_snapshot.snapshot_id,
+	                                          include_read_snapshot ? active_read_snapshot_id : optional_idx(),
+	                                          transaction.GetCommitInfo());
+	auto output = RuntimeExecute("CommitDataMutation", payload);
+	transaction.ApplyExternalDataMutationCommit(OptionalRuntimeTableIndexList(output, "affected_table_ids"));
+	pending_inline_file_delete_payload.clear();
+	pending_flushed_inline_payload.clear();
+	{
+		std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+		pending_inline_flushes.clear();
+	}
+	pending_dropped_data_files_payload.clear();
+	pending_delete_files_payload.clear();
+	pending_delete_file_ids_payload.clear();
+	pending_append_files_payload.clear();
+	pending_append_data_file_ids_payload.clear();
+}
