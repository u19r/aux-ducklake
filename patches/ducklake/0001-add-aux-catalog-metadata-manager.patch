 namespace duckdb {
 
+static void MarkInlinedDataCommitted(vector<DuckLakeInlinedDataInfo> &new_inlined_data, idx_t commit_snapshot_id) {
+	for (auto &entry : new_inlined_data) {
+		if (!entry.data || !entry.data->data) {
+			continue;
+		}
+		auto row_count = entry.data->data->Count();
+		auto &begin_snapshots = entry.data->begin_snapshot_ids;
+		if (begin_snapshots.empty()) {
+			begin_snapshots.assign(row_count, optional_idx(commit_snapshot_id));
+			continue;
+		}
+		if (begin_snapshots.size() != row_count) {
+			throw InternalException("inlined data begin snapshot count does not match row count");
+		}
+		for (auto &begin_snapshot : begin_snapshots) {
+			if (!begin_snapshot.IsValid()) {
+				begin_snapshot = optional_idx(commit_snapshot_id);
+			}
+		}
+	}
+}
