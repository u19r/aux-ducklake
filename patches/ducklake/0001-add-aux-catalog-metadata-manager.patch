+		return;
+	}
+	lock_guard<mutex> guard(lock);
+	auto entry = changes.find(requested_table_id);
+	if (entry == changes.end()) {
+		return;
+	}
+	auto existing = changes.find(persisted_table_id);
+	if (existing != changes.end()) {
+		throw InternalException("Cannot remap DuckLake local table changes to an existing table id");
+	}
+	auto table_changes = std::move(entry->second);
+	changes.erase(entry);
+	changes.emplace(persisted_table_id, std::move(table_changes));
+}
