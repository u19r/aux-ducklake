+idx_t AuxCatalogMetadataManager::GetBeginSnapshotForSchemaVersion(TableIndex table_id, idx_t schema_version) {
+	table_id = RemapCreatedTableId(table_id);
+	auto output = RuntimeExecute("GetBeginSnapshotForSchemaVersion",
+	                             StringUtil::Format("table_id=%d\nschema_version=%d\n", table_id.index, schema_version));
+	return RequireRuntimeIndex(output, "begin_snapshot_id");
+}
+
+bool AuxCatalogMetadataManager::TryAppendDataFiles(DuckLakeSnapshot &commit_snapshot, const vector<DuckLakeFileInfo> &new_files,
+                                                   const vector<DuckLakeTableInfo> &new_tables,
+                                                   vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	if (new_files.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &file : new_files) {
+		auto path = GetRelativePath(file.table_id, file.file_name, new_tables, new_schemas_result);
+		AppendFilePayload(payload, file, FromRelativePath(file.table_id, path));
+		pending_append_data_file_ids_payload += StringUtil::Format("data_file_id\t%d\n", file.id.index);
+	}
+	pending_append_files_payload += payload;
+	{
+		std::lock_guard<std::mutex> guard(pending_inline_flushes_lock);
+		pending_inline_flushes.clear();
+	}
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryCreateTables(DuckLakeSnapshot &commit_snapshot,
+                                                const vector<DuckLakeTableInfo> &new_tables) {
+	if (new_tables.empty()) {
+		return false;
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &table : new_tables) {
+		AppendTablePayload(payload, table);
+	}
+	pending_create_tables_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryCreateSchemas(DuckLakeSnapshot &commit_snapshot,
+                                                 const vector<DuckLakeSchemaInfo> &new_schemas) {
+	if (new_schemas.empty()) {
+		return false;
+	}
+	string payload = StringUtil::Format("commit_snapshot\t%d\n", commit_snapshot.snapshot_id);
+	for (auto &schema : new_schemas) {
+		RejectRuntimeField(schema.uuid, "schema UUIDs");
+		RejectRuntimeField(schema.name, "schema names");
+		RejectRuntimeField(schema.path, "schema paths");
+		payload += StringUtil::Format("schema\t%d\t%s\t%s\t%s\n", schema.id.index, schema.uuid, schema.name,
+		                              schema.path);
+	}
+	pending_create_schemas_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+bool AuxCatalogMetadataManager::TryDropSchemas(DuckLakeSnapshot &, const set<SchemaIndex> &dropped_schemas) {
+	if (dropped_schemas.empty()) {
+		return false;
+	}
+	string payload;
+	for (auto &schema_id : dropped_schemas) {
+		payload += StringUtil::Format("schema\t%d\n", schema_id.index);
+	}
+	pending_drop_schemas_payload += payload;
+	pending_metadata_batch = true;
+	return true;
+}
+
+string AuxCatalogMetadataManager::GetPathForSchema(SchemaIndex schema_id,
+                                                   vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	for (auto &schema : new_schemas_result) {
+		if (schema.id == schema_id) {
+			return schema.path;
+		}
+	}
+	if (schema_id.index == 0) {
+		auto &ducklake_catalog = transaction.GetCatalog();
+		return ducklake_catalog.DataPath() + "main" + ducklake_catalog.Separator();
+	}
+	auto snapshot = GetSnapshot();
+	auto catalog = GetCatalogForSnapshot(*snapshot);
+	for (auto &schema : catalog.schemas) {
+		if (schema.id == schema_id) {
+			return schema.path;
+		}
+	}
+	throw IOException("aux_catalog could not find schema id %d for path resolution", schema_id.index);
+}
+
+string AuxCatalogMetadataManager::GetPathForTable(TableIndex table_id, const vector<DuckLakeTableInfo> &new_tables,
+                                                  const vector<DuckLakeSchemaInfo> &new_schemas_result) {
+	unique_ptr<DuckLakeCatalogInfo> persisted_catalog;
+	for (auto &table : new_tables) {
+		if (table.id == table_id) {
+			string schema_path;
+			for (auto &schema : new_schemas_result) {
+				if (schema.id == table.schema_id) {
+					schema_path = schema.path;
+					break;
+				}
+			}
+			if (schema_path.empty()) {
+				if (!persisted_catalog) {
+					auto snapshot = GetSnapshot();
+					persisted_catalog = make_uniq<DuckLakeCatalogInfo>(GetCatalogForSnapshot(*snapshot));
+				}
+				for (auto &schema : persisted_catalog->schemas) {
+					if (schema.id == table.schema_id) {
+						schema_path = schema.path;
+						break;
+					}
+				}
+			}
+			if (schema_path.empty()) {
+				throw IOException("aux_catalog could not find schema id %d for table path resolution",
+				                  table.schema_id.index);
+			}
+			return FromRelativePath(GetRelativePath(table.path, schema_path), schema_path);
+		}
+	}
+	if (!persisted_catalog) {
+		auto snapshot = GetSnapshot();
+		persisted_catalog = make_uniq<DuckLakeCatalogInfo>(GetCatalogForSnapshot(*snapshot));
+	}
+	for (auto &table : persisted_catalog->tables) {
+		if (table.id == table_id) {
+			return table.path;
+		}
+	}
+	throw IOException("aux_catalog could not find table id %d for path resolution", table_id.index);
+}
+
+unique_ptr<QueryResult> AuxCatalogMetadataManager::Execute(DuckLakeSnapshot snapshot, string &query) {
+	auto committed_column_mappings = CommitColumnMappingSql(query);
+	auto committed_generated_inline_flushes = AppendGeneratedInlineFlushDeletes(pending_flushed_inline_payload, query);
+	auto has_pending_data_mutation =
+	    HasPendingDataMutationPayload(pending_append_files_payload, pending_delete_files_payload,
+	                                  pending_flushed_inline_payload + PendingInlineFlushPayload(),
+	                                  pending_inline_file_delete_payload, pending_dropped_data_files_payload);
+	auto has_pending_compaction = !pending_merge_adjacent_payload.empty() || !pending_rewrite_delete_payload.empty();
+	auto committed_generated_inline_file_delete_flush = query.find("ducklake_inlined_delete_") != string::npos;
+	if (!pending_metadata_batch && !committed_column_mappings && !committed_generated_inline_flushes &&
+	    !has_pending_data_mutation && !has_pending_compaction && !committed_generated_inline_file_delete_flush) {
+		throw NotImplementedException("conflict: aux_catalog cannot execute unhandled SQL metadata batches");
+	}
+	if (has_pending_compaction && !commit_attempt_active) {
+		return transaction.ExecuteRaw("SELECT 1");
+	}
+	auto same_attempt_table_or_partition_metadata =
+	    !pending_create_tables_payload.empty() || !pending_change_partition_keys_payload.empty();
+	auto mirror_refresh_plan = PendingMirrorRefreshPlan(pending_flushed_inline_payload + PendingInlineFlushPayload());
+	CommitPendingMetadataPayloads(snapshot, same_attempt_table_or_partition_metadata);
+	CommitPendingDataMutation(snapshot, !same_attempt_table_or_partition_metadata);
+	ApplyMirrorRefreshPlan(snapshot, mirror_refresh_plan);
+	if (std::getenv("AUX_DUCKLAKE_VALIDATE_MIRROR_KEYS")) {
+		ValidateMirrorPrimaryKeys();
+	}
+	pending_metadata_batch = false;
+	RuntimeExecute("CommitMetadataBatch", "");
+	return transaction.ExecuteRaw("SELECT 1");
+}
+
+AuxCatalogMetadataManager::MirrorRefreshPlan
+AuxCatalogMetadataManager::PendingMirrorRefreshPlan(const string &flushed_inline_payload) const {
+	MirrorRefreshPlan plan;
+	auto table_metadata_changed = !pending_create_tables_payload.empty() || !pending_drop_tables_payload.empty() ||
+	                              !pending_rename_tables_payload.empty() || !pending_change_partition_keys_payload.empty();
+	auto schema_metadata_changed = !pending_create_schemas_payload.empty() || !pending_drop_schemas_payload.empty();
+	auto column_metadata_changed =
+	    !pending_add_columns_payload.empty() || !pending_drop_columns_payload.empty() ||
+	    !pending_rename_columns_payload.empty() || !pending_change_column_defaults_payload.empty() ||
+	    !pending_change_column_types_payload.empty() || !pending_change_comments_payload.empty() ||
+	    !pending_change_sort_keys_payload.empty();
+	auto data_files_changed = !pending_append_files_payload.empty() || !pending_dropped_data_files_payload.empty() ||
+	                          !pending_merge_adjacent_payload.empty() || !pending_rewrite_delete_payload.empty();
+	auto delete_files_changed = !pending_delete_files_payload.empty() || !pending_inline_file_delete_payload.empty() ||
+	                            !pending_merge_adjacent_payload.empty() || !pending_rewrite_delete_payload.empty();
+	auto can_bound_append_files = !pending_append_files_payload.empty() && pending_dropped_data_files_payload.empty() &&
+	                              pending_merge_adjacent_payload.empty() && pending_rewrite_delete_payload.empty();
+	auto can_bound_merge_adjacent = pending_append_files_payload.empty() && pending_dropped_data_files_payload.empty() &&
+	                                !pending_merge_adjacent_payload.empty() && pending_rewrite_delete_payload.empty();
+	auto can_bound_delete_files = !pending_delete_files_payload.empty() && pending_inline_file_delete_payload.empty() &&
+	                              pending_merge_adjacent_payload.empty() && pending_rewrite_delete_payload.empty();
+	auto cleanup_changed = pending_dropped_data_files_payload.empty() && can_bound_delete_files
+	                           ? false
+	                           : (!pending_dropped_data_files_payload.empty() || !pending_inline_file_delete_payload.empty() ||
+	                              !pending_merge_adjacent_payload.empty() || !pending_rewrite_delete_payload.empty());
+
+	plan.partition_info = table_metadata_changed || schema_metadata_changed || column_metadata_changed || data_files_changed;
+	plan.partition_value = data_files_changed || plan.partition_info;
+	plan.data_file = data_files_changed;
+	plan.delete_file = delete_files_changed || data_files_changed;
+	plan.scheduled_cleanup = cleanup_changed;
+	plan.file_column_stats = data_files_changed;
+	plan.table_column_stats = plan.file_column_stats || plan.data_file;
+	if (can_bound_append_files || can_bound_merge_adjacent) {
+		plan.append_files_payload = can_bound_append_files ? pending_append_files_payload : pending_merge_adjacent_payload;
+		plan.data_file_ids_payload =
+		    can_bound_append_files ? pending_append_data_file_ids_payload : pending_merge_adjacent_data_file_ids_payload;
+	}
+	if (can_bound_delete_files) {
+		plan.delete_file_ids_payload = pending_delete_file_ids_payload;
+	}
+	return plan;
+}
+
+void AuxCatalogMetadataManager::ApplyMirrorRefreshPlan(DuckLakeSnapshot snapshot, const MirrorRefreshPlan &plan) {
+	auto append_refresh_bounded = !plan.data_file_ids_payload.empty();
+	auto delete_refresh_bounded = !plan.delete_file_ids_payload.empty();
+	if (plan.partition_info) {
+		RefreshPartitionInfoMirrorTable(snapshot);
+	}
+	if (append_refresh_bounded) {
+		ApplyBoundedAppendMirrorRefresh(plan);
+	} else if (plan.partition_value) {
+		RefreshPartitionValueMirrorTable();
+	}
+	if (!append_refresh_bounded && plan.data_file) {
+		RefreshDataFileMirrorTable();
+	}
+	if (delete_refresh_bounded) {
+		ApplyBoundedDeleteFileMirrorRefresh(plan);
+	} else if (plan.delete_file) {
+		RefreshDeleteFileMirrorTable();
+	}
+	if (plan.scheduled_cleanup) {
+		RefreshScheduledCleanupMirrorTable();
+	}
+	if (!append_refresh_bounded && plan.file_column_stats) {
+		RefreshFileColumnStatsMirrorTable();
+	}
+	if (plan.table_column_stats) {
+		RefreshTableColumnStatsMirrorTable();
+	}
+}
+
+void AuxCatalogMetadataManager::ApplyBoundedAppendMirrorRefresh(const MirrorRefreshPlan &plan) {
+	EnsurePartitionValueMirrorTable();
+	EnsureDataFileMirrorTable();
+	EnsureFileColumnStatsMirrorTable();
+	auto query =
+	    AuxCatalogRuntimeSqlPayload(RuntimeExecute("RenderBoundedAppendMirrorSql", plan.data_file_ids_payload + plan.append_files_payload));
+	SubstituteCatalogPlaceholders(query);
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		result->GetErrorObject().Throw("Failed to apply bounded aux append mirror refresh: ");
+	}
+}
+
+void AuxCatalogMetadataManager::ApplyBoundedDeleteFileMirrorRefresh(const MirrorRefreshPlan &plan) {
+	EnsureDeleteFileMirrorTable();
+	auto query = AuxCatalogRuntimeSqlPayload(RuntimeExecute("RenderBoundedDeleteFileMirrorSql", plan.delete_file_ids_payload));
+	SubstituteCatalogPlaceholders(query);
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		result->GetErrorObject().Throw("Failed to apply bounded aux delete file mirror refresh: ");
+	}
+}
+
+void AuxCatalogMetadataManager::ValidateMirrorPrimaryKeys() {
+	string query = R"(
+SELECT table_name, key_value, key_count
+FROM (
+	SELECT 'ducklake_data_file' AS table_name, data_file_id AS key_value, count(*) AS key_count
+	FROM {METADATA_CATALOG}.ducklake_data_file
+	GROUP BY data_file_id
+	HAVING count(*) > 1
+	UNION ALL
+	SELECT 'ducklake_delete_file' AS table_name, delete_file_id AS key_value, count(*) AS key_count
+	FROM {METADATA_CATALOG}.ducklake_delete_file
+	GROUP BY delete_file_id
+	HAVING count(*) > 1
+) duplicates
+LIMIT 1;
+)";
+	SubstituteCatalogPlaceholders(query);
+	auto result = transaction.ExecuteRaw(query);
+	if (result->HasError()) {
+		result->GetErrorObject().Throw("Failed to validate aux metadata mirror primary keys: ");
+	}
+	for (auto &row : *result) {
+		throw IOException("aux_catalog metadata mirror has duplicate %s key %d (%d rows)",
+		                  row.GetValue<string>(0), row.GetValue<idx_t>(1), row.GetValue<idx_t>(2));
+	}
+}
